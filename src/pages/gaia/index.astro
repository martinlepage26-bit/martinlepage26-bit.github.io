---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GaiaAppExperience from '../../components/gaia/GaiaAppExperience.astro';
import '../../styles/gaia-theme.css';
import { buildCanonical } from '../../lib/seo';

const pageDescription =
  "GAIA is an Earth-based online astrology app built from Breath of the Astral Year, with general readings and daily horoscope.";

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'GAIA',
  description: pageDescription,
  applicationCategory: 'LifestyleApplication',
  url: buildCanonical('/gaia/'),
  creator: {
    '@type': 'Person',
    name: 'Martin Lepage',
  },
  isBasedOn: {
    '@type': 'Book',
    name: 'Breath of the Astral Year',
    url: buildCanonical('/gaia/book/'),
  },
};
---

<BaseLayout
  title="GAIA App"
  description={pageDescription}
  image="/social/og-breath-of-the-astral-year.png"
  canonical="/gaia/"
  structuredData={structuredData}
>
  <GaiaAppExperience />
</BaseLayout>
