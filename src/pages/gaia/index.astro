---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GaiaAppExperience from '../../components/gaia/GaiaAppExperience.astro';
import { buildCanonical } from '../../lib/seo';

const pageDescription =
  "GAIA is the public gaialogy reading surface built from Breath of the Astral Year, with grounded sign profiles, seasonal readings, and daily modulation.";

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'GAIA',
  description: pageDescription,
  applicationCategory: 'LifestyleApplication',
  url: buildCanonical('/gaia/'),
  creator: {
    '@type': 'Person',
    name: 'Martin Lepage',
  },
  isBasedOn: {
    '@type': 'Book',
    name: 'Breath of the Astral Year',
    url: buildCanonical('/gaia/book/'),
  },
};
---

<BaseLayout
  title="GAIA"
  description={pageDescription}
  image="/social/og-breath-of-the-astral-year.png"
  canonical="/gaia/"
  structuredData={structuredData}
  extraStyles={['/gaia/gaia-theme.css']}
>
  <GaiaAppExperience />
</BaseLayout>
