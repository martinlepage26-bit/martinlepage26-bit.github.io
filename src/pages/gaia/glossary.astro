---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionIntro from '../../components/SectionIntro.astro';
import AstralGlossaryGrid from '../../components/astral/AstralGlossaryGrid.astro';
import { gaialogySigns } from '../../data/astralYear';
import { buildCanonical } from '../../lib/seo';
import '../../styles/gaia-theme.css';

const pageDescription =
  'The GAIA glossary defines the 12 signs from Breath of the Astral Year through competence, civic weather, body register, social pattern, shadow, and ritual.';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'GAIA Glossary',
  description: pageDescription,
  url: buildCanonical('/gaia/glossary/'),
};
---

<BaseLayout
  title="GAIA Glossary"
  description={pageDescription}
  canonical="/gaia/glossary/"
  structuredData={structuredData}
>
  <section class="relative overflow-hidden border-b border-[rgba(255,255,255,0.08)]">
    <div class="section-shell gaia-cosmos-shell">
      <div class="gaia-orbit gaia-orbit-one"></div>
      <div class="gaia-orbit gaia-orbit-two"></div>

      <div class="grid gap-10 lg:grid-cols-[minmax(0,1.08fr)_minmax(320px,0.92fr)] lg:items-end">
        <div class="relative z-10 max-w-4xl">
          <p class="eyebrow">Companion guide</p>
          <h1 class="mt-5">GAIA Glossary</h1>
          <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-100 md:text-xl">
            Breath of the Astral Year reads the gaialogy as a grounded language for earthly life. This glossary names
            what each sign is for, how it feels in the body, how it moves through relations, and where it can fray.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a class="button-primary" href="#gaia-glossary-grid">Browse the signs</a>
            <a class="button-secondary" href="/gaia/">Open the GAIA app</a>
            <a class="button-secondary" href="/gaia/book/">Back to the book page</a>
          </div>
          <p class="mt-5 max-w-2xl text-sm leading-6 text-slate-300">
            Use this page as a reading key. The sign language here is descriptive rather than predictive, and each
            entry stays close to the book&apos;s vocabulary.
          </p>
        </div>

        <div class="veil-panel gaia-panel relative z-10">
          <p class="eyebrow">How to read it</p>
          <div class="mt-5 grid gap-4">
            <div class="gaia-mini-card">
              <p class="gaia-mini-label">Competence</p>
              <p class="mt-2 text-base leading-7 text-slate-200">
                The sign&apos;s practical talent, the kind of movement it knows how to make well.
              </p>
            </div>
            <div class="gaia-mini-card">
              <p class="gaia-mini-label">Civic weather</p>
              <p class="mt-2 text-base leading-7 text-slate-200">
                The public atmosphere the sign names: rupture, reciprocity, structure, release, and similar climates.
              </p>
            </div>
            <div class="gaia-mini-card">
              <p class="gaia-mini-label">Body and relation</p>
              <p class="mt-2 text-base leading-7 text-slate-200">
                Body register, social pattern, shadow, and ritual tell you how the sign behaves when lived, strained,
                or carried forward.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-shell border-y border-[rgba(255,255,255,0.08)] bg-[rgba(8,11,16,0.72)]">
    <SectionIntro
      eyebrow="Reading guide"
      title="The glossary works as a translation layer."
      description="It turns each sign into a compact set of definitions that future seasonal reading output can use without becoming vague or generic."
    />

    <div class="mt-12 gaia-grid-3">
      <article class="veil-panel gaia-panel gaia-guide-card">
        <p class="gaia-guide-label">1. Competence</p>
        <p class="mt-3 text-base leading-7 text-slate-200">
          Start with what the sign does well. That is the sign&apos;s most useful motion, not its marketing line.
        </p>
      </article>
      <article class="veil-panel gaia-panel gaia-guide-card">
        <p class="gaia-guide-label">2. Weather</p>
        <p class="mt-3 text-base leading-7 text-slate-200">
          The civic theme and body register show the sign&apos;s climate in public life and in lived sensation.
        </p>
      </article>
      <article class="veil-panel gaia-panel gaia-guide-card">
        <p class="gaia-guide-label">3. Pressure</p>
        <p class="mt-3 text-base leading-7 text-slate-200">
          Shadow and ritual keep the language honest. They mark where the sign bends badly and how it can be used
          again without flattening into cliche.
        </p>
      </article>
    </div>
  </section>

  <section class="section-shell">
    <SectionIntro
      eyebrow="The signs"
      title="Twelve entries, grouped by element."
      description="Fire, earth, air, and water set the larger climate. Each sign then gives that climate a more exact voice."
    />

    <div class="mt-12">
      <AstralGlossaryGrid signs={gaialogySigns} />
    </div>
  </section>

  <section class="section-shell border-t border-[rgba(36,27,23,0.08)]">
    <div class="grid gap-6 lg:grid-cols-[minmax(0,1.05fr)_minmax(320px,0.95fr)]">
      <article class="veil-panel gaia-panel">
        <p class="eyebrow">Why it matters</p>
        <h2 class="mt-4 text-[1.18rem] md:text-[1.36rem]">This is the book&apos;s vocabulary bank.</h2>
        <p class="mt-4 text-base leading-7 text-slate-200">
          The glossary keeps the project from collapsing into loose seasonal reading prose. It gives each sign a stable
          profile so future pages can generate interpretations that still sound like Breath of the Astral Year.
        </p>
      </article>
      <article class="veil-panel gaia-panel">
        <p class="eyebrow">Use case</p>
        <h2 class="mt-4 text-[1.18rem] md:text-[1.36rem]">Reference, then reuse.</h2>
        <p class="mt-4 text-base leading-7 text-slate-200">
          Read the sign once as a glossary entry. Use it again as a source for seasonal reading copy, app copy, or any later
          GAIA interface that needs the language to stay grounded.
        </p>
      </article>
    </div>
  </section>
</BaseLayout>
