---
import { existsSync } from 'node:fs';
import { join } from 'node:path';
import { fileURLToPath } from 'node:url';
import type { CollectionEntry } from 'astro:content';
import { getCollection, render } from 'astro:content';
import EntryHero from '../../components/EntryHero.astro';
import { hiddenProjectArchiveSlugs, projectArchivePromotedPaperSlugs } from '../../data/site';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { contentSlug, isPublishedPaper, joinDistinctText } from '../../lib/content';
import { buildArticleSchema, buildCanonical } from '../../lib/seo';

type ProjectEntry = CollectionEntry<'projects'>;
type PaperEntry = CollectionEntry<'papers'>;

export async function getStaticPaths() {
  const hiddenProjectArchiveSlugSet = new Set<string>(hiddenProjectArchiveSlugs);
  const promotedPaperSlugSet = new Set<string>(projectArchivePromotedPaperSlugs);
  const projects = (await getCollection('projects')).filter(
    (project) => !hiddenProjectArchiveSlugSet.has(contentSlug(project.id)),
  );
  const unpublishedPapers = (await getCollection('papers')).filter(
    (paper) => !isPublishedPaper(paper) && !promotedPaperSlugSet.has(contentSlug(paper.id)),
  );

  return [
    ...projects.map((project) => ({
      params: { slug: contentSlug(project.id) },
      props: { entryKind: 'project', entry: project },
    })),
    ...unpublishedPapers.map((paper) => ({
      params: { slug: contentSlug(paper.id) },
      props: { entryKind: 'paper', entry: paper },
    })),
  ];
}

interface Props {
  entryKind: 'project' | 'paper';
  entry: ProjectEntry | PaperEntry;
}

const { entryKind, entry } = Astro.props as Props;
const { Content } = await (entryKind === 'project'
  ? render(entry as ProjectEntry)
  : render(entry as PaperEntry));
const slug = contentSlug(entry.id);
const canonical = `/projects/${slug}/`;
const project = entryKind === 'project' ? (entry as ProjectEntry) : undefined;
const paper = entryKind === 'paper' ? (entry as PaperEntry) : undefined;
const isSignalManuscript = slug === 'from-ai-anxiety-to-recursive-governance-under-constraint' && Boolean(project);
const publicDir = fileURLToPath(new URL('../../../public/', import.meta.url));
const projectImagePath = project ? join(publicDir, project.data.image.replace(/^\/+/, '')) : undefined;
const hasProjectImage = Boolean(projectImagePath && existsSync(projectImagePath));
const meta = project
  ? [project.data.year ? String(project.data.year) : undefined, project.data.status, project.data.role]
      .filter(Boolean)
      .join(' · ')
  : joinDistinctText([paper?.data.year, paper?.data.venue, paper?.data.status]);
const standaloneRoutes = new Set([
  '/echo/',
  '/gaia/',
  '/gaia/app/',
  '/gaia/glossary/',
  '/gaia/book/',
  '/lotus/',
  '/scriptorium/',
  '/hephaistos/',
]);
const opensInNewWindow = (url: string) => standaloneRoutes.has(url) || /^https?:\/\//.test(url);
const structuredData = isSignalManuscript && project
  ? buildArticleSchema({
      title: project.data.title,
      description: project.data.description,
      url: buildCanonical(canonical),
      datePublished: String(project.data.year ?? 2026),
      schemaType: 'ScholarlyArticle',
    })
  : undefined;
---

<BaseLayout
  title={project?.data.title ?? paper?.data.title ?? 'Projects'}
  description={project?.data.description ?? paper?.data.abstract ?? 'Project record'}
  image={project && hasProjectImage ? project.data.image : undefined}
  canonical={canonical}
  ogType={paper || isSignalManuscript ? 'article' : 'website'}
  structuredData={structuredData}
>
  <EntryHero
    eyebrow={project ? 'Project' : paper?.data.type ?? 'Working paper'}
    title={project?.data.title ?? paper?.data.title ?? 'Project'}
    description={project?.data.description ?? paper?.data.abstract ?? ''}
    meta={meta}
    backHref="/projects/"
    backLabel="Back to projects"
    tags={project?.data.tags ?? paper?.data.tags}
    links={project?.data.links ?? paper?.data.links}
  />

  {
    project ? (
      <article class="section-shell grid gap-8 lg:grid-cols-[minmax(0,1fr)_320px]">
        <div class="reading-flow">
          {
            hasProjectImage ? (
              <figure class="mb-8 overflow-hidden border-y border-[rgba(255,255,255,0.08)] bg-[linear-gradient(180deg,rgba(8,11,16,0.92),rgba(8,11,16,0.7))]">
                <div class="aspect-[16/9] overflow-hidden border-b border-[rgba(255,255,255,0.08)]">
                  <img class="h-full w-full object-cover" src={project.data.image} alt={project.data.imageAlt} loading="eager" />
                </div>
                <figcaption class="space-y-4 p-6 md:p-8">
                  <p class="eyebrow">{project.data.status}</p>
                  <h2 class="text-[1.24rem] md:text-[1.38rem]">{project.data.subtitle}</h2>
                </figcaption>
              </figure>
            ) : (
              <div class="mb-8 overflow-hidden border-y border-[rgba(255,255,255,0.08)] bg-[linear-gradient(180deg,rgba(8,11,16,0.92),rgba(8,11,16,0.7))] p-5">
                <div class="border-t border-[rgba(36,27,23,0.12)] pt-8">
                  <p class="eyebrow">{project.data.status}</p>
                  <h2 class="mt-3 text-[1.24rem] md:text-[1.38rem]">{project.data.subtitle}</h2>
                </div>
              </div>
            )
          }
          <Content />
        </div>

        <aside class="space-y-6">
          <section class="veil-panel">
            <p class="eyebrow">Role</p>
            <p class="mt-4 text-base text-slate-200">{project.data.role}</p>
          </section>
          <section class="veil-panel">
            <p class="eyebrow">Outputs</p>
            <ul class="mt-4 ml-5 list-disc space-y-2 text-base text-slate-200">
              {project.data.outputs.map((output) => (
                <li>{output}</li>
              ))}
            </ul>
          </section>
          {project.data.links.length > 0 && (
            <section class="veil-panel">
              <p class="eyebrow">Links</p>
              <ul class="mt-4 space-y-3">
                {project.data.links.map((link) => (
                  <li>
                    <a
                      class="link-inline"
                      href={link.url}
                      target={opensInNewWindow(link.url) ? '_blank' : undefined}
                      rel={opensInNewWindow(link.url) ? 'noopener noreferrer' : undefined}
                    >
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )}
        </aside>
      </article>
    ) : paper && (
      <article class="section-shell grid gap-8 lg:grid-cols-[minmax(0,1fr)_320px]">
        <div class="reading-flow">
          <Content />
        </div>

        <aside class="space-y-6">
          <section class="veil-panel">
            <p class="eyebrow">Citation</p>
            <p class="mt-4 text-base text-slate-200">{paper.data.citation}</p>
          </section>
          <section class="veil-panel">
            <p class="eyebrow">Status</p>
            <p class="mt-4 text-base text-slate-200">{paper.data.status}</p>
          </section>
          <section class="veil-panel">
            <p class="eyebrow">Archive</p>
            <p class="mt-4 text-base text-slate-200">
              This record stays under Projects until it becomes part of the published academic archive.
            </p>
          </section>
          {paper.data.links.length > 0 && (
            <section class="veil-panel">
              <p class="eyebrow">Links</p>
              <ul class="mt-4 space-y-3">
                {paper.data.links.map((link) => (
                  <li>
                    <a
                      class="link-inline"
                      href={link.url}
                      target={opensInNewWindow(link.url) ? '_blank' : undefined}
                      rel={opensInNewWindow(link.url) ? 'noopener noreferrer' : undefined}
                    >
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )}
        </aside>
      </article>
    )
  }
</BaseLayout>
