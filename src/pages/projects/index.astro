---
import { getCollection } from 'astro:content';
import FilterBar from '../../components/FilterBar.astro';
import PracticeHero from '../../components/PracticeHero.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import PublicationCard from '../../components/PublicationCard.astro';
import SectionIntro from '../../components/SectionIntro.astro';
import { hiddenProjectArchiveSlugs, projectArchivePromotedPaperSlugs } from '../../data/site';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { collectTags, contentSlug, isPublishedPaper, sortByYear } from '../../lib/content';

const allProjects = sortByYear(await getCollection('projects'));
const hiddenProjectArchiveSlugSet = new Set<string>(hiddenProjectArchiveSlugs);
const promotedPaperSlugSet = new Set<string>(projectArchivePromotedPaperSlugs);
const projects = allProjects.filter(
  (project) =>
    !/\bamazon\b/i.test(project.data.status) && !hiddenProjectArchiveSlugSet.has(contentSlug(project.id)),
);
const allPapers = sortByYear(await getCollection('papers'));
const unpublishedPapers = allPapers.filter(
  (paper) => !isPublishedPaper(paper) && !promotedPaperSlugSet.has(contentSlug(paper.id)),
);
const tags = collectTags([...projects, ...unpublishedPapers]);
---

<BaseLayout
  title="Projects"
  description="An archive of unpublished books, papers, apps in development, and research builds by Martin Lepage."
>
  <PracticeHero
    eyebrow="Projects"
    title="Unpublished books, papers, apps in development, and research builds."
    description="Projects now holds the in-progress archive: frameworks, manuscripts, tools, and app lines that are still becoming themselves."
    details="Published academic work lives under Publications, while published Amazon books now live under Writings. This page stays focused on material still under construction, revision, or technical iteration."
    links={[
      { label: 'Browse project archive', url: '#project-archive', variant: 'primary' },
      { label: 'Browse research records', url: '#unpublished-papers', variant: 'secondary' },
      { label: 'Published books now live under Writings', url: '/writing/', variant: 'inline' },
    ]}
    sideEyebrow="Archive logic"
    sideTitle="What belongs here now."
    sideDescription="The Projects page is no longer a loose overflow area. It is the bounded public archive for work that is still in progress."
    sidePoints={[
      'Book-stage work stays here until it becomes a published record.',
      'Apps in development remain visible without overstating readiness.',
      'Unpublished papers remain public, but no longer masquerade as publication entries.',
    ]}
    stats={[
      {
        eyebrow: 'Books and builds',
        value: projects.length,
        label: 'Project records',
        description: 'Book-stage work, frameworks, apps in development, and research builds.',
      },
      {
        eyebrow: 'Research records',
        value: unpublishedPapers.length,
        label: 'Manuscripts and leads',
        description: 'In-progress manuscripts and unresolved bibliographic leads kept public until they become publication entries.',
      },
      {
        eyebrow: 'Published elsewhere',
        value: 'Writings',
        label: 'Amazon books',
        description: 'Published books with outward links now sit on the Writings page.',
      },
    ]}
  />

  <section class="section-shell">
    <div class="mt-2">
      <FilterBar scopeId="projects" tags={tags} searchPlaceholder="Search projects, manuscripts, and apps in development" />
    </div>

    <div class="mt-10 space-y-16" data-filter-scope="projects">
      <section id="project-archive">
        <SectionIntro
          eyebrow="Project archive"
          title="Books, apps in development, and research builds."
          description="This section includes the working archive rather than only a curated shortlist."
        />

        <div class="mt-10 grid gap-6 lg:grid-cols-2">
          {projects.map((project) => <ProjectCard project={project} />)}
        </div>
      </section>

      <section id="unpublished-papers">
        <SectionIntro
          eyebrow="In-progress research"
          title="Manuscripts and unresolved research leads."
          description="These records stay public here until they become publication entries or their bibliographic details are confirmed."
        />

        <div class="mt-10 grid gap-6 lg:grid-cols-2">
          {unpublishedPapers.map((paper) => <PublicationCard paper={paper} />)}
        </div>
      </section>
    </div>
  </section>
</BaseLayout>
