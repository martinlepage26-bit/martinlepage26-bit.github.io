---
import { getCollection } from 'astro:content';
import FilterBar from '../../components/FilterBar.astro';
import PracticeHero from '../../components/PracticeHero.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import PublicationCard from '../../components/PublicationCard.astro';
import SectionIntro from '../../components/SectionIntro.astro';
import { hiddenProjectArchiveSlugs, pageMeta, projectArchivePromotedPaperSlugs, publicProjectOrder } from '../../data/site';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { collectTags, contentSlug, isPublishedPaper, prioritizeEntriesBySlug, sortByYear } from '../../lib/content';

const allProjects = sortByYear(await getCollection('projects'));
const hiddenProjectArchiveSlugSet = new Set<string>(hiddenProjectArchiveSlugs);
const promotedPaperSlugSet = new Set<string>(projectArchivePromotedPaperSlugs);
const suppressedProjectArchiveSlugs = new Set<string>(['ai-governance']);
const projects = prioritizeEntriesBySlug(
  allProjects.filter(
    (project) =>
      !/\bamazon\b/i.test(project.data.status) &&
      !hiddenProjectArchiveSlugSet.has(contentSlug(project.id)) &&
      !suppressedProjectArchiveSlugs.has(contentSlug(project.id)),
  ),
  publicProjectOrder,
);
const allPapers = sortByYear(await getCollection('papers'));
const unpublishedPapers = allPapers.filter(
  (paper) => !isPublishedPaper(paper) && !promotedPaperSlugSet.has(contentSlug(paper.id)),
);
const tags = collectTags([...projects, ...unpublishedPapers]);
---

<BaseLayout
  title={pageMeta.projects.title}
  description={pageMeta.projects.description}
  pageClass="page-projects"
>
  <PracticeHero
    eyebrow="Projects"
    title="Five public app surfaces, method tools, manuscripts, and unfinished systems."
    description="Projects is the working archive: LOTUS, ECHO, SCRIPTO, GAIA, and Dr.Sort; recursive method tools; book-stage records; and exploratory research that is not yet classified as published output."
    details="This page keeps public app surfaces visible without overstating readiness. Governance, Papers, and Writings keep distinct claim boundaries, while Projects holds active builds, current manuscripts, and the not-yet-published side of the paper line."
    links={[
      { label: 'Browse project archive', url: '#project-archive', variant: 'primary' },
      { label: 'Browse research records', url: '#unpublished-papers', variant: 'secondary' },
      { label: 'Open governance practice', url: '/governance/', variant: 'inline' },
    ]}
    sideEyebrow="Archive logic"
    sideTitle="Why this section exists."
    sideDescription="Projects preserves visibility into active work while keeping publication and governance claims disciplined."
    sidePoints={[
      'The five public apps stay visible here as distinct surfaces rather than collapsing into one generic tooling bucket.',
      'Method-facing tools stay visible here while they are being tested and refined.',
      'Book-stage work remains here until it reaches published-book status.',
      'Apps in development remain public without implying production readiness.',
      'Unpublished papers stay here until publication status and bibliographic metadata are verified.',
    ]}
    stats={[
      {
        eyebrow: 'Methods and builds',
        value: projects.length,
        label: 'Project records',
        description: 'Recursive tools, manuscripts, apps in development, and experimental research artifacts.',
      },
      {
        eyebrow: 'Research records',
        value: unpublishedPapers.length,
        label: 'Manuscripts and leads',
        description: 'In-progress papers and unresolved leads kept public at the correct confidence level.',
      },
      {
        eyebrow: 'Professional route',
        value: 'Governance',
        label: 'Dedicated practice page',
        description: 'Formal governance engagement material lives on its own focused page.',
      },
    ]}
  />

  <section class="section-shell">
    <div class="mt-2">
      <FilterBar scopeId="projects" tags={tags} searchPlaceholder="Search projects, manuscripts, and apps in development" />
    </div>

    <div class="mt-10 space-y-16" data-filter-scope="projects">

      <!-- Project archive: bento grid — first card spans full width -->
      <section id="project-archive">
        <SectionIntro
          eyebrow="Project archive"
          title="Public app surfaces, active manuscripts, and experimental builds."
          description="This section foregrounds unfinished work where process visibility matters as much as outcomes, and where the five app lines stay visibly distinct."
        />

        <div class="project-bento mt-10">
          {projects.map((project) => <ProjectCard project={project} />)}
        </div>
      </section>

      <!-- Research records: visually distinct container, separated from app builds -->
      <section id="unpublished-papers">
        <div class="projects-research-section">
          <SectionIntro
            eyebrow="In-progress research"
            title="Manuscripts and unresolved research leads."
            description="These records stay public here until publication status is confirmed and metadata is stable."
          />

          <div class="mt-10 grid gap-6 lg:grid-cols-2">
            {unpublishedPapers.map((paper) => <PublicationCard paper={paper} />)}
          </div>
        </div>
      </section>

    </div>
  </section>
</BaseLayout>
