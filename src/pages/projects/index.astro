---
import { getCollection } from 'astro:content';
import FilterBar from '../../components/FilterBar.astro';
import PracticeHero from '../../components/PracticeHero.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import PublicationCard from '../../components/PublicationCard.astro';
import SectionIntro from '../../components/SectionIntro.astro';
import { hiddenProjectArchiveSlugs, pageMeta, projectArchivePromotedPaperSlugs, publicProjectOrder } from '../../data/site';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { collectTags, contentSlug, isPublishedPaper, prioritizeEntriesBySlug, sortByYear } from '../../lib/content';

const allProjects = sortByYear(await getCollection('projects'));
const hiddenProjectArchiveSlugSet = new Set<string>(hiddenProjectArchiveSlugs);
const promotedPaperSlugSet = new Set<string>(projectArchivePromotedPaperSlugs);
const suppressedProjectArchiveSlugs = new Set<string>(['govern-ai-practice', 'ai-governance']);
const projects = prioritizeEntriesBySlug(
  allProjects.filter(
    (project) =>
      !/\bamazon\b/i.test(project.data.status) &&
      !hiddenProjectArchiveSlugSet.has(contentSlug(project.id)) &&
      !suppressedProjectArchiveSlugs.has(contentSlug(project.id)),
  ),
  publicProjectOrder,
);
const allPapers = sortByYear(await getCollection('papers'));
const unpublishedPapers = allPapers.filter(
  (paper) => !isPublishedPaper(paper) && !promotedPaperSlugSet.has(contentSlug(paper.id)),
);
const tags = collectTags([...projects, ...unpublishedPapers]);
---

<BaseLayout
  title={pageMeta.projects.title}
  description={pageMeta.projects.description}
>
  <PracticeHero
    eyebrow="Projects"
    title="Projects, manuscripts, and deterministic recursive method work."
    description="This page now foregrounds recursive method tools, book-stage work, working manuscripts, and experimental builds rather than general governance positioning."
    details="Governance, Writings, and Publications now have clearer routes of their own. Projects holds the unfinished, exploratory, and method-facing work that does not belong on those shelves yet."
    links={[
      { label: 'Browse project archive', url: '#project-archive', variant: 'primary' },
      { label: 'Browse research records', url: '#unpublished-papers', variant: 'secondary' },
      { label: 'Start with governance work', url: '/governance/', variant: 'inline' },
    ]}
    sideEyebrow="Archive logic"
    sideTitle="What belongs here now."
    sideDescription="Use this archive for recursive method tools, apps in development, book-stage work, experimental builds, and unpublished research."
    sidePoints={[
      'The deterministic recursive method now gets a clearer front-facing role here through Scriptorium and related work.',
      'Book-stage work stays here until it becomes a published book entry under Writings.',
      'Apps in development stay visible without overstating readiness.',
      'Unpublished papers remain public here until they can stand as publication entries.',
    ]}
    stats={[
      {
        eyebrow: 'Books and builds',
        value: projects.length,
        label: 'Project records',
        description: 'Recursive method tools, book-stage work, apps in development, and research builds.',
      },
      {
        eyebrow: 'Research records',
        value: unpublishedPapers.length,
        label: 'Manuscripts and leads',
        description: 'In-progress manuscripts and unresolved bibliographic leads kept public until they become publication entries.',
      },
      {
        eyebrow: 'Professional route',
        value: 'Governance',
        label: 'Practice page',
        description: 'The more explicitly professional governance surface now lives at its own dedicated entry point.',
      },
    ]}
  />

  <section class="section-shell">
    <div class="mt-2">
      <FilterBar scopeId="projects" tags={tags} searchPlaceholder="Search projects, manuscripts, and apps in development" />
    </div>

    <div class="mt-10 space-y-16" data-filter-scope="projects">
      <section id="project-archive">
        <SectionIntro
          eyebrow="Project archive"
          title="Recursive method tools, books, apps in development, and research builds."
          description="Scriptorium, book-stage projects, apps in development, and experimental research builds organized around unfinished or method-facing work."
        />

        <div class="mt-10 grid gap-6 lg:grid-cols-2">
          {projects.map((project) => <ProjectCard project={project} />)}
        </div>
      </section>

      <section id="unpublished-papers">
        <SectionIntro
          eyebrow="In-progress research"
          title="Manuscripts and unresolved research leads."
          description="These records stay public here until they become publication entries or their bibliographic details are secure."
        />

        <div class="mt-10 grid gap-6 lg:grid-cols-2">
          {unpublishedPapers.map((paper) => <PublicationCard paper={paper} />)}
        </div>
      </section>
    </div>
  </section>
</BaseLayout>
