---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionIntro from '../../components/SectionIntro.astro';
import AstralHoroscopeApp from '../../components/astral/AstralHoroscopeApp.astro';
import { zodiacSigns } from '../../data/astralYear';
import { buildCanonical } from '../../lib/seo';

const pageDescription =
  'Astral is an interactive horoscope app built from Breath of the Astral Year, turning the book’s sign language into a grounded reading experience.';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Astral',
  description: pageDescription,
  applicationCategory: 'LifestyleApplication',
  url: buildCanonical('/astral-year/app/'),
  creator: {
    '@type': 'Person',
    name: 'Martin Lepage',
  },
  isBasedOn: {
    '@type': 'Book',
    name: 'Breath of the Astral Year',
    url: buildCanonical('/astral-year/'),
  },
};
---

<BaseLayout
  title="Astral App"
  description={pageDescription}
  image="/social/og-breath-of-the-astral-year.svg"
  canonical="/astral-year/app/"
  structuredData={structuredData}
>
  <section class="relative overflow-hidden border-b border-white/10">
    <div class="section-shell relative astral-hero-shell">
      <div class="astral-ring astral-ring-one"></div>
      <div class="astral-ring astral-ring-two"></div>
      <div class="grid gap-10 lg:grid-cols-[minmax(0,1.08fr)_minmax(320px,0.92fr)] lg:items-end">
        <div class="relative z-10 max-w-4xl">
          <p class="eyebrow">Astral app</p>
          <h1 class="mt-5">A horoscope app drawn from the book&apos;s sign language.</h1>
          <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-100 md:text-xl">
            Astral translates <em>Breath of the Astral Year</em> into a usable reading surface. It keeps astrology close
            to season, body, relation, and earthly pressure instead of turning it into a distant mechanism.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a class="button-primary" href="#astral-tool">Open the app</a>
            <a class="button-secondary" href="/astral-year/">Return to the book page</a>
            <a class="button-secondary" href="/astral-year/glossary/">Open the sign glossary</a>
          </div>
        </div>

        <div class="veil-panel relative z-10 astral-hero-card">
          <p class="eyebrow">What it gives you</p>
          <div class="mt-5 grid gap-4">
            <div class="astral-mini-card">
              <p class="astral-mini-label">Entry paths</p>
              <p class="mt-2 text-base leading-7 text-slate-200">
                Read by sign when you already know it, or resolve your sign from birth month and day.
              </p>
            </div>
            <div class="astral-mini-card">
              <p class="astral-mini-label">Reading style</p>
              <p class="mt-2 text-base leading-7 text-slate-200">
                Every result is grounded, literary, and structured around mood, movement, caution, and ritual.
              </p>
            </div>
            <div class="astral-mini-card">
              <p class="astral-mini-label">Source</p>
              <p class="mt-2 text-base leading-7 text-slate-200">
                Built directly from the existing sign vocabulary already defined for the book.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="astral-tool" class="section-shell">
    <SectionIntro
      eyebrow="Interactive reading"
      title="Use the sign language as an app."
      description="The book supplies the symbolic grammar. The app turns it into a live reading surface you can use directly."
    />

    <div class="mt-12">
      <AstralHoroscopeApp signs={zodiacSigns} />
    </div>
  </section>

  <section class="section-shell border-y border-white/8 bg-white/4">
    <div class="grid gap-6 lg:grid-cols-3">
      <article class="veil-panel">
        <p class="eyebrow">Grounded</p>
        <h2 class="mt-4 text-[1.25rem] md:text-[1.4rem]">No sky machine.</h2>
        <p class="mt-4 text-base leading-7 text-slate-200">
          The reading stays close to seasons, relations, labor, tenderness, and the lived texture of the year.
        </p>
      </article>
      <article class="veil-panel">
        <p class="eyebrow">Structured</p>
        <h2 class="mt-4 text-[1.25rem] md:text-[1.4rem]">A repeatable frame.</h2>
        <p class="mt-4 text-base leading-7 text-slate-200">
          Every sign is read through the same fields: key note, season mood, body feeling, movement, shadow, and ritual.
        </p>
      </article>
      <article class="veil-panel">
        <p class="eyebrow">Companion</p>
        <h2 class="mt-4 text-[1.25rem] md:text-[1.4rem]">Part of the larger Astral surface.</h2>
        <p class="mt-4 text-base leading-7 text-slate-200">
          The app sits beside the book page and glossary, making the language easier to navigate without flattening it.
        </p>
      </article>
    </div>
  </section>

  <style>
    .astral-hero-shell {
      position: relative;
      isolation: isolate;
    }

    .astral-ring {
      position: absolute;
      border-radius: 999px;
      border: 1px solid rgba(209, 181, 255, 0.16);
      pointer-events: none;
    }

    .astral-ring-one {
      width: min(74vw, 820px);
      height: min(74vw, 820px);
      top: -12rem;
      right: -15rem;
      background: radial-gradient(circle, rgba(209, 181, 255, 0.12) 0%, rgba(209, 181, 255, 0) 62%);
    }

    .astral-ring-two {
      width: min(38vw, 320px);
      height: min(38vw, 320px);
      left: -3rem;
      bottom: -3rem;
      background: radial-gradient(circle, rgba(110, 200, 214, 0.14) 0%, rgba(110, 200, 214, 0) 58%);
    }

    .astral-hero-card {
      background:
        radial-gradient(circle at top right, rgba(110, 200, 214, 0.12), transparent 35%),
        linear-gradient(165deg, rgba(13, 9, 27, 0.92), rgba(28, 19, 45, 0.96));
    }

    .astral-mini-card {
      border-radius: 1.15rem;
      border: 1px solid rgba(255, 255, 255, 0.08);
      background: rgba(255, 255, 255, 0.04);
      padding: 1rem 1.05rem;
    }

    .astral-mini-label {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--color-accent);
    }
  </style>
</BaseLayout>
