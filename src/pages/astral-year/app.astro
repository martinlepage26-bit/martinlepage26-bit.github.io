---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionIntro from '../../components/SectionIntro.astro';
import AstralHoroscopeApp from '../../components/astral/AstralHoroscopeApp.astro';
import { zodiacSigns } from '../../data/astralYear';
import { buildCanonical } from '../../lib/seo';

const pageDescription =
  'Astral is an interactive seasonal reading app built from Breath of the Astral Year, turning the book’s sign language into a grounded reading experience.';

const astralSurfaces = [
  {
    eyebrow: 'App',
    title: 'Open the seasonal reading surface.',
    description: 'Use the live interface to choose a sign directly or resolve one by month and day.',
    href: '#astral-tool',
    cta: 'Use Astral',
  },
  {
    eyebrow: 'Book',
    title: 'Read Breath of the Astral Year.',
    description: 'Return to the published book page that frames the whole seasonal language.',
    href: '/astral-year/',
    cta: 'Open the book',
  },
  {
    eyebrow: 'Glossary',
    title: 'Browse the sign glossary.',
    description: 'See the stable vocabulary behind each reading: competence, weather, body, relation, shadow, and ritual.',
    href: '/astral-year/glossary/',
    cta: 'Open the glossary',
  },
  {
    eyebrow: 'Project record',
    title: 'See the archive record for the title.',
    description: 'View the public project entry that links the published book, glossary, and app as one bounded record.',
    href: '/projects/breath-of-the-astral-year/',
    cta: 'Open the archive record',
  },
] as const;

const seasonalMethod = [
  {
    label: '1. Entry input',
    body: 'Astral starts with either a direct sign choice or a month-and-day date used to resolve the seasonal sign range.',
  },
  {
    label: '2. Seasonal grounding',
    body: 'The app maps that date to the sign calendar already defined for the book. It does not use birth time, birth place, or planetary positions.',
  },
  {
    label: '3. Reading frame',
    body: 'Each sign is read through the same six fields: key note, season mood, body feeling, movement pattern, shadow, and ritual.',
  },
  {
    label: '4. Rendered output',
    body: 'Astral turns those fields into a summary, a longer message, and grounded guidance lines that stay close to earthly life.',
  },
] as const;

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Astral',
  description: pageDescription,
  applicationCategory: 'LifestyleApplication',
  url: buildCanonical('/astral-year/app/'),
  creator: {
    '@type': 'Person',
    name: 'Martin Lepage',
  },
  isBasedOn: {
    '@type': 'Book',
    name: 'Breath of the Astral Year',
    url: buildCanonical('/astral-year/'),
  },
};
---

<BaseLayout
  title="Astral App"
  description={pageDescription}
  image="/social/og-breath-of-the-astral-year.png"
  canonical="/astral-year/app/"
  structuredData={structuredData}
>
  <section class="relative overflow-hidden border-b border-[rgba(36,27,23,0.12)]">
    <div class="section-shell relative astral-hero-shell">
      <div class="astral-ring astral-ring-one"></div>
      <div class="astral-ring astral-ring-two"></div>
      <div class="grid gap-10 lg:grid-cols-[minmax(0,1.08fr)_minmax(320px,0.92fr)] lg:items-end">
        <div class="relative z-10 max-w-4xl">
          <p class="eyebrow">Astral app</p>
          <h1 class="mt-5">A seasonal reading app drawn from the book&apos;s sign language.</h1>
          <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-100 md:text-xl">
            Astral translates <em>Breath of the Astral Year</em> into a usable reading surface. It keeps astrology close
            to season, body, relation, and earthly pressure instead of turning it into a distant mechanism.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a class="button-primary" href="#astral-tool">Open the app</a>
            <a class="button-secondary" href="/astral-year/">Return to the book page</a>
            <a class="button-secondary" href="/astral-year/glossary/">Open the sign glossary</a>
          </div>
        </div>

        <div class="veil-panel relative z-10 astral-hero-card">
          <p class="eyebrow">What it gives you</p>
          <div class="mt-5 grid gap-4">
            <div class="astral-mini-card">
              <p class="astral-mini-label">Entry paths</p>
              <p class="mt-2 text-base leading-7 text-slate-200">
                Read by sign when you already know it, or resolve your sign from month and day.
              </p>
            </div>
            <div class="astral-mini-card">
              <p class="astral-mini-label">Reading style</p>
              <p class="mt-2 text-base leading-7 text-slate-200">
                Every result is grounded, literary, and structured around season, movement, caution, and ritual.
              </p>
            </div>
            <div class="astral-mini-card">
              <p class="astral-mini-label">Source</p>
              <p class="mt-2 text-base leading-7 text-slate-200">
                Built directly from the existing sign vocabulary already defined for the book, not from chart calculation.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-shell border-y border-[rgba(36,27,23,0.08)] bg-[rgba(251,246,239,0.28)]">
    <SectionIntro
      eyebrow="Astral surfaces"
      title="Use the project across its local pages."
      description="The app sits inside a small seasonal ecosystem: the book, the glossary, the live reading surface, and the project record."
    />

    <div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-4">
      {astralSurfaces.map((item) => (
        <article class="veil-panel h-full">
          <p class="eyebrow">{item.eyebrow}</p>
          <h2 class="mt-4 text-[1.08rem] md:text-[1.2rem]">{item.title}</h2>
          <p class="mt-4 text-base leading-7 text-slate-200">{item.description}</p>
          <div class="mt-5">
            <a class="link-inline" href={item.href}>{item.cta}</a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section id="astral-tool" class="section-shell">
    <SectionIntro
      eyebrow="Interactive reading"
      title="Use the seasonal language as an app."
      description="The book supplies the symbolic grammar. The app turns it into a live seasonal reading surface you can use directly."
    />

    <div class="mt-12">
      <AstralHoroscopeApp signs={zodiacSigns} />
    </div>
  </section>

  <section class="section-shell border-y border-[rgba(36,27,23,0.08)] bg-[rgba(251,246,239,0.28)]">
    <SectionIntro
      eyebrow="How it works"
      title="A seasonal method, not a natal chart."
      description="Astral renders repeatable seasonal readings from the book&apos;s sign calendar and vocabulary. It does not calculate planets, houses, or transits."
    />

    <div class="mt-12 grid gap-6 lg:grid-cols-4">
      {seasonalMethod.map((item) => (
        <article class="veil-panel h-full">
          <p class="astral-mini-label">{item.label}</p>
          <p class="mt-4 text-base leading-7 text-slate-200">{item.body}</p>
        </article>
      ))}
    </div>

    <div class="mt-10 grid gap-6 lg:grid-cols-[minmax(0,1.05fr)_minmax(320px,0.95fr)]">
      <article class="veil-panel">
        <p class="eyebrow">What it does not do</p>
        <h2 class="mt-4 text-[1.16rem] md:text-[1.28rem]">No hidden astronomy claims.</h2>
        <ul class="mt-4 ml-5 list-disc space-y-2 text-base leading-7 text-slate-200">
          <li>No birth time or birth place input.</li>
          <li>No planetary positions, houses, aspects, or transit layers.</li>
          <li>No claim that the book needs a natal chart engine in order to speak.</li>
        </ul>
      </article>

      <article class="veil-panel">
        <p class="eyebrow">If full charts come later</p>
        <h2 class="mt-4 text-[1.16rem] md:text-[1.28rem]">That would be a separate build step.</h2>
        <p class="mt-4 text-base leading-7 text-slate-200">
          To render full natal horoscopes later, the project would need a declared astrological system, real astronomical
          calculations or an external chart engine, and additional birth inputs such as exact time and place.
        </p>
        <p class="mt-4 text-base leading-7 text-slate-200">
          The current Astral app is intentionally narrower: a seasonal reading surface grounded in <em>Breath of the
          Astral Year</em>.
        </p>
      </article>
    </div>
  </section>

  <section class="section-shell border-y border-[rgba(36,27,23,0.08)] bg-[rgba(251,246,239,0.28)]">
    <div class="grid gap-6 lg:grid-cols-3">
      <article class="veil-panel">
        <p class="eyebrow">Grounded</p>
        <h2 class="mt-4 text-[1.08rem] md:text-[1.2rem]">No sky machine.</h2>
        <p class="mt-4 text-base leading-7 text-slate-200">
          The reading stays close to seasons, relations, labor, tenderness, and the lived texture of the year.
        </p>
      </article>
      <article class="veil-panel">
        <p class="eyebrow">Structured</p>
        <h2 class="mt-4 text-[1.08rem] md:text-[1.2rem]">A repeatable frame.</h2>
        <p class="mt-4 text-base leading-7 text-slate-200">
          Every sign is read through the same fields: key note, season mood, body feeling, movement, shadow, and ritual.
        </p>
      </article>
      <article class="veil-panel">
        <p class="eyebrow">Companion</p>
        <h2 class="mt-4 text-[1.08rem] md:text-[1.2rem]">Part of the larger Astral surface.</h2>
        <p class="mt-4 text-base leading-7 text-slate-200">
          The app sits beside the book page and glossary, making the language easier to navigate without flattening it.
        </p>
      </article>
    </div>
  </section>

  <style>
    .astral-hero-shell {
      position: relative;
      isolation: isolate;
    }

    .astral-ring {
      position: absolute;
      border-radius: 999px;
      border: 1px solid rgba(127, 83, 178, 0.14);
      pointer-events: none;
    }

    .astral-ring-one {
      width: min(74vw, 820px);
      height: min(74vw, 820px);
      top: -12rem;
      right: -15rem;
      background: radial-gradient(circle, rgba(127, 83, 178, 0.1) 0%, rgba(127, 83, 178, 0) 62%);
    }

    .astral-ring-two {
      width: min(38vw, 320px);
      height: min(38vw, 320px);
      left: -3rem;
      bottom: -3rem;
      background: radial-gradient(circle, rgba(92, 110, 198, 0.12) 0%, rgba(92, 110, 198, 0) 58%);
    }

    .astral-hero-card {
      background:
        radial-gradient(circle at top right, rgba(92, 110, 198, 0.12), transparent 35%),
        linear-gradient(165deg, rgba(251, 246, 239, 0.62), rgba(251, 246, 239, 0.16));
    }

    .astral-mini-card {
      border-top: 1px solid rgba(36, 27, 23, 0.12);
      padding: 1rem 0;
    }

    .astral-mini-label {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--color-accent);
    }
  </style>
</BaseLayout>
