---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionIntro from '../../components/SectionIntro.astro';
import { classicalElements, zodiacSigns } from '../../data/astralYear';
import { buildCanonical } from '../../lib/seo';

const pageDescription =
  'Breath of the Astral Year is a self-published book about astrology as a grammar of collective life, with signs and seasons kept close to lived experience.';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Book',
  name: 'Breath of the Astral Year',
  description: pageDescription,
  url: buildCanonical('/astral-year/'),
  creator: {
    '@type': 'Person',
    name: 'Martin Lepage',
  },
  genre: 'Self-published book',
};

const astralBookData = { signs: zodiacSigns };
---

<BaseLayout
  title="Breath of the Astral Year"
  description={pageDescription}
  image="/social/og-breath-of-the-astral-year.svg"
  canonical="/astral-year/"
  structuredData={structuredData}
>
  <section class="relative overflow-hidden border-b border-[rgba(36,27,23,0.12)]">
    <div class="section-shell relative astral-hero-shell">
      <div class="astral-orbit astral-orbit-one"></div>
      <div class="astral-orbit astral-orbit-two"></div>
      <div class="grid gap-10 lg:grid-cols-[minmax(0,1.08fr)_minmax(340px,0.92fr)] lg:items-end">
        <div class="relative z-10 max-w-4xl">
          <p class="eyebrow">Self-published book</p>
          <h1 class="mt-5">Breath of the Astral Year</h1>
          <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-100 md:text-xl">
            An Earth-bound reading of signs, seasons, bodies, and weather. It keeps its answers close to the ground,
            where change can be felt and shared.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a class="button-primary" href="/projects/breath-of-the-astral-year/">Read about the book</a>
            <a class="button-secondary" href="/astral-year/app/">Open the Astral app</a>
            <a class="button-secondary" href="/astral-year/glossary/">Browse the sign glossary</a>
          </div>
          <p class="mt-5 max-w-2xl text-sm leading-6 text-slate-300">
            This page offers the book&apos;s tone and structure, while the companion glossary and app turn that sign
            language into a living public-facing toolset.
          </p>
        </div>

        <div class="veil-panel relative z-10 astral-manifest-panel">
          <p class="eyebrow">Book frame</p>
          <div class="mt-5 grid gap-4">
            <div class="astral-mini-card">
              <p class="astral-mini-label">Status</p>
              <p class="mt-2 text-base leading-7 text-slate-200">Self-published book on Amazon.</p>
            </div>
            <div class="astral-mini-card">
              <p class="astral-mini-label">What it follows</p>
              <p class="mt-2 text-base leading-7 text-slate-200">
                The year as it is actually lived on Earth: light and dark, heat and cold, ripening and retreat, motion
                and rest.
              </p>
            </div>
            <div class="astral-mini-card">
              <p class="astral-mini-label">For readers</p>
              <p class="mt-2 text-base leading-7 text-slate-200">
                Written for general readers who want a grounded symbolic language, not a distant sky-machine.
              </p>
            </div>
            <div class="astral-mini-card">
              <p class="astral-mini-label">Companion surfaces</p>
              <p class="mt-2 text-base leading-7 text-slate-200">
                Use the <a class="link-inline" href="/astral-year/glossary/">sign glossary</a> to read the lexicon, or open the
                <a class="link-inline" href="/astral-year/app/">Astral app</a> for a guided horoscope experience.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="elements-chapter" class="section-shell border-y border-[rgba(36,27,23,0.08)] bg-[rgba(251,246,239,0.28)]">
    <SectionIntro
      eyebrow="Chapter: The elements"
      title="The four elements."
      description="Fire, earth, air, and water shape the book&apos;s first layer."
    />

    <div class="mt-12 grid gap-6 xl:grid-cols-4 md:grid-cols-2">
      {classicalElements.map((element) => (
        <article class="veil-panel astral-element-card" style={`--element-color:${element.color};`}>
          <p class="astral-mini-label">{element.name}</p>
          <h3 class="mt-4 text-[1.12rem] md:text-[1.24rem]">{element.signs.join(' · ')}</h3>
          <p class="mt-4 text-base leading-7 text-slate-200">
            <strong>Qualities:</strong> {element.traits}.
          </p>
          <p class="mt-4 text-base leading-7 text-slate-200">{element.bookUse}</p>
        </article>
      ))}
    </div>

    <div class="mt-8 grid gap-6 lg:grid-cols-[minmax(0,1.05fr)_minmax(320px,0.95fr)]">
      <article class="veil-panel">
        <p class="eyebrow">How the book uses them</p>
        <h3 class="mt-4 text-[1.28rem] md:text-[1.44rem]">The elements are the first layer of the book&apos;s movement.</h3>
        <p class="mt-4 text-base leading-7 text-slate-200">
          Before the book arrives at individual signs, it listens for elemental weather as it is lived on Earth. Fire
          pushes outward. Earth steadies and shapes. Air connects and stirs. Water absorbs and deepens.
        </p>
        <p class="mt-4 text-base leading-7 text-slate-200">
          That is how gaialogy becomes operational on the page. The elements set the temperature of a chapter, the kind
          of attention it gives the world, and the emotional pressure carried by the signs inside it.
        </p>
        <p class="mt-4 text-base leading-7 text-slate-200">
          They also change one another. Fire can lift air. Air can unsettle earth. Water can cool fire. Earth can hold
          water in place. The book uses those frictions and affinities to shape how one mood turns into the next.
        </p>
        <p class="mt-4 text-base leading-7 text-slate-200">
          The signs then refine that mood. Three signs belong to each element, but they do not repeat one another. One
          begins, one holds, one changes. The sky may give the old names, but the meaning is made down here, in the
          texture of earthly life.
        </p>
      </article>

      <article class="veil-panel">
        <p class="eyebrow">The fifth</p>
        <h3 class="mt-4 text-[1.12rem] md:text-[1.28rem]">If a fifth is named here, it is Gaia: the living field of Earth.</h3>
        <p class="mt-4 text-base leading-7 text-slate-200">
          The book can make room for a fifth, but not as another distant astrological mechanism. Gaia is the better name
          for it here: the living ground that holds weather, body, season, growth, decay, and relation together.
        </p>
        <p class="mt-4 text-base leading-7 text-slate-200">
          Spirit, aether, or akasha may still appear as poetic or metaphysical names for the unseen, but they do not do
          the practical work of the system. The practical work belongs to what can be felt on Earth: climate, season,
          pressure, desire, hunger, labor, loss, rest, and return.
        </p>
        <p class="mt-4 text-base leading-7 text-slate-200">
          The limit is simple: Gaia is not a new triplicity and not a proof claim. It is the name the book gives to the
          living totality from which the four elements are read. If akasha enters the language at all, it stays a
          neighboring idea, not the engine of the method.
        </p>
        <ul class="mt-4 ml-5 list-disc space-y-2 text-base leading-7 text-slate-200">
          <li>Do not treat the planets as hidden causes the book needs in order to work.</li>
          <li>Do not turn Gaia into a fifth technical sign-family beside the four elements.</li>
          <li>Do not present akasha, Gaia, or spirit as scientific proof of cosmic mechanism.</li>
          <li>Keep the method empirical in tone: what happens to bodies, moods, seasons, and forms of life on Earth.</li>
        </ul>
        <p class="mt-4 text-base leading-7 text-slate-200">
          Used carefully, the fifth is not another element competing with the others. It is the name for the living
          whole they belong to.
        </p>
      </article>
    </div>
  </section>

  <section id="zodiac-architecture" class="section-shell">
    <SectionIntro
      eyebrow="The signs"
      title="The zodiac, kept close to the ground."
      description="The elements set the weather; each sign gives it a more exact voice."
    />

    <div class="mt-12 grid gap-8 xl:grid-cols-[minmax(0,1.1fr)_minmax(360px,0.9fr)]">
      <div class="veil-panel">
        <div class="astral-wheel-grid" id="sign-grid">
          {zodiacSigns.map((sign) => (
            <button
              type="button"
              class="astral-sign-chip"
              data-sign={sign.slug}
              style={`--sign-color:${sign.color};`}
              aria-pressed="false"
            >
              <span class="astral-sign-glyph">{sign.glyph}</span>
              <span class="astral-sign-name">{sign.name}</span>
              <span class="astral-sign-dates">{sign.dateLabel}</span>
            </button>
          ))}
        </div>
        <p class="mt-6 astral-helper-text">
          Click any sign to see how it feels inside the book.
        </p>
      </div>

      <aside class="veil-panel astral-detail-panel" aria-live="polite" aria-atomic="true">
        <p class="eyebrow">Selected sign</p>
        <div class="mt-5 flex items-center justify-between gap-4">
          <div>
            <p id="detail-range" class="text-sm uppercase tracking-[0.18em] text-slate-400"></p>
            <h2 id="detail-name" class="mt-2 text-[1.5rem] md:text-[1.8rem]"></h2>
          </div>
          <div class="astral-glyph-wrap">
            <span id="detail-glyph" class="astral-glyph">♈</span>
          </div>
        </div>
        <p id="detail-competence" class="mt-4 text-lg text-accent"></p>
        <div class="mt-6 grid gap-4">
          <div class="astral-detail-card">
            <p class="astral-mini-label">Season mood</p>
            <p id="detail-civic" class="mt-2 text-base leading-7 text-slate-200"></p>
          </div>
          <div class="astral-detail-card">
            <p class="astral-mini-label">Body feeling</p>
            <p id="detail-body" class="mt-2 text-base leading-7 text-slate-200"></p>
          </div>
          <div class="astral-detail-card">
            <p class="astral-mini-label">How it moves</p>
            <p id="detail-social" class="mt-2 text-base leading-7 text-slate-200"></p>
          </div>
          <div class="astral-detail-grid">
            <div class="astral-mini-card">
              <p class="astral-mini-label">Where it turns dark</p>
              <p id="detail-shadow" class="mt-2 text-sm leading-6 text-slate-200"></p>
            </div>
            <div class="astral-mini-card">
              <p class="astral-mini-label">Small ritual</p>
              <p id="detail-ritual" class="mt-2 text-sm leading-6 text-slate-200"></p>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="section-shell border-y border-[rgba(36,27,23,0.08)] bg-[rgba(251,246,239,0.28)]">
    <div class="grid gap-6 lg:grid-cols-3">
      <article class="veil-panel">
        <p class="eyebrow">Book mood</p>
        <h3 class="mt-4 text-[1.12rem] md:text-[1.28rem]">A book of atmosphere</h3>
        <p class="mt-4 text-base leading-7 text-slate-200">
          The signs move through the book like changing weather: beginnings, ripening, restlessness, brightness,
          balance, pressure, release, and return.
        </p>
      </article>
      <article class="veil-panel">
        <p class="eyebrow">Approach</p>
        <h3 class="mt-4 text-[1.12rem] md:text-[1.28rem]">Gaialogy, not sky worship</h3>
        <p class="mt-4 text-base leading-7 text-slate-200">
          The book turns away from the fantasy that all answers are hidden in the sky. It works from Earth, from the
          Sun&apos;s lived rhythm, and from what can actually be seen in bodies, climates, relations, and forms of life.
        </p>
      </article>
      <article class="veil-panel">
        <p class="eyebrow">Audience</p>
        <h3 class="mt-4 text-[1.12rem] md:text-[1.28rem]">Written for general readers</h3>
        <p class="mt-4 text-base leading-7 text-slate-200">
          The voice stays close to the surface of things: seasons, moods, desire, drift, pressure, tenderness, and the
          small ways a year changes how life feels.
        </p>
      </article>
    </div>
  </section>

  <script is:inline type="application/json" id="astral-year-data" set:html={JSON.stringify(astralBookData)}></script>
  <script is:inline>
    const bookDataElement = document.getElementById('astral-year-data');
    const signButtons = Array.from(document.querySelectorAll('[data-sign]'));

    if (bookDataElement && signButtons.length > 0) {
      const astralData = JSON.parse(bookDataElement.textContent || '{}');
      const signs = astralData.signs || [];

      function renderSignDetail(sign) {
        signButtons.forEach((button) => {
          button.setAttribute('aria-pressed', button.dataset.sign === sign.slug ? 'true' : 'false');
        });

        document.getElementById('detail-name').textContent = sign.name;
        document.getElementById('detail-glyph').textContent = sign.glyph;
        document.getElementById('detail-range').textContent = `${sign.dateLabel} · ${sign.element}`;
        document.getElementById('detail-competence').textContent = `Key note: ${sign.competence}`;
        document.getElementById('detail-civic').textContent = sign.civicTheme;
        document.getElementById('detail-body').textContent = sign.bodyRegister;
        document.getElementById('detail-social').textContent = sign.socialPattern;
        document.getElementById('detail-shadow').textContent = sign.shadow;
        document.getElementById('detail-ritual').textContent = sign.ritual;
      }

      signButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const sign = signs.find((entry) => entry.slug === button.dataset.sign);
          if (sign) {
            renderSignDetail(sign);
          }
        });
      });

      renderSignDetail(signs[0]);
    }
  </script>

  <style>
    .astral-hero-shell {
      position: relative;
      isolation: isolate;
    }

    .astral-orbit {
      position: absolute;
      border-radius: 999px;
      border: 1px solid rgba(127, 83, 178, 0.14);
      pointer-events: none;
      filter: drop-shadow(0 0 24px rgba(127, 83, 178, 0.08));
    }

    .astral-orbit-one {
      width: min(72vw, 780px);
      height: min(72vw, 780px);
      top: -10rem;
      right: -14rem;
      background: radial-gradient(circle, rgba(127, 83, 178, 0.1) 0%, rgba(127, 83, 178, 0) 62%);
    }

    .astral-orbit-two {
      width: min(42vw, 360px);
      height: min(42vw, 360px);
      left: -4rem;
      bottom: -4rem;
      background: radial-gradient(circle, rgba(92, 110, 198, 0.12) 0%, rgba(92, 110, 198, 0) 58%);
    }

    .astral-manifest-panel {
      background:
        radial-gradient(circle at top right, rgba(127, 83, 178, 0.12), transparent 35%),
        linear-gradient(160deg, rgba(251, 246, 239, 0.6), rgba(251, 246, 239, 0.14));
    }

    .astral-wheel-grid {
      display: grid;
      gap: 0.9rem;
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    }

    .astral-element-card {
      position: relative;
      background:
        radial-gradient(circle at top left, color-mix(in srgb, var(--element-color) 18%, transparent) 0%, transparent 42%),
        linear-gradient(180deg, rgba(251, 246, 239, 0.58) 0%, rgba(251, 246, 239, 0.18) 100%);
    }

    .astral-sign-chip {
      position: relative;
      display: grid;
      gap: 0.35rem;
      min-height: 9.5rem;
      align-content: space-between;
      padding: 1rem;
      border-radius: 1.1rem;
      border: 1px solid rgba(36, 27, 23, 0.1);
      background:
        radial-gradient(circle at top left, color-mix(in srgb, var(--sign-color) 22%, transparent) 0%, transparent 42%),
        linear-gradient(180deg, rgba(251, 246, 239, 0.8) 0%, rgba(251, 246, 239, 0.36) 100%);
      color: var(--color-moon);
      text-align: left;
      transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
    }

    .astral-sign-chip:hover,
    .astral-sign-chip[aria-pressed='true'] {
      transform: translateY(-2px);
      border-color: color-mix(in srgb, var(--sign-color) 48%, rgba(36, 27, 23, 0.2));
      box-shadow:
        0 18px 30px rgba(36, 27, 23, 0.06),
        0 0 0 1px color-mix(in srgb, var(--sign-color) 24%, transparent);
    }

    .astral-sign-chip:focus-visible {
      outline: none;
      border-color: rgba(127, 83, 178, 0.72);
      box-shadow:
        0 0 0 3px rgba(127, 83, 178, 0.18),
        0 18px 30px rgba(36, 27, 23, 0.06);
    }

    .astral-sign-glyph {
      font-size: 1.8rem;
      line-height: 1;
      color: var(--sign-color);
    }

    .astral-sign-name {
      font-size: 1.08rem;
      font-weight: 600;
      color: var(--color-moon);
    }

    .astral-sign-dates {
      font-size: 0.78rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--color-slate-300);
    }

    .astral-glyph-wrap {
      display: grid;
      place-items: center;
      width: 4.5rem;
      height: 4.5rem;
      border-radius: 1.2rem;
      border: 1px solid rgba(36, 27, 23, 0.1);
      background: linear-gradient(180deg, rgba(251, 246, 239, 0.82), rgba(251, 246, 239, 0.46));
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.4);
    }

    .astral-glyph {
      font-size: 2rem;
      line-height: 1;
      color: var(--color-accent);
    }

    .astral-mini-card,
    .astral-detail-card {
      border-top: 1px solid rgba(36, 27, 23, 0.12);
      padding: 1rem 0;
    }

    .astral-mini-label {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--color-accent);
    }

    .astral-detail-grid {
      display: grid;
      gap: 1rem;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    }

    .astral-helper-text {
      font-size: 0.94rem;
      line-height: 1.7;
      color: var(--color-slate-soft);
    }

    @media (max-width: 768px) {
      .astral-sign-chip {
        min-height: 8.6rem;
      }
    }
  </style>
</BaseLayout>
