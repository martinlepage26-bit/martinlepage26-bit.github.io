---
import { getCollection } from 'astro:content';
import FilterBar from '../../components/FilterBar.astro';
import PracticeHero from '../../components/PracticeHero.astro';
import SectionIntro from '../../components/SectionIntro.astro';
import WritingCard from '../../components/WritingCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { collectTags, contentSlug, estimateReadingMinutes, sortByDate, sortByTitle } from '../../lib/content';
import { pageMeta, siteMeta } from '../../data/site';

const writings = sortByDate(await getCollection('writings', ({ data }) => !data.draft));
const allProjects = await getCollection('projects');
const amazonBooks = sortByTitle(allProjects.filter((project) => /\bamazon\b/i.test(project.data.status)));
const tags = collectTags(writings);
const writingLinks = [
  { label: 'Visit HEXA', url: siteMeta.substack, variant: 'primary' as const },
  { label: 'Browse books', url: '#books', variant: 'secondary' as const },
  ...(siteMeta.siteUrl ? [{ label: 'Subscribe by RSS', url: '/rss.xml', variant: 'inline' as const }] : []),
  { label: 'Contact about editorial work', url: '/contact/', variant: 'inline' as const },
];
---

<BaseLayout
  title={pageMeta.writings.title}
  description={pageMeta.writings.description}
>
  <PracticeHero
    eyebrow="Writings"
    title="Essays, criticism, and books."
    description="This archive holds public prose: essays, notes, criticism, and published books. It is where conceptual work is tested in language meant to travel beyond specialist contexts."
    details="Academic publication records remain under Publications, and developmental manuscripts remain under Projects. This boundary keeps each archive legible."
    links={writingLinks}
    sideEyebrow="Reading path"
    sideTitle="How this archive is structured."
    sideDescription="Writings carry the public argument; they do not replace the scholarly archive or the project lab."
    sidePoints={[
      'HEXA remains the main outward channel for ongoing publication rhythm.',
      'Books remain visible here once publication status is confirmed.',
      'Projects and Publications keep developmental and academic records distinct.',
    ]}
    stats={[
      {
        eyebrow: 'Essays and notes',
        value: writings.length,
        label: 'Writing entries',
        description: 'Published essays, criticism, notes, and short-form public analysis.',
      },
      {
        eyebrow: 'Books',
        value: amazonBooks.length,
        label: 'Published titles',
        description: 'Self-published books with companion pages and stable outbound links.',
      },
      {
        eyebrow: 'Topics',
        value: tags.length,
        label: 'Filter tags',
        description: 'Searchable themes that track recurring concepts across the archive.',
      },
    ]}
  />

  <section class="section-shell">
    <div id="writing-archive">
      <SectionIntro
        eyebrow="Writing archive"
        title="Search essays and notes."
        description="Filter the on-site writing archive by theme, title, and description."
      />
    </div>

    <div class="mt-8">
      <FilterBar scopeId="writings" tags={tags} searchPlaceholder="Search writings" />
    </div>

    <div class="mt-10 grid gap-6 lg:grid-cols-2" data-filter-scope="writings">
      {writings.map((writing) => (
        <WritingCard writing={writing} readingMinutes={estimateReadingMinutes(writing.body ?? '')} />
      ))}
    </div>

    <div id="books" class="mt-20">
      <SectionIntro
        eyebrow="Books"
        title="Published books with companion records."
        description="Each title stays linked to its companion project page and outbound publication links."
      />

      <div class="mt-10 grid gap-6 lg:grid-cols-2">
        {amazonBooks.map((book) => (
          <article class="card-link">
            <div class="space-y-2">
              <p class="eyebrow">{book.data.status}</p>
              <h3 class="text-[1.06rem] leading-tight md:text-[1.28rem]">{book.data.title}</h3>
              <p class="text-sm text-slate-200">{book.data.subtitle}</p>
            </div>
            <p class="max-w-[58ch] text-base text-slate-200">{book.data.description}</p>
            <div class="flex flex-wrap gap-3 text-sm font-semibold text-accent">
              <a class="link-inline" href={`/projects/${contentSlug(book.id)}/`}>Open companion page</a>
              {book.data.links.map((link) => (
                <a class="link-inline" href={link.url}>{link.label}</a>
              ))}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
