---
import { getCollection } from 'astro:content';
import FilterBar from '../../components/FilterBar.astro';
import PracticeHero from '../../components/PracticeHero.astro';
import SectionIntro from '../../components/SectionIntro.astro';
import WritingCard from '../../components/WritingCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { collectTags, contentSlug, estimateReadingMinutes, sortByDate, sortByTitle } from '../../lib/content';
import { siteMeta } from '../../data/site';

const writings = sortByDate(await getCollection('writings', ({ data }) => !data.draft));
const allProjects = await getCollection('projects');
const amazonBooks = sortByTitle(allProjects.filter((project) => /\bamazon\b/i.test(project.data.status)));
const tags = collectTags(writings);
const writingLinks = [
  { label: 'Visit HEXA', url: siteMeta.substack, variant: 'primary' as const },
  { label: 'Browse the books', url: '#books', variant: 'secondary' as const },
  ...(siteMeta.siteUrl ? [{ label: 'Subscribe by RSS', url: '/rss.xml', variant: 'inline' as const }] : []),
];
---

<BaseLayout
  title="Writings"
  description="Essays, reflections, notes, and published book pages by Martin Lepage."
>
  <PracticeHero
    eyebrow="Writings"
    title="Essays, notes, and books."
    description="Public writing, criticism, reflections, and the confirmed book pages gathered in one place."
    details="This page keeps the public-facing prose together: essays, shorter reflections, and published book entries with companion detail pages and outbound links."
    links={writingLinks}
    sideEyebrow="Reading path"
    sideTitle="How to move through the writing archive."
    sideDescription="Writings is the more reader-facing side of the site, where editorial voice and public essays sit beside confirmed book metadata."
    sidePoints={[
      'HEXA remains the outward channel for ongoing publication rhythm.',
      'Books stay visible here once they are actually published.',
      'Projects and Publications hold the in-progress and academic archives separately.',
    ]}
    stats={[
      {
        eyebrow: 'Essays and notes',
        value: writings.length,
        label: 'Writing entries',
        description: 'Published reflections, criticism, notes, and shorter public writing.',
      },
      {
        eyebrow: 'Books',
        value: amazonBooks.length,
        label: 'Published titles',
        description: 'Self-published books with confirmed descriptions, companion pages, and stored links.',
      },
      {
        eyebrow: 'Topics',
        value: tags.length,
        label: 'Filter tags',
        description: 'Searchable themes carried across the on-site writing archive.',
      },
    ]}
  />

  <section class="section-shell">
    <div id="writing-archive">
      <SectionIntro
        eyebrow="Writing archive"
        title="Search essays and notes."
        description="Public-facing prose, shorter reflections, and criticism from the on-site writing archive."
      />
    </div>

    <div class="mt-8">
      <FilterBar scopeId="writings" tags={tags} searchPlaceholder="Search writings" />
    </div>

    <div class="mt-10 grid gap-6 lg:grid-cols-2" data-filter-scope="writings">
      {writings.map((writing) => (
        <WritingCard writing={writing} readingMinutes={estimateReadingMinutes(writing.body ?? '')} />
      ))}
    </div>

    <div id="books" class="mt-20">
      <SectionIntro
        eyebrow="Books"
        title="Published books with details and links."
        description="These self-published titles stay visible here with confirmed descriptions, companion pages, and stored outbound links."
      />

      <div class="mt-10 grid gap-6 lg:grid-cols-2">
        {amazonBooks.map((book) => (
          <article class="card-link">
            <div class="space-y-2">
              <p class="eyebrow">{book.data.status}</p>
              <h3 class="text-[1.06rem] leading-tight md:text-[1.28rem]">{book.data.title}</h3>
              <p class="text-sm text-slate-200">{book.data.subtitle}</p>
            </div>
            <p class="max-w-[58ch] text-base text-slate-200">{book.data.description}</p>
            <div class="flex flex-wrap gap-3 text-sm font-semibold text-accent">
              <a class="link-inline" href={`/projects/${contentSlug(book.id)}/`}>Read details</a>
              {book.data.links.map((link) => (
                <a class="link-inline" href={link.url}>{link.label}</a>
              ))}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
