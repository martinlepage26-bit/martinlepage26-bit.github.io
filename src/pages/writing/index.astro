---
import { getCollection } from 'astro:content';
import FilterBar from '../../components/FilterBar.astro';
import SectionIntro from '../../components/SectionIntro.astro';
import WritingCard from '../../components/WritingCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { collectTags, contentSlug, estimateReadingMinutes, sortByDate, sortByTitle } from '../../lib/content';
import { pageMeta, siteMeta } from '../../data/site';

const writings = sortByDate(await getCollection('writings', ({ data }) => !data.draft));
const allProjects = await getCollection('projects');
const amazonBooks = sortByTitle(allProjects.filter((project) => /\bamazon\b/i.test(project.data.status)));
const tags = collectTags(writings);
---

<BaseLayout
  title={pageMeta.writings.title}
  description={pageMeta.writings.description}
  pageClass="page-writing"
>
  <!-- Editorial hero: full-width single-column, no aside panel, no glass -->
  <section class="writing-editorial-hero">
    <div class="shell relative">
      <p class="eyebrow">Writings</p>
      <h1 class="writing-hero-title">Essays,<br /> criticism,<br /> and books.</h1>
      <p class="writing-hero-lead">
        Public prose: essays, notes, criticism, and published books. Where conceptual
        work is tested in language meant to travel beyond specialist contexts.
      </p>
      <p class="writing-hero-detail">
        Academic records stay under Publications; developmental manuscripts stay under Projects.
        This boundary keeps each archive legible.
      </p>

      <!-- Stats as a light ruled row, not panels -->
      <div class="writing-hero-stats">
        <div class="writing-hero-stat">
          <span class="writing-hero-stat-value">{writings.length}</span>
          <span class="writing-hero-stat-label">Writing entries</span>
        </div>
        <div class="writing-hero-stat">
          <span class="writing-hero-stat-value">{amazonBooks.length}</span>
          <span class="writing-hero-stat-label">Published books</span>
        </div>
        <div class="writing-hero-stat">
          <span class="writing-hero-stat-value">{tags.length}</span>
          <span class="writing-hero-stat-label">Filter tags</span>
        </div>
      </div>

      <div class="writing-hero-actions">
        <a class="button-primary" href={siteMeta.substack}>Visit HEXA</a>
        <a class="button-secondary" href="#books">Browse books</a>
        {siteMeta.siteUrl && <a class="button-secondary" href="/rss.xml">RSS feed</a>}
        <a class="button-secondary" href="/contact/">Contact about editorial work</a>
      </div>
    </div>
  </section>

  <section class="section-shell">
    <div id="writing-archive">
      <SectionIntro
        eyebrow="Writing archive"
        title="Search essays and notes."
        description="Filter the on-site writing archive by theme, title, and description."
      />
    </div>

    <div class="mt-8">
      <FilterBar scopeId="writings" tags={tags} searchPlaceholder="Search writings" />
    </div>

    <div class="mt-10 grid gap-6 lg:grid-cols-2" data-filter-scope="writings">
      {writings.map((writing) => (
        <WritingCard writing={writing} readingMinutes={estimateReadingMinutes(writing.body ?? '')} />
      ))}
    </div>

    <div id="books" class="mt-20">
      <SectionIntro
        eyebrow="Books"
        title="Published books with companion records."
        description="Each title stays linked to its companion project page and outbound publication links."
      />

      <div class="mt-10 grid gap-6 lg:grid-cols-2">
        {amazonBooks.map((book) => (
          <article class="card-link">
            <div class="space-y-2">
              <p class="eyebrow">{book.data.status}</p>
              <h3 class="text-[1.06rem] leading-tight md:text-[1.28rem]">{book.data.title}</h3>
              <p class="text-sm text-slate-200">{book.data.subtitle}</p>
            </div>
            <p class="max-w-[58ch] text-base text-slate-200">{book.data.description}</p>
            <div class="flex flex-wrap gap-3 text-sm font-semibold text-accent">
              <a class="link-inline" href={`/projects/${contentSlug(book.id)}/`}>Open companion page</a>
              {book.data.links.map((link) => (
                <a class="link-inline" href={link.url}>{link.label}</a>
              ))}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
