---
import { getCollection, render } from 'astro:content';
import EntryHero from '../../components/EntryHero.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { contentSlug, estimateReadingMinutes, formatDate } from '../../lib/content';
import { buildArticleSchema, buildCanonical } from '../../lib/seo';

export async function getStaticPaths() {
  const writings = await getCollection('writings', ({ data }) => !data.draft);
  return writings.map((writing) => ({
    params: { slug: contentSlug(writing.id) },
    props: { writing },
  }));
}

const { writing } = Astro.props;
const { Content } = await render(writing);
const minutes = estimateReadingMinutes(writing.body ?? '');
const canonical = `/writing/${contentSlug(writing.id)}/`;
const structuredData = buildArticleSchema({
  title: writing.data.title,
  description: writing.data.description,
  url: buildCanonical(canonical),
  datePublished: writing.data.date.toISOString(),
});
---

<BaseLayout title={writing.data.title} description={writing.data.description} canonical={canonical} structuredData={structuredData}>
  <EntryHero
    eyebrow="Writings"
    title={writing.data.title}
    description={writing.data.description}
    meta={`${formatDate(writing.data.date)} · ${minutes} min read`}
    backHref="/writing/"
    backLabel="Back to writings"
    tags={writing.data.tags}
    links={writing.data.externalUrl ? [{ label: writing.data.externalLabel ?? 'External link', url: writing.data.externalUrl }] : []}
  />

  <article class="section-shell grid gap-8 lg:grid-cols-[minmax(0,1fr)_320px]">
    <div class="reading-flow">
      <Content />
    </div>

    <aside class="space-y-6">
      <section class="veil-panel">
        <p class="eyebrow">Reading time</p>
        <p class="mt-4 text-base text-slate-200">{minutes} minutes</p>
      </section>
      {writing.data.externalUrl && (
        <section class="veil-panel">
          <p class="eyebrow">External connection</p>
          <a class="link-inline mt-4 inline-flex" href={writing.data.externalUrl}>
            {writing.data.externalLabel ?? 'Open external link'}
          </a>
        </section>
      )}
    </aside>
  </article>
</BaseLayout>
