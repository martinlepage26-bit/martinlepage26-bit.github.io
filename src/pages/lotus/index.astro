---
import LotusWorkbench from '../../components/lotus/LotusWorkbench.astro';
import LotusVectorWorkbench from '../../components/lotus/LotusVectorWorkbench.astro';
import SectionIntro from '../../components/SectionIntro.astro';
import { lotusBoundaryCards, lotusSignalGroups } from '../../data/lotus';
import LotusLayout from '../../layouts/LotusLayout.astro';
import { buildCanonical } from '../../lib/seo';

const pageDescription =
  'LOTUS is a reflective support and agency-scoring system for naming how pressure narrows choice, support, meaning, and room to move.';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Lotus',
  description: pageDescription,
  applicationCategory: 'ResearchApplication',
  url: buildCanonical('/lotus/'),
  creator: {
    '@type': 'Person',
    name: 'Martin Lepage',
  },
};
---

<LotusLayout title="Lotus" description={pageDescription} canonical="/lotus/" structuredData={structuredData}>
  <section class="section-shell border-b border-[rgba(255,255,255,0.08)] lotus-top-section">
    <div class="grid gap-8 xl:grid-cols-[minmax(0,1.16fr)_minmax(280px,0.84fr)] xl:items-start">
      <div class="max-w-4xl">
        <p class="eyebrow">Lotus</p>
        <h1 class="mt-5">Agency scorer and reflective workbench.</h1>
        <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-100 md:text-xl">
          Score a note in the browser, see which pressures rise to the surface, and move straight into the full LOTUS
          vector model below.
        </p>
        <div class="mt-8 flex flex-wrap gap-3 lotus-top-actions">
          <a class="button-primary" href="#lotus-workbench">Start scoring</a>
          <a class="button-secondary" href="#lotus-vector">Jump to the questions</a>
        </div>
        <p class="mt-4 max-w-2xl lotus-top-note">
          One route, two depths: a quick reading of the note, then the longer vector model when you need to stay with
          the shape of the situation.
        </p>
      </div>

      <aside class="veil-panel lotus-orientation-card">
        <p class="eyebrow">Orientation</p>
        <div class="mt-5 space-y-4">
          <div class="lotus-orientation-item">
            <p class="lotus-orientation-label">In browser</p>
            <p class="lotus-orientation-copy">
              Paste a note, score it in place, and read the active signals without stepping into another tool.
            </p>
          </div>
          <div class="lotus-orientation-item">
            <p class="lotus-orientation-label">Full model</p>
            <p class="lotus-orientation-copy">
              The longer questions and vector categories stay on this same route, so the quick read and deeper pass stay
              in one frame.
            </p>
          </div>
          <div class="lotus-orientation-item">
            <p class="lotus-orientation-label">Bounded use</p>
            <p class="lotus-orientation-copy">
              LOTUS is a reflective and analytical aid, not diagnosis, crisis care, or a substitute for human judgment.
            </p>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section id="lotus-workbench" class="section-shell">
    <SectionIntro
      eyebrow="Workbench"
      title="Map the pressure in your own words."
      description="Paste a journal entry, a situation note, or a working fragment. LOTUS reads for signal groups that gather around constraint, support, meaning, and room to act. The reading stays in your browser."
    />

    <div class="mt-12">
      <LotusWorkbench />
    </div>
  </section>

  <section id="lotus-vector" class="section-shell border-y border-[rgba(255,255,255,0.08)] bg-[rgba(8,11,16,0.72)]">
    <SectionIntro
      eyebrow="Vector model"
      title="Trace what narrows agency, and what keeps it open."
      description="For researchers, clinicians, and practitioners who need a structured reading of a situation. Rate base state, constraints, and supports, and LOTUS computes the effective agency vector through the full formula chain."
    />
    <div class="mt-12">
      <LotusVectorWorkbench />
    </div>
  </section>

  <section class="section-shell border-y border-[rgba(255,255,255,0.08)] bg-[rgba(8,11,16,0.72)]">
    <SectionIntro
      eyebrow="Signal library"
      title="Six patterns LOTUS listens for."
      description="These are not personality types. They are recurring forms of pressure, condition, and capacity: how choices narrow, how institutions bear down, how execution frays, and how meaning or creative life either holds or thins out."
    />

    <div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {lotusSignalGroups.map((group) => (
        <article class="veil-panel h-full">
          <div class="flex items-start justify-between gap-3">
            <div>
              <p class="eyebrow">{group.label}</p>
              <h2 class="mt-4 text-[1.08rem] md:text-[1.18rem]">{group.description}</h2>
            </div>
            <span class="lotus-weight-badge">{group.weight}</span>
          </div>
          <p class="mt-5 text-sm uppercase tracking-[0.18em] text-slate-400">Representative terms</p>
          <p class="mt-3 text-base leading-7 text-slate-200">{group.terms.slice(0, 5).join(', ')}</p>
        </article>
      ))}
    </div>
  </section>

  <section id="lotus-boundary" class="section-shell">
    <SectionIntro
      eyebrow="What LOTUS does not claim"
      title="LOTUS can clarify a situation. It cannot finish the interpretation."
      description="A clear read can widen room to act. But any reading remains partial, revisable, and answerable to context. LOTUS is built to support reflection without collapsing the person into the frame."
    />

    <div class="mt-12 grid gap-6 lg:grid-cols-3">
      {lotusBoundaryCards.map((item) => (
        <article class="veil-panel h-full">
          <h2 class="text-[1.08rem] md:text-[1.18rem]">{item.title}</h2>
          <p class="mt-4 text-base leading-7 text-slate-200">{item.body}</p>
        </article>
      ))}
    </div>
  </section>

  <style>
    .lotus-orientation-card {
      height: fit-content;
    }

    .lotus-orientation-item + .lotus-orientation-item {
      border-top: 1px solid rgba(255, 255, 255, 0.08);
      padding-top: 1rem;
    }

    .lotus-orientation-label {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      font-family: var(--font-mono);
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: #cc9967;
    }

    .lotus-orientation-label::before {
      content: '';
      width: 0.55rem;
      height: 0.55rem;
      border-radius: 999px;
      border: 1px solid rgba(204, 153, 103, 0.42);
      background: rgba(204, 153, 103, 0.12);
    }

    .lotus-orientation-copy {
      margin-top: 0.55rem;
      color: var(--lotus-text);
      font-size: 0.98rem;
      line-height: 1.7;
    }

    .lotus-top-actions .button-primary {
      border-color: rgba(200, 92, 136, 0.78);
      background: linear-gradient(135deg, #ef9fc0 0%, #d8709c 100%);
      color: #030508;
      box-shadow: 0 16px 30px rgba(216, 112, 156, 0.16);
    }

    .lotus-top-actions .button-primary:hover {
      background: linear-gradient(135deg, #f3accb 0%, #df7aa6 100%);
      color: #030508;
    }

    .lotus-weight-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 2.3rem;
      height: 2.3rem;
      border-radius: 999px;
      background: rgba(189, 138, 81, 0.12);
      color: var(--color-heading);
      font-family: var(--font-mono);
      font-size: 0.82rem;
      font-weight: 700;
      background: rgba(204, 153, 103, 0.14);
      color: var(--color-moon);
    }

    .lotus-top-note {
      color: var(--lotus-text-soft);
      font-size: 0.96rem;
      line-height: 1.72;
    }
  </style>
</LotusLayout>
