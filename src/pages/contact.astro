---
import ContactBlock from '../components/ContactBlock.astro';
import SectionIntro from '../components/SectionIntro.astro';
import { pageMeta } from '../data/site';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title={pageMeta.contact.title}
  description={pageMeta.contact.description}
>
  <section class="section-shell">
    <SectionIntro
      eyebrow="Contact"
      title="For serious governance, writing, and research work."
      description="Use the pathways below to route governance engagements, editorial requests, speaking invitations, research collaborations, or media outreach."
    />

    <div class="mt-8 max-w-3xl">
      <p class="text-base text-slate-200">
        A precise first message helps: include context, objective, constraints, and timeline. That makes it easier to
        return with the right next step, material, or scheduling option.
      </p>
    </div>

    <div class="mt-12">
      <ContactBlock />
    </div>
  </section>
</BaseLayout>
