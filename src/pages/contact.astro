---
import ContactBlock from '../components/ContactBlock.astro';
import { pageMeta } from '../data/site';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title={pageMeta.contact.title}
  description={pageMeta.contact.description}
  pageClass="page-contact"
>
  <!-- Narrow, centered, singular: one page, one action -->
  <div class="contact-centered">
    <p class="eyebrow">Contact</p>
    <h1>For serious work.</h1>
    <p class="contact-inst">
      Governance engagements, editorial requests, speaking invitations, research
      collaborations, and media outreach. A precise first message helps: context,
      objective, constraints, and timeline.
    </p>
    <div class="contact-divider" aria-hidden="true"></div>
    <ContactBlock />
  </div>
</BaseLayout>
