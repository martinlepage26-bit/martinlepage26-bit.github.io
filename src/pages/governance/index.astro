---
import { getCollection } from 'astro:content';
import ContactBlock from '../../components/ContactBlock.astro';
import PracticeHero from '../../components/PracticeHero.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import SectionIntro from '../../components/SectionIntro.astro';
import WritingCard from '../../components/WritingCard.astro';
import {
  governanceFit,
  governancePracticeAreas,
  governanceProjectSlugs,
  governanceWritingSlugs,
  pageMeta,
} from '../../data/site';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { estimateReadingMinutes, orderEntriesBySlug, sortByDate, sortByYear } from '../../lib/content';

const allProjects = sortByYear(await getCollection('projects'));
const allWritings = sortByDate(await getCollection('writings', ({ data }) => !data.draft));

const governanceProjects = orderEntriesBySlug(allProjects, governanceProjectSlugs);
const governanceWriting = orderEntriesBySlug(allWritings, governanceWritingSlugs);
---

<BaseLayout
  title={pageMeta.governance.title}
  description={pageMeta.governance.description}
>
  <PracticeHero
    eyebrow="Governance"
    title="AI governance strategy, documentation, and reviewable systems."
    description="This is the professional entry point: governance framing, decision traceability, evidence packaging, documentation, and public explanation for AI-related work."
    details="The wider archive remains on the site, but this is the place to start if you need the governance practice itself rather than the full record around it."
    links={[
      { label: 'Contact Martin', url: '/contact/', variant: 'primary' },
      { label: 'Open resume and CV', url: '/resume/', variant: 'secondary' },
      { label: 'Read governance-related writing', url: '/writing/', variant: 'inline' },
    ]}
    sideEyebrow="Best fit"
    sideTitle="What this page can support clearly."
    sideDescription="These are the areas the public record can support clearly and honestly right now."
    sidePoints={governanceFit}
    stats={[
      {
        eyebrow: 'Visible practice',
        value: governanceProjects.length,
        label: 'Governance records',
        description: 'Governance-related project entries currently visible on the site.',
      },
      {
        eyebrow: 'Public thinking',
        value: governanceWriting.length,
        label: 'Related essays',
        description: 'Selected writings that show how the governance thinking is articulated in public.',
      },
      {
        eyebrow: 'Working mode',
        value: 'EN/FR',
        label: 'Languages',
        description: 'Martin works in English and French across documentation, writing, and review-oriented work.',
      },
    ]}
  />

  <section class="section-shell">
    <SectionIntro
      eyebrow="Practice areas"
      title="What the governance work is for."
      description="The emphasis here is legibility, reviewability, and bounded claims: making AI-related work easier to inspect, explain, and govern inside real institutions."
    />

    <div class="mt-10 grid gap-4 md:grid-cols-2">
      {governancePracticeAreas.map((area) => (
        <article class="veil-panel h-full">
          <p class="eyebrow">Practice area</p>
          <h2 class="mt-3 text-[1.2rem] md:text-[1.34rem]">{area.title}</h2>
          <p class="mt-4 text-base text-slate-200">{area.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section-shell border-y border-[rgba(17,23,38,0.08)] bg-[rgba(251,246,239,0.32)]">
    <div class="grid gap-8 xl:grid-cols-[minmax(0,1.12fr)_minmax(0,0.88fr)]">
      <div>
        <SectionIntro
          eyebrow="Selected work"
          title="Projects that make the governance layer visible."
          description="These project records show governance as documents, workflows, and review surfaces rather than as branding language."
        />

        <div class="mt-10 grid gap-6 lg:grid-cols-2">
          {governanceProjects.map((project) => <ProjectCard project={project} />)}
        </div>
      </div>

      <div class="space-y-6">
        <div class="veil-panel">
          <p class="eyebrow">How the archive helps</p>
          <h2 class="mt-3 text-[1.28rem] md:text-[1.42rem]">The wider record still matters.</h2>
          <p class="mt-4 text-base text-slate-200">
            Publications, essays, and talks show the longer argument behind the practice, but you do not need the full
            archive to understand the professional offer here.
          </p>
          <ul class="bullet-links mt-6">
            <li><a class="link-inline" href="/papers/">Browse publications</a></li>
            <li><a class="link-inline" href="/projects/">Open the wider project archive</a></li>
          </ul>
        </div>

        <div class="veil-panel">
          <p class="eyebrow">Related writing</p>
          <h2 class="mt-3 text-[1.28rem] md:text-[1.42rem]">Essays that sharpen the public argument.</h2>
        </div>

        <div class="grid gap-6">
          {governanceWriting.map((writing) => (
            <WritingCard writing={writing} readingMinutes={estimateReadingMinutes(writing.body ?? '')} />
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section-shell">
    <ContactBlock />
  </section>
</BaseLayout>
