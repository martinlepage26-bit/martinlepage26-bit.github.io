---
import { getCollection, render } from 'astro:content';
import EntryHero from '../../../components/EntryHero.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { contentSlug, joinDistinctText } from '../../../lib/content';

export async function getStaticPaths() {
  const entries = await getCollection('research');
  return entries.map((entry) => ({
    params: { slug: contentSlug(entry.id) },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const canonical = `/governance/methods/${contentSlug(entry.id)}/`;

const allResearchEntries = await getCollection('research');
const bySlug = new Map(allResearchEntries.map((candidate) => [contentSlug(candidate.id), candidate]));
const relatedEntries = (entry.data.relatedWorks ?? [])
  .map((slug) => bySlug.get(slug))
  .filter((candidate): candidate is (typeof allResearchEntries)[number] => Boolean(candidate));

const meta = joinDistinctText([
  entry.data.family,
  entry.data.phase,
  entry.data.type,
  entry.data.status,
  entry.data.year,
]);

const originalTitleLabel = entry.data.originalTitle && entry.data.originalTitle !== entry.data.title
  ? entry.data.originalTitle
  : undefined;
---

<BaseLayout title={entry.data.title} description={entry.data.abstract} canonical={canonical} ogType="article">
  <EntryHero
    eyebrow={entry.data.family ?? 'Governance Methods'}
    title={entry.data.title}
    description={entry.data.abstract}
    meta={meta}
    backHref="/governance/methods/"
    backLabel="Back to governance methods"
    tags={entry.data.tags}
    links={entry.data.links}
  />

  <article class="section-shell reading-layout">
    <div class="reading-main reading-flow">
      {originalTitleLabel && (
        <section class="mb-10 border-y border-[rgba(17,23,38,0.08)] bg-[rgba(8,11,16,0.78)] p-5">
          <p class="eyebrow">Source title preserved</p>
          <p class="mt-4 text-base text-slate-700">{originalTitleLabel}</p>
          {entry.data.titleNote && <p class="mt-3 text-sm text-slate-600">{entry.data.titleNote}</p>}
        </section>
      )}

      <Content />
    </div>

    <aside class="reading-sidebar space-y-6">
      <section class="veil-panel">
        <p class="eyebrow">Role in tree</p>
        <p class="mt-4 text-[1.02rem] leading-7 text-slate-200">{entry.data.entryRole ?? 'major entry'}</p>
      </section>

      {entry.data.sourcePaths.length > 0 && (
        <section class="veil-panel">
          <p class="eyebrow">Source files</p>
          <ul class="mt-4 space-y-2 text-sm text-slate-200">
            {entry.data.sourcePaths.map((sourcePath) => (
              <li class="font-mono text-xs uppercase tracking-[0.08em] text-slate-400">{sourcePath}</li>
            ))}
          </ul>
        </section>
      )}

      {relatedEntries.length > 0 && (
        <section class="veil-panel">
          <p class="eyebrow">Related entries</p>
          <ul class="mt-4 space-y-3">
            {relatedEntries.map((related) => (
              <li>
                <a class="link-inline" href={`/governance/methods/${contentSlug(related.id)}/`}>
                  {related.data.title}
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}
    </aside>
  </article>
</BaseLayout>
