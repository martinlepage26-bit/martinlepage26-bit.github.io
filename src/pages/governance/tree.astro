];

function makeGovLeaf(n) {
  const el = document.createElement('div');
  el.className = 'leaf-node';
  el.innerHTML = `
    <div class="leaf-row" onclick="toggleAbs('g-${n.id}')">
      <div class="label-wrap">
        <div class="node-title">${n.label}</div>
        <div class="node-sub">${n.sub}</div>
      </div>
    </div>
    <div class="abstract-panel" id="g-${n.id}">
      <div class="panel-title">${n.full}</div>
      ${n.abstract}
      <div class="tags-row">${n.tags.map(t=>`<span class="tag-pill">${t}</span>`).join('')}</div>
    </div>
  `;
  return el;
}

function makeGovBranch(n) {
  const el = document.createElement('div');
  el.className = 'branch-node';
  el.innerHTML = `
    <div class="branch-row" onclick="toggleBr('gb-${n.id}')">
      <span class="toggle" id="gb-${n.id}-tog">+</span>
      <div class="label-wrap">
        <span class="branch-tag ${n.tagClass}">${n.label}</span>
      </div>
    </div>
    <div class="children" id="gb-${n.id}"></div>
  `;
  const ch = el.querySelector(`#gb-${n.id}`);
  n.children.forEach(c => ch.appendChild(makeGovLeaf(c)));
  return el;
}

// ── Skill Tree ───────────────────────────────────────────────────
const SKILL_DATA = [
  { id:"res", label:"Research & Analysis", badge:"b-research", tag:"Research", children:[
    {id:"gov2",label:"Recursive Governance Method",sub:"Control extraction from mixed archives",tags:["recursive analysis","control extraction","evidence hierarchy","method lock"]},
    {id:"trace",label:"Trace Investigator",sub:"Authority and accountability flow mapping",tags:["authority flow","definition drift","handoff mapping","bounded conclusions"]},
    {id:"power",label:"Power Analyst",sub:"Actors, incentives, leverage, hidden rules",tags:["actor map","incentives","leverage","structural power"]},
    {id:"qual",label:"Qualitative Methods",sub:"Study design, coding, interpretation",tags:["thematic analysis","ethnography","discourse analysis","positionality"]},
    {id:"red",label:"Red Team",sub:"Authorized adversarial exercise design",tags:["rules of engagement","purple team","executive reporting","adversary emulation"]},
  ]},
  { id:"wri", label:"Writing & Publishing", badge:"b-write", tag:"Writing", children:[
    {id:"peer",label:"Peer-Reviewed Paper Writer",sub:"Scholarly manuscript to submission",tags:["governing claim","contribution ladder","reviewer response","evidence sufficiency"]},
    {id:"novel",label:"Novelist",sub:"Novel planning, drafting, revision",tags:["character arc","plot momentum","POV control","scene structure"]},
    {id:"pub",label:"Publisher",sub:"Manuscript evaluation and positioning",tags:["editorial letter","acquisitions memo","jacket copy","metadata"]},
  ]},
  { id:"strat", label:"Strategy & Identity", badge:"b-strat", tag:"Strategy", children:[
    {id:"brand",label:"Brand Identity System",sub:"Diagnosis, positioning, visual direction",tags:["strategic brief","logo concepts","website direction","professional services"]},
    {id:"hum",label:"Humanize",sub:"Compliance rules redesigned for real behavior",tags:["rule redesign","COM-B","behavioral science","compliance"]},
  ]},
  { id:"orch", label:"Orchestration", badge:"b-orch", tag:"Orchestration", children:[
    {id:"pair",label:"Skill Pairing",sub:"Two-skill sequencing for one request",tags:["two-skill coordination","handoff artifact","analysis→writing"]},
    {id:"philosopher",label:"Philosopher",sub:"Conceptual framing, debate, cross-domain routing",tags:["debate engine","meta-router","value tension","epistemic pressure"]},
  ]},
  { id:"arch2", label:"Skill Architecture", badge:"b-arch", tag:"Architecture", children:[
    {id:"prompt",label:"Prompt Engineering Layer",sub:"Brain: persona, logic, constraints",tags:["persona","chain-of-thought","negative constraints","few-shot"]},
    {id:"ctx",label:"Context Engineering Layer",sub:"Map: knowledge retrieval and tool routing",tags:["knowledge retrieval","tool orchestration","memory","context pruning"]},
  ]},
];

function makeSkillLeaf(n) {
  const el = document.createElement('div');
  el.className = 'leaf-node';
  el.innerHTML = `
    <div class="leaf-row" onclick="toggleAbs('s-${n.id}')">
      <div class="label-wrap">
        <div class="node-title">${n.label}</div>
        <div class="node-sub">${n.sub}</div>
      </div>
    </div>
    <div class="abstract-panel" id="s-${n.id}">
      <div class="tags-row">${n.tags.map(t=>`<span class="tag-pill">${t}</span>`).join('')}</div>
    </div>
  `;
  return el;
}

function makeSkillBranch(n) {
  const el = document.createElement('div');
  el.className = 'branch-node';
  el.innerHTML = `
    <div class="branch-row" onclick="toggleBr('sb-${n.id}')">
      <span class="toggle" id="sb-${n.id}-tog">+</span>
      <div class="label-wrap">
        <span class="badge ${n.badge}">${n.tag} — ${n.label}</span>
      </div>
    </div>
    <div class="children" id="sb-${n.id}"></div>
  `;
  const ch = el.querySelector(`#sb-${n.id}`);
  n.children.forEach(c => ch.appendChild(makeSkillLeaf(c)));
  return el;
}

// ── Shared helpers ───────────────────────────────────────────────
function toggleBr(id) {
  const ch = document.getElementById(id);
  const tog = document.getElementById(id + '-tog');
  if (!ch || !tog) return;
  const open = ch.classList.toggle('open');
  tog.textContent = open ? '−' : '+';
  tog.classList.toggle('open', open);
}
function toggleAbs(id) {
  const el = document.getElementById(id);
  if (el) el.classList.toggle('open');
}

// ── Mount ────────────────────────────────────────────────────────
const govMount = document.getElementById('governance-tree-mount');
const skillMount = document.getElementById('skill-tree-mount');
const govTree = document.createElement('div'); govTree.className = 'tree';
const skillTree = document.createElement('div'); skillTree.className = 'tree';
GOV_DATA.forEach(n => govTree.appendChild(makeGovBranch(n)));
SKILL_DATA.forEach(n => skillTree.appendChild(makeSkillBranch(n)));
govMount.appendChild(govTree);
skillMount.appendChild(skillTree);
</script>
