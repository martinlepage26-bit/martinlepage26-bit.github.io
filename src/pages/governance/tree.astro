        tags:["constitution","voice constraints","receipts doctrine","stewardship","constraint design"] },
      { id:"alambic",
        label:"Constitutional Governance Architecture",
        sub:"Constitutional · Six-Layer Precedence Hierarchy and Amendment Channel",
        full:"Constitutional Governance Architecture: Precedence Hierarchy, Amendment Channel, and Ontological Integrity Controls",
        abstract:"Defines what counts as law, method, implementation, and laboratory. Establishes a six-layer precedence hierarchy and a five-step amendment channel that prevents drift, tone-smuggling, and ontology betrayal across the full governance stack.",
        tags:["precedence hierarchy","amendment channel","drift prevention","ontology","governance architecture"] },
      { id:"violet",
        label:"Governance Deployment Protocol",
        sub:"Operational · Switchback Architecture and Layer Structure",
        full:"Governance Deployment Protocol: Switchback Architecture, Voice Specification, and Operational Layer Structure",
        abstract:"Operational carry-kit for the AI Governance Master Project. Contains the Witches' Road Switchback Governance Protocol, voice specification, milestone map, and layer architecture. Seven trials with four switchback reversals prevent premature closure.",
        tags:["switchback protocol","voice specification","milestone map","layer architecture","operational"] },
      { id:"recurso",
        label:"First Implementation and Stabilization Record",
        sub:"Operational · Phase 1 Live Testing Against Bounded Corpus",
        full:"Recursive Deterministic AI Governance: First Implementation and Stabilization Record",
        abstract:"First live implementation and testing of the RDAIG method against a real bounded corpus. Produced baseline instability record, correction and stabilization passes, recursive plateau data, and failure harvest evidence that the methods paper reports as its first implementation results.",
        tags:["first implementation","live testing","stabilization","failure harvest","bounded corpus"] },
      { id:"skill",
        label:"Bounded AI Agent Governance",
        sub:"Operational · Governance-Primary Architecture and Dual-Layer Design",
        full:"Bounded AI Agent Governance: Governance-Primary Skill Architecture and Dual-Layer Design",
        abstract:"Governance is primary in the Hephaistos stack. Philosopher and power-analyst operate as co-equal right-arms, while recursive governance, trace, red-team, and companion skills execute within that bounded routing. Dual-layer brain-and-map architecture separates prompt engineering from context engineering.",
        tags:["SKILL.md","governance primary","philosopher","power-analyst","dual-layer"] },
      { id:"arch",
        label:"Recursive Archive Governance",
