      { id:"rdaig",
        label:"RDAIG Methods Paper",
        sub:"Core Method · First Implementation Results",
        full:"Recursive Deterministic AI Governance: Extracting Workflow Controls from Recursive Transformation of a Bounded Corpus",
        abstract:"Governance-control methods paper. Uses recursive transformation of a bounded corpus to identify where AI outputs stabilize, where drift enters, and where workflow controls must attach. Documents the first implementation results.",
        tags:["recursive governance","bounded corpus","workflow controls","agentic AI","auditability"] },
      { id:"dast",
        label:"Discursive Authority Stress Test",
        sub:"Experimental Governance · Authority Excess Under Recursive Pressure",
        full:"Discursive Authority Stress Test: Evidential Warrant, Authority Excess, and Recursive Pressure in AI Systems",
        abstract:"Subjects the recursive self-audit instrument to governance analysis. Measures how AI systems generate authority claims exceeding their evidential warrant under recursive pressure. Applies Goodhart's Law as a governance instrument.",
        tags:["discursive authority","evidential warrant","Goodhart's Law","recursive pressure","stress testing"] },
      { id:"ritual",
        label:"Ritual Authority in the Digital Age",
        sub:"Cultural Governance · Proof Regimes and Wiccan Practice",
        full:"Ritual Authority in the Digital Age: Proof Regimes, Legitimacy, and the Recomposition of Wiccan Practice",
        abstract:"Analyzes the recomposition of Wiccan witchcraft under digital circulation. Drawn from ethnographic fieldwork in Montréal and Québec. Shows how ritual authority becomes a governance problem when proof regimes shift from embodied community validation to digital visibility.",
        tags:["ritual authority","Wicca","proof regimes","ethnography","Québec"] },
      { id:"sealed",
        label:"Legitimacy as Pathway Authorization",
        sub:"Final Phase of Conceptualisation · Accountability Under Consequence Pressure",
        full:"Legitimacy as Pathway Authorization: Accountability, Proof Regimes, and Governance Under Consequence Pressure",
        abstract:"Examines how legitimacy operates as pathway authorization under consequence pressure. Develops a five-term apparatus — glitch, seam, charging, legibility, legitimacy — analyzed across art, academia, and ritual. Final conceptual phase of the AI Governance Master Project.",
        tags:["legitimacy","pathway authorization","proof regimes","accountability","consequence pressure"] },
      { id:"wheel",
        label:"Process Ontology and Recursive AI Deployment",
        sub:"Companion Study · Twenty-Two-Iteration Protocol Analysis",
        full:"Process Ontology and Recursive AI Deployment: Companion Analysis of the Twenty-Two-Iteration Protocol Study",
        abstract:"Companion study analyzing the 22-iteration deployment through process ontology, Buddhist philosophy, ritual theory, and STS. Examines what recursive self-interrogation reveals about the conditions and limits of AI self-knowledge.",
        tags:["process ontology","recursive deployment","AI self-knowledge","Buddhist philosophy","STS"] },
    ]
  },
  {
    id: "method", label: "Method", tag: "method", tagClass: "tag-method", children: [
      { id:"pipeline",
        label:"Twelve-Stage Control Pipeline",
        sub:"Core Pipeline · Corpus Formation Through Failure Harvesting",
        full:"Recursive Deterministic AI Governance: Canonical Twelve-Stage Control Pipeline and Workflow Binding Specification",
        abstract:"Canonical twelve-stage governance-control pipeline. Converts a bounded corpus into auditable workflow controls: corpus formation, intent embedding, multi-model rendering, triangulation, recursive return, control extraction, determinism hardening, deployment binding, logging, and failure harvesting. The endpoint is workflow binding, not recursive fluency.",
        tags:["twelve stages","control extraction","workflow binding","failure harvesting","corpus formation"] },
      { id:"mobius",
        label:"Recursive Self-Audit Protocol",
        sub:"Twenty-Eight-Step Adversarial Diagnostic · Forced Terminal Synthesis",
        full:"Recursive Self-Audit Protocol: A Twenty-Eight-Step Adversarial Diagnostic Instrument for AI Reasoning Coherence",
        abstract:"A twenty-eight-step adversarial diagnostic instrument. Each new conversation reinjects the full prior archive before the next prompt. Proceeds through recursive self-audit phases, context persistence tests, compressed archive injections, silence probes, and perturbation questions before arriving at forced terminal synthesis.",
        tags:["self-audit","recursive interrogation","perturbation testing","forced terminal synthesis","adversarial"] },
