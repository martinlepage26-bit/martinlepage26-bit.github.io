---
import { getCollection } from 'astro:content';
import FilterBar from '../../components/FilterBar.astro';
import PracticeHero from '../../components/PracticeHero.astro';
import PublicationCard from '../../components/PublicationCard.astro';
import SectionIntro from '../../components/SectionIntro.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { collectTags, isPublishedPaper, sortByYear } from '../../lib/content';
import { researchOverview, researchProfile } from '../../data/research';
import { siteMeta } from '../../data/site';

const publications = sortByYear((await getCollection('papers')).filter(isPublishedPaper));
const tags = collectTags(publications);
const paperYears = publications
  .map((paper) => paper.data.year)
  .filter((year): year is number => typeof year === 'number');
const archiveStartYear = paperYears.length > 0 ? Math.min(...paperYears) : undefined;
const archiveEndYear = paperYears.length > 0 ? Math.max(...paperYears) : undefined;
const archiveSpan =
  archiveStartYear && archiveEndYear
    ? archiveStartYear === archiveEndYear
      ? `${archiveStartYear}`
      : `${archiveStartYear}-${archiveEndYear}`
    : 'Selected years';
---

<BaseLayout
  title="Publications"
  description="A selected index of Martin Lepage's published academic work, with Academia.edu as the larger public archive."
>
  <PracticeHero
    eyebrow="Publications"
    title="Published academic work."
    description="This page is the on-site guide to the published record, with Academia.edu holding the larger outward archive."
    details="Manuscripts, unresolved leads, and other in-progress records stay under Projects. The archive here is limited to validated publication entries."
    links={[
      { label: 'Open Academia.edu', url: siteMeta.academia, variant: 'primary' },
      { label: 'Browse this site index', url: '#publication-archive', variant: 'secondary' },
      { label: 'See in-progress work under Projects', url: '/projects/', variant: 'inline' },
    ]}
    sideEyebrow="Archive boundary"
    sideTitle="What this page claims."
    sideDescription="This page is narrower than the full research universe. It lists records solid enough to stand as publications without mixing them with manuscripts or unresolved leads."
    sidePoints={[
      'Published articles, chapters, dissertation records, and reviews stay here as record entries.',
      'The larger outward archive continues on Academia.edu.',
      'In-progress manuscripts and unresolved leads move to Projects until publication or verification is confirmed.',
    ]}
    stats={[
      {
        eyebrow: 'Archive span',
        value: archiveSpan,
        label: 'Years covered',
        description: 'Years currently represented by the on-site publication index.',
      },
      {
        eyebrow: 'Published',
        value: publications.length,
        label: 'Publication entries',
        description: 'Entries currently presented as published academic work.',
      },
      {
        eyebrow: 'In progress',
        value: 'Projects',
        label: 'Unpublished work',
        description: 'Unpublished papers, books, and apps in development now live under Projects.',
      },
    ]}
  />

  <section class="section-shell">
    <div class="grid gap-6 xl:grid-cols-[minmax(0,1.35fr)_minmax(0,0.65fr)]">
      <article class="veil-panel">
        <p class="eyebrow">Canonical archive</p>
        <h2 class="mt-3 text-[1.42rem] md:text-[1.62rem]">The full paper archive is on Academia.edu.</h2>
        <p class="mt-4 max-w-[58ch] text-base text-slate-200">
          Use this page as the clean on-site guide to the published record. For the larger outward-facing archive, use
          Academia.edu. For in-progress manuscripts, unresolved review leads, and research still being confirmed, go to
          Projects.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a class="button-primary" href={siteMeta.academia}>Open Academia.edu</a>
          <a class="button-secondary" href="#publication-archive">Browse this site index</a>
        </div>
      </article>

      <div class="veil-panel">
        <p class="eyebrow">On-site use</p>
        <h2 class="mt-3 text-[1.28rem] md:text-[1.44rem]">Use this page as the bounded guide, not the exhaustive dump.</h2>
        <p class="mt-4 text-base text-slate-200">
          The on-site archive stays selective and readable. It includes only records with enough metadata to stand as
          publication entries, while the larger external stack remains available for the broader paper trail.
        </p>
      </div>
    </div>

    <div class="mt-10 max-w-4xl">
      <p class="text-lg leading-8 text-slate-200">{researchProfile}</p>
    </div>

    <div class="mt-12 grid gap-6 lg:grid-cols-3">
      {researchOverview.map((item) => (
        <article class="veil-panel h-full">
          <p class="eyebrow">Archive guide</p>
          <h2 class="mt-3 text-[1.24rem] md:text-[1.38rem]">{item.title}</h2>
          <p class="mt-4 text-base text-slate-200">{item.body}</p>
        </article>
      ))}
    </div>

    <div class="mt-14" id="publication-archive">
      <SectionIntro
        eyebrow="On-site index"
        title="Search the publications here."
        description="Search validated publications by title, venue, year, and topic."
      />
    </div>

    <div class="mt-8">
      <FilterBar scopeId="papers" tags={tags} searchPlaceholder="Search publications" />
    </div>

    <div class="mt-10 grid gap-6 lg:grid-cols-2" data-filter-scope="papers">
      {publications.map((paper) => <PublicationCard paper={paper} />)}
    </div>
  </section>
</BaseLayout>
