---
import { getCollection } from 'astro:content';
import FilterBar from '../../components/FilterBar.astro';
import PracticeHero from '../../components/PracticeHero.astro';
import PublicationCard from '../../components/PublicationCard.astro';
import SectionIntro from '../../components/SectionIntro.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { collectTags, isPublishedPaper, sortByYear } from '../../lib/content';
import { researchOverview, researchProfile } from '../../data/research';
import { pageMeta, siteMeta } from '../../data/site';

const publications = sortByYear((await getCollection('papers')).filter(isPublishedPaper));
const tags = collectTags(publications);
const paperYears = publications
  .map((paper) => paper.data.year)
  .filter((year): year is number => typeof year === 'number');
const archiveStartYear = paperYears.length > 0 ? Math.min(...paperYears) : undefined;
const archiveEndYear = paperYears.length > 0 ? Math.max(...paperYears) : undefined;
const archiveSpan =
  archiveStartYear && archiveEndYear
    ? archiveStartYear === archiveEndYear
      ? `${archiveStartYear}`
      : `${archiveStartYear}-${archiveEndYear}`
    : 'Selected years';
---

<BaseLayout
  title={pageMeta.publications.title}
  description={pageMeta.publications.description}
>
  <PracticeHero
    eyebrow="Publications"
    title="Published research and verified academic records."
    description="This section holds published articles, chapters, reviews, and dissertation-linked records. It keeps the publication boundary explicit so readers can distinguish validated outputs from in-progress work."
    details="The larger outward archive remains on Academia.edu. Manuscripts, unresolved leads, and exploratory material stay under Projects until they are publication-ready."
    links={[
      { label: 'Open Academia.edu', url: siteMeta.academia, variant: 'primary' },
      { label: 'Browse on-site index', url: '#publication-archive', variant: 'secondary' },
      { label: 'Open resume and CV', url: '/resume/', variant: 'inline' },
      { label: 'View in-progress work in Projects', url: '/projects/', variant: 'inline' },
    ]}
    sideEyebrow="Archive boundary"
    sideTitle="What this page includes."
    sideDescription="This archive remains intentionally strict: published records only, each with enough metadata to stand on its own."
    sidePoints={[
      'Published articles, chapters, dissertation records, and reviews are indexed here as bounded entries.',
      'Academia.edu remains the wider outward archive for additional publication context.',
      'Manuscripts and unresolved bibliographic leads remain under Projects until verification is complete.',
    ]}
    stats={[
      {
        eyebrow: 'Archive span',
        value: archiveSpan,
        label: 'Years covered',
        description: 'Years currently represented in the on-site publication index.',
      },
      {
        eyebrow: 'Published',
        value: publications.length,
        label: 'Publication entries',
        description: 'Entries currently presented as verified published work.',
      },
      {
        eyebrow: 'In progress',
        value: 'Projects',
        label: 'Unpublished work',
        description: 'Manuscripts and unresolved leads stay public under Projects until status changes.',
      },
    ]}
  />

  <section class="section-shell">
    <div class="grid gap-6 xl:grid-cols-[minmax(0,1.35fr)_minmax(0,0.65fr)]">
      <article class="veil-panel">
        <p class="eyebrow">Canonical archive</p>
        <h2 class="mt-3 text-[1.42rem] md:text-[1.62rem]">The complete outward stack remains on Academia.edu.</h2>
        <p class="mt-4 max-w-[58ch] text-base text-slate-200">
          This on-site index is designed for precision and readability. It keeps publication claims bounded while
          preserving a clear route to the broader external archive.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a class="button-primary" href={siteMeta.academia}>Open Academia.edu</a>
          <a class="button-secondary" href="#publication-archive">Browse on-site index</a>
        </div>
      </article>

      <div class="veil-panel">
        <p class="eyebrow">On-site method</p>
        <h2 class="mt-3 text-[1.28rem] md:text-[1.44rem]">Selective index, not exhaustive repository.</h2>
        <p class="mt-4 text-base text-slate-200">
          Publication entries stay separate from drafts and exploratory records so readers can evaluate claims at the
          right confidence level.
        </p>
      </div>
    </div>

    <div class="mt-10 max-w-4xl">
      <p class="text-lg leading-8 text-slate-200">{researchProfile}</p>
    </div>

    <div class="mt-12 grid gap-6 lg:grid-cols-3">
      {researchOverview.map((item) => (
        <article class="veil-panel h-full">
          <p class="eyebrow">Archive guide</p>
          <h2 class="mt-3 text-[1.24rem] md:text-[1.38rem]">{item.title}</h2>
          <p class="mt-4 text-base text-slate-200">{item.body}</p>
        </article>
      ))}
    </div>

    <div class="mt-14" id="publication-archive">
      <SectionIntro
        eyebrow="On-site index"
        title="Search the published record."
        description="Filter published articles, chapters, reviews, and dissertation-linked records by title, venue, year, and topic."
      />
    </div>

    <div class="mt-8">
      <FilterBar scopeId="papers" tags={tags} searchPlaceholder="Search publications" />
    </div>

    <div class="mt-10 grid gap-6 lg:grid-cols-2" data-filter-scope="papers">
      {publications.map((paper) => <PublicationCard paper={paper} />)}
    </div>
  </section>
</BaseLayout>
