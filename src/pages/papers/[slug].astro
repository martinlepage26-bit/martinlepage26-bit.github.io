---
import { getCollection, render } from 'astro:content';
import EntryHero from '../../components/EntryHero.astro';
import { siteMeta } from '../../data/site';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { contentSlug, isPublishedStatus, joinDistinctText } from '../../lib/content';
import { buildArticleSchema, buildCanonical } from '../../lib/seo';

export async function getStaticPaths() {
  const papers = (await getCollection('papers')).filter((paper) => isPublishedStatus(paper.data.status));
  return papers.map((paper) => ({
    params: { slug: contentSlug(paper.id) },
    props: { paper },
  }));
}

const { paper } = Astro.props;
const { Content } = await render(paper);
const canonical = `/papers/${contentSlug(paper.id)}/`;
const meta = joinDistinctText([paper.data.year, paper.data.venue, paper.data.status]);
const isPublished = isPublishedStatus(paper.data.status);
const structuredData = isPublished
  ? buildArticleSchema({
      title: paper.data.title,
      description: paper.data.abstract,
      url: buildCanonical(canonical),
      datePublished: `${paper.data.year}`,
      schemaType: 'ScholarlyArticle',
    })
  : undefined;
---

<BaseLayout
  title={paper.data.title}
  description={paper.data.abstract}
  canonical={canonical}
  ogType="article"
  structuredData={structuredData}
>
  <EntryHero
    eyebrow={paper.data.type}
    title={paper.data.title}
    description={paper.data.abstract}
    meta={meta}
    backHref={isPublished ? '/papers/' : '/projects/'}
    backLabel={isPublished ? 'Back to publications' : 'Back to projects'}
    tags={paper.data.tags}
    links={paper.data.links}
  />

  <article class="section-shell reading-layout">
    <div class="reading-main reading-flow">
      <Content />
    </div>

    <aside class="reading-sidebar">
      <section class="veil-panel">
        <p class="eyebrow">Citation</p>
        <p class="mt-4 text-[1.02rem] leading-7 text-slate-200">{paper.data.citation}</p>
      </section>
      <section class="veil-panel">
        <p class="eyebrow">Status</p>
        <p class="mt-4 text-[1.02rem] leading-7 text-slate-200">{paper.data.status}</p>
      </section>
      <section class="veil-panel">
        <p class="eyebrow">Archive</p>
        <p class="mt-4 text-[1.02rem] leading-7 text-slate-200">
          The broader public paper archive lives on Academia.edu. Use it for the full profile and outward-facing paper
          list.
        </p>
        <div class="mt-4">
          <a class="link-inline" href={siteMeta.academia}>Open Academia.edu profile</a>
        </div>
      </section>
      {paper.data.links.length > 0 && (
        <section class="veil-panel">
          <p class="eyebrow">Links</p>
          <ul class="mt-4 space-y-3">
            {paper.data.links.map((link) => (
              <li><a class="link-inline" href={link.url}>{link.label}</a></li>
            ))}
          </ul>
        </section>
      )}
    </aside>
  </article>
</BaseLayout>
