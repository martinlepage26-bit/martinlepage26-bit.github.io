---
import { getCollection } from 'astro:content';
import PracticeHero from '../../components/PracticeHero.astro';
import SectionIntro from '../../components/SectionIntro.astro';
import { pageMeta } from '../../data/site';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { sortByDate } from '../../lib/content';

const talks = sortByDate(await getCollection('talks'));
const talkYears = talks.map((talk) => talk.data.date.getFullYear());
const latestTalkYear = talkYears.length ? Math.max(...talkYears) : 'Current';
const earliestTalkYear = talkYears.length ? Math.min(...talkYears) : 'Current';
const talkSpan = earliestTalkYear === latestTalkYear ? `${latestTalkYear}` : `${earliestTalkYear}-${latestTalkYear}`;
const talkFormatCount = new Set(talks.map((talk) => talk.data.format)).size;
---

<BaseLayout title={pageMeta.talks.title} description={pageMeta.talks.description}>
  <PracticeHero
    eyebrow="Talks and media"
    title="Talks, panels, and invited public argument."
    description="A concise speaking archive of conference presentations, panels, and invited appearances across governance, legitimacy, and cultural analysis."
    details="This page keeps the speaking record readable and bounded without folding it into publication or writing archives."
    links={[
      { label: 'Browse talks', url: '#talk-archive', variant: 'primary' },
      { label: 'Open resume and CV', url: '/resume/', variant: 'secondary' },
      { label: 'Read publications', url: '/papers/', variant: 'inline' },
      { label: 'Contact about talks', url: '/contact/', variant: 'inline' },
    ]}
    sideEyebrow="Speaking profile"
    sideTitle="What this archive makes visible."
    sideDescription="The talks archive shows how the work translates across scholarly, professional, and public-facing contexts."
    sidePoints={[
      'Conference talks and panel sessions remain organized as one readable archive.',
      'Format labels keep event context legible at a glance.',
      'Readers can move directly from talks into publications, writing, or contact.',
    ]}
    stats={[
      {
        eyebrow: 'Appearances',
        value: talks.length,
        label: 'Talk records',
        description: 'Conference talks, panels, sessions, and public-facing speaking entries.',
      },
      {
        eyebrow: 'Archive span',
        value: talkSpan,
        label: 'Years covered',
        description: 'Years represented in the current on-site speaking archive.',
      },
      {
        eyebrow: 'Formats',
        value: talkFormatCount,
        label: 'Distinct formats',
        description: 'Different appearance formats represented across the archive.',
      },
    ]}
  />

  <section class="section-shell">
    <div id="talk-archive">
      <SectionIntro
        eyebrow="Talk archive"
        title="Talks, panels, and presentations."
        description="Conference presentations, panels, sessions, and related speaking records from the public archive."
      />
    </div>

    <div class="mt-10 space-y-5">
      {talks.map((talk) => (
        <article class="veil-panel grid gap-5 md:grid-cols-[160px_minmax(0,1fr)]">
          <div>
            <p class="eyebrow">{talk.data.dateLabel ?? talk.data.date.getFullYear()}</p>
            <p class="mt-3 text-sm uppercase tracking-[0.2em] text-slate-400">{talk.data.format}</p>
          </div>
          <div>
            <h2 class="text-[1.3rem] md:text-[1.46rem]">{talk.data.title}</h2>
            <p class="mt-2 text-sm uppercase tracking-[0.2em] text-slate-400">{talk.data.event}{talk.data.location ? ` · ${talk.data.location}` : ''}</p>
            <p class="mt-4 text-base text-slate-200">{talk.data.description}</p>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
