---
import '@fontsource-variable/space-grotesk';
import '@fontsource/ibm-plex-sans/400.css';
import '@fontsource/ibm-plex-sans/600.css';
import '../../styles/echo-standalone.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="ECHO local file-to-MP3 text-to-speech app with voice selection and no paid API." />
    <meta name="theme-color" content="#5ba7ff" />
    <link rel="stylesheet" href="/martin-portfolio/index.css" />
    <title>ECHO | File to MP3</title>
  </head>
  <body class="echo-standalone">
    <div class="echo-shell">
      <header class="echo-header">
        <a class="echo-brand" href="/echo/">
          <span class="echo-mark">ECHO</span>
          <span class="echo-tagline">File-in -> Voice -> MP3-out</span>
        </a>
        <nav class="echo-nav" aria-label="ECHO navigation">
          <a href="/projects/echo/">Project details</a>
          <a href="/projects/">All projects</a>
          <a href="/contact/">Contact</a>
        </nav>
      </header>

      <main class="echo-main">
        <section class="echo-hero">
          <p class="echo-eyebrow">Text-to-Speech</p>
          <h1>ECHO / Ariel / Voice11</h1>
          <p>Drag in a file, choose a real local synthesis voice, and generate a downloadable MP3.</p>
          <p>No paid API key and no backend inference service are required for this route.</p>
          <div class="echo-actions">
            <a class="echo-button secondary" href="/projects/echo/">Project details</a>
            <a class="echo-button secondary" href="mailto:martinlepage.ai@gmail.com">Report issue</a>
          </div>
        </section>

        <section class="echo-workbench" aria-labelledby="echo-workbench-title" data-echo-app>
          <div class="echo-workbench-head">
            <p class="echo-eyebrow">Generator</p>
            <h2 id="echo-workbench-title">File to MP3</h2>
            <p>Supported upload formats: <code>.txt</code>, <code>.md</code>, <code>.docx</code>, <code>.pdf</code>.</p>
          </div>

          <div class="echo-dropzone" data-echo-dropzone tabindex="0" role="button" aria-label="Drop file here or click to choose file">
            <p><strong>Drop file here</strong> or click to browse</p>
            <p>Text will be extracted locally in the browser.</p>
            <input class="echo-file-input" data-echo-file-input type="file" accept=".txt,.md,.markdown,.docx,.pdf" />
          </div>

          <p class="echo-file-meta" data-echo-file-meta>No file selected yet.</p>

          <div class="echo-form-grid">
            <label class="echo-field" for="echo-voice">
              <span class="echo-field-label">Voice Dashboard</span>
              <select id="echo-voice" class="echo-input" data-echo-voice></select>
            </label>

            <div class="echo-field">
              <span class="echo-field-label">Selected Voice</span>
              <p class="echo-voice-meta" data-echo-voice-meta></p>
            </div>

            <label class="echo-field echo-field-full" for="echo-text">
              <span class="echo-field-label">Extracted Text</span>
              <textarea id="echo-text" class="echo-textarea" data-echo-text rows="12" placeholder="Upload a file to populate text. You can edit before generation."></textarea>
            </label>
          </div>

          <div class="echo-runner">
            <button class="echo-button primary" type="button" data-echo-generate disabled>Generate MP3</button>
          </div>

          <div class="echo-progress-shell" aria-live="polite">
            <p class="echo-status" data-echo-status data-tone="info">Initializing...</p>
            <progress class="echo-progress" data-echo-progress max="100" value="0"></progress>
            <p class="echo-progress-label" data-echo-progress-label>Idle</p>
          </div>

          <section class="echo-result" data-echo-result hidden>
            <h3>Generated MP3</h3>
            <audio class="echo-audio" data-echo-audio controls preload="metadata"></audio>
            <a class="echo-button secondary" data-echo-download href="#">Download MP3</a>
            <p class="echo-note" data-echo-result-meta></p>
          </section>
        </section>
      </main>
    </div>

    <script>
      import { initEchoFileToMp3App } from '../../scripts/echo-file-to-mp3.js';

      initEchoFileToMp3App();
    </script>
  </body>
</html>
