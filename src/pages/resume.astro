---
import { getCollection } from 'astro:content';
import ResumeSection from '../components/ResumeSection.astro';
import SectionIntro from '../components/SectionIntro.astro';
import { pageMeta } from '../data/site';
import BaseLayout from '../layouts/BaseLayout.astro';
import { isPublishedPaper, sortByYear } from '../lib/content';

const papers = sortByYear(await getCollection('papers'));
const selectedPublications = papers.filter((entry) => isPublishedPaper(entry)).slice(0, 4);
---

<BaseLayout
  title={pageMeta.resume.title}
  description={pageMeta.resume.description}
>
  <section class="section-shell">
    <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
      <SectionIntro
        eyebrow="Resume and CV"
        title="Professional record, selected publications, and downloads."
        description="A concise record of governance practice, research operations, publications, and institutional experience."
      />

      <ul class="bullet-links">
        <li><a class="link-inline" href="/files/Martin-Lepage-CV-2026.pdf">Download PDF</a></li>
        <li><a class="link-inline" href="/files/Martin-Lepage-CV-2026.docx">Download DOCX</a></li>
        <li><a class="link-inline" href="/governance/">Open governance practice</a></li>
        <li><a class="link-inline" href="/papers/">Read publications</a></li>
        <li><a class="link-inline" href="/talks/">View talks</a></li>
        <li><a class="link-inline" href="/contact/">Contact Martin</a></li>
      </ul>
    </div>

    <div class="mt-12">
      <ResumeSection selectedPublications={selectedPublications} />
    </div>
  </section>
</BaseLayout>
