---
import { getCollection } from 'astro:content';
import ResumeSection from '../components/ResumeSection.astro';
import { pageMeta } from '../data/site';
import BaseLayout from '../layouts/BaseLayout.astro';
import { isPublishedPaper, sortByYear } from '../lib/content';

const papers = sortByYear(await getCollection('papers'));
const selectedPublications = papers.filter((entry) => isPublishedPaper(entry)).slice(0, 4);
---

<BaseLayout
  title={pageMeta.resume.title}
  description={pageMeta.resume.description}
  pageClass="page-resume"
>
  <section class="section-shell">

    <!-- Document masthead: identity left, downloads right — no hero composition -->
    <div class="resume-masthead">
      <div class="resume-identity">
        <img
          src="/assets/ml-signature-monogram.svg"
          alt=""
          aria-hidden="true"
          class="resume-monogram"
        />
        <div class="resume-name-block">
          <h1>Martin Lepage, PhD</h1>
          <p class="resume-subtitle">AI Governance · Research Operations · Strategic Writing</p>
        </div>
      </div>
      <div class="resume-dl-links">
        <a class="button-primary" href="/files/Martin-Lepage-CV-2026.pdf">Download PDF</a>
        <a class="button-secondary" href="/files/Martin-Lepage-CV-2026.docx">Download DOCX</a>
      </div>
    </div>

    <!-- Quick nav: pill links, not bullet list -->
    <nav class="resume-quick-nav" aria-label="Resume sections">
      <a href="/governance/">Governance Practice</a>
      <a href="/papers/">Publications</a>
      <a href="/talks/">Talks</a>
      <a href="/projects/">Projects</a>
      <a href="/contact/">Contact Martin</a>
    </nav>

    <div class="mt-2">
      <ResumeSection selectedPublications={selectedPublications} />
    </div>

  </section>
</BaseLayout>
