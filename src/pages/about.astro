---
import BackgroundTreatment from '../components/BackgroundTreatment.astro';
import ContactBlock from '../components/ContactBlock.astro';
import SectionIntro from '../components/SectionIntro.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { biography, pageMeta, researchInterests, timeline } from '../data/site';
---

<BaseLayout title={pageMeta.about.title} description={pageMeta.about.description}>
  <section class="relative overflow-hidden border-b border-[rgba(36,27,23,0.12)]">
    <BackgroundTreatment variant="hero" />
    <div class="section-shell relative grid gap-10 lg:grid-cols-[minmax(0,1fr)_340px] lg:items-center">
      <div>
        <SectionIntro
          eyebrow="About"
          title="Research background and working context."
          description={biography.intro}
        />
        <div class="mt-8 space-y-5">
          {biography.paragraphs.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </div>
      </div>

      <figure class="veil-panel veil-panel-bare relative mx-auto w-full max-w-[18.5rem] overflow-hidden lg:mx-0 lg:justify-self-end">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(205,255,54,0.1),transparent_34%),linear-gradient(180deg,rgba(255,255,255,0.08),transparent_48%)]"></div>
        <div class="relative overflow-hidden border border-[rgba(17,23,38,0.08)] bg-[linear-gradient(180deg,rgba(245,241,237,0.82),rgba(245,241,237,0.26))]">
          <img
            src="/assets/portrait.png"
            alt="Portrait of Martin Lepage"
            class="negative-restore-image aspect-[4/5] w-full object-cover object-center"
          />
          <div class="absolute inset-x-0 bottom-0 bg-[linear-gradient(180deg,transparent,rgba(17,23,38,0.76))] p-5">
            <p class="eyebrow">Martin Lepage</p>
            <p class="mt-2 max-w-xs text-sm leading-6 text-slate-100">
              AI governance strategist. PhD, Religious Sciences. Working across governance, media, and public writing.
            </p>
          </div>
        </div>
      </figure>
    </div>
  </section>

  <section class="section-shell">
    <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_360px]">
      <div class="veil-panel">
        <p class="eyebrow">Current work</p>
        <h2 class="mt-3 text-[1.42rem] md:text-[1.62rem]">Current focus.</h2>
        <p class="mt-5 text-lg leading-8 text-slate-200">{biography.currentWork}</p>
        <ul class="bullet-links mt-6">
          <li><a class="link-inline" href="/governance/">Start with governance practice</a></li>
          <li><a class="link-inline" href="/papers/">Browse publications</a></li>
          <li><a class="link-inline" href="/resume/">Open resume and CV</a></li>
        </ul>
      </div>

      <div class="veil-panel">
        <p class="eyebrow">Research and professional interests</p>
        <ul class="mt-5 space-y-3 text-base text-slate-200">
          {researchInterests.map((interest) => (
            <li class="border-t border-[rgba(36,27,23,0.12)] pt-3">
              {interest}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="section-shell border-y border-[rgba(36,27,23,0.08)] bg-[rgba(251,246,239,0.28)]">
    <SectionIntro
      eyebrow="Timeline"
      title="How this work took shape."
      description="Study, research, and operational work from literary studies through governance and clinical coordination."
    />

    <div class="mt-12 space-y-5">
      {timeline.map((item) => (
        <article class="grid gap-4 border-t border-[rgba(36,27,23,0.12)] pt-6 md:grid-cols-[140px_minmax(0,1fr)]">
          <p class="text-sm font-semibold uppercase tracking-[0.14em] text-accent">{item.year}</p>
          <div>
            <h3 class="text-[1.12rem] md:text-[1.28rem]">{item.title}</h3>
            <p class="mt-2 text-base text-slate-200">{item.detail}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section-shell">
    <ContactBlock />
  </section>
</BaseLayout>
