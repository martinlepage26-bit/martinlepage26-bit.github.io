---
import { siteMeta } from '../data/site';

const pathname = Astro.url.pathname;

const isActivePath = (href: string) => {
  const cleanHref = href.split('#')[0] || '/';
  return cleanHref === '/' ? pathname === '/' : pathname === cleanHref || pathname.startsWith(cleanHref);
};

const navItems = [
  { href: '/governance/', label: 'Governance' },
  { href: '/papers/', label: 'Publications' },
  { href: '/writing/', label: 'Writings' },
  { href: '/talks/', label: 'Talks' },
  { href: '/projects/', label: 'Projects' },
  { href: '/about/', label: 'About' },
].map(({ href, label }) => ({
  href,
  label,
  isActive: isActivePath(href),
}));

const utilityItems = [{ href: '/contact/', label: 'Contact', isActive: isActivePath('/contact/') }];
---

<header class="site-header sticky top-0 z-40 border-b border-[rgba(17,23,38,0.08)] bg-[rgba(246,241,233,0.9)] backdrop-blur-[16px]">
  <div class="shell flex items-center justify-between gap-6 py-4">
    <a class="group inline-flex min-w-0 items-center gap-3 text-sm font-semibold text-moon" href="/">
      <span class="brand-monogram relative flex items-center justify-center">
        <img src="/assets/ml-signature-monogram.svg" alt="" class="h-9 w-auto object-contain md:h-10" />
      </span>
      <span class="flex min-w-0 flex-col leading-tight">
        <span class="truncate font-display text-[1.08rem] tracking-[0.01em] text-moon">Martin Lepage</span>
        <span class="hidden truncate text-[0.69rem] font-medium uppercase tracking-[0.14em] text-slate-300 2xl:block">
          {siteMeta.jobTitle}
        </span>
      </span>
    </a>

    <nav aria-label="Primary" class="hidden min-w-0 items-center gap-3 xl:flex 2xl:gap-4">
      {
        navItems.map(({ href, isActive, label }) => (
          <a
            href={href}
            aria-current={isActive ? 'page' : undefined}
            class:list={[
              'border-b-2 px-0.5 py-2 text-[0.72rem] font-semibold uppercase tracking-[0.14em] transition',
              isActive
                ? 'border-accent text-accent'
                : 'border-transparent text-slate-300 hover:border-[rgba(55,92,145,0.2)] hover:text-moon',
            ]}
          >
            {label}
          </a>
        ))
      }
    </nav>

    <div class="hidden items-center gap-3 md:flex">
      {utilityItems.map(({ href, isActive, label }) => (
        <a
          href={href}
          aria-current={isActive ? 'page' : undefined}
          class:list={[
            'button-primary',
            'px-4 py-2 text-[0.68rem]',
            isActive && 'ring-1 ring-[rgba(55,92,145,0.32)]',
          ]}
        >
          {label}
        </a>
      ))}
    </div>

    <details class="group relative xl:hidden">
      <summary class="flex list-none cursor-pointer items-center gap-3 rounded-full border border-[rgba(17,23,38,0.1)] bg-[rgba(250,247,242,0.92)] px-4 py-2 font-mono text-[0.72rem] uppercase tracking-[0.18em] text-slate-300 transition hover:border-[rgba(55,92,145,0.24)] hover:text-moon [&::-webkit-details-marker]:hidden">
        Menu
        <span class="text-base leading-none text-slate-300 transition group-open:rotate-45 group-open:text-accent" aria-hidden="true">
          +
        </span>
      </summary>

      <div class="absolute right-0 top-[calc(100%+0.75rem)] w-[min(20rem,calc(100vw-2rem))] rounded-[1rem] border border-[rgba(17,23,38,0.08)] bg-[rgba(250,247,242,0.98)] p-3 shadow-[0_20px_48px_rgba(17,23,38,0.08)]">
        <nav aria-label="Primary mobile" class="grid gap-1">
          {navItems.map(({ href, isActive, label }) => (
            <a
              href={href}
              aria-current={isActive ? 'page' : undefined}
              class:list={[
                'px-3 py-3 text-[0.76rem] font-semibold uppercase tracking-[0.16em] transition',
                isActive ? 'text-accent' : 'text-slate-200 hover:text-moon',
              ]}
            >
              {label}
            </a>
          ))}

          <div class="mt-2 border-t border-[rgba(17,23,38,0.08)] pt-3 md:hidden">
            {utilityItems.map(({ href, isActive, label }) => (
              <a
                href={href}
                aria-current={isActive ? 'page' : undefined}
                class:list={[
                  'block px-3 py-3 text-[0.76rem] font-semibold uppercase tracking-[0.16em] transition',
                  isActive ? 'text-accent' : 'text-slate-200 hover:text-moon',
                ]}
              >
                {label}
              </a>
            ))}
          </div>
        </nav>
      </div>
    </details>
  </div>
</header>
