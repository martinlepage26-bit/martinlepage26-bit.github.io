---
interface Props {
  scopeId: string;
  tags: string[];
  searchPlaceholder?: string;
}

const { scopeId, tags, searchPlaceholder = 'Search by title, theme, or keyword' } = Astro.props;
const seenTags = new Set<string>();
const normalizedTags = tags.filter((tag) => {
  const key = tag.toLowerCase();
  if (seenTags.has(key)) {
    return false;
  }

  seenTags.add(key);
  return true;
});
---

<div data-filter-root={scopeId}>
  <div class="filter-shell">
    <div class="filter-toolbar">
      <label class="filter-field">
        <span class="filter-label">Find</span>
        <input
          data-filter-search
          class="filter-search"
          type="search"
          placeholder={searchPlaceholder}
        />
      </label>

      <label class="filter-field">
        <span class="filter-label">Theme</span>
        <select class="filter-select" data-filter-tag>
          <option value="all">All themes</option>
          {normalizedTags.map((tag) => (
            <option value={tag.toLowerCase()}>{tag}</option>
          ))}
        </select>
      </label>

      <div class="filter-actions">
        <span class="filter-count" data-filter-count></span>
        <button class="filter-reset" data-filter-reset type="button">Clear</button>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  const script = document.currentScript;
  const root = script?.previousElementSibling;
  const scopeId = root?.getAttribute('data-filter-root');
  const scope = scopeId ? document.querySelector(`[data-filter-scope="${scopeId}"]`) : null;

  if (root && scope) {
    const input = root.querySelector('[data-filter-search]');
    const select = root.querySelector('[data-filter-tag]');
    const reset = root.querySelector('[data-filter-reset]');
    const count = root.querySelector('[data-filter-count]');
    const items = [...scope.querySelectorAll('[data-filter-item]')];
    let activeTag = 'all';

    const applyFilters = () => {
      const searchValue = input instanceof HTMLInputElement ? input.value.trim().toLowerCase() : '';
      let visibleCount = 0;

      items.forEach((item) => {
        const tagValue = item.getAttribute('data-tags') ?? '';
        const searchSource = item.getAttribute('data-search') ?? '';
        const matchesTag = activeTag === 'all' || tagValue.includes(activeTag);
        const matchesSearch = !searchValue || searchSource.includes(searchValue);
        const visible = matchesTag && matchesSearch;

        item.toggleAttribute('hidden', !visible);
        if (visible) visibleCount += 1;
      });

      if (count instanceof HTMLElement) {
        count.textContent = `${visibleCount} shown`;
      }
    };

    select?.addEventListener('change', () => {
      activeTag = select instanceof HTMLSelectElement ? select.value : 'all';
      applyFilters();
    });

    input?.addEventListener('input', applyFilters);
    reset?.addEventListener('click', () => {
      if (input instanceof HTMLInputElement) {
        input.value = '';
      }

      if (select instanceof HTMLSelectElement) {
        select.value = 'all';
      }

      activeTag = 'all';
      applyFilters();
    });
    applyFilters();
  }
</script>
