---
import type { CollectionEntry } from 'astro:content';
import { contentSlug, formatDate } from '../lib/content';

interface Props {
  writing: CollectionEntry<'writings'>;
  readingMinutes: number;
}

const { writing, readingMinutes } = Astro.props;
---

<article data-filter-item data-tags={writing.data.tags.join('|').toLowerCase()} data-search={`${writing.data.title} ${writing.data.description} ${writing.data.tags.join(' ')}`.toLowerCase()}>
  <a class="group card-link" href={`/writing/${contentSlug(writing.id)}/`}>
    <div class="flex flex-wrap items-center gap-3 text-xs font-semibold uppercase tracking-[0.14em] text-slate-400">
      <span>{formatDate(writing.data.date)}</span>
      <span class="h-1 w-1 rounded-full bg-accent/70"></span>
      <span>{readingMinutes} min read</span>
    </div>
    <div>
      <h3 class="text-[1rem] leading-tight md:text-[1.22rem]">{writing.data.title}</h3>
      <p class="mt-3 max-w-[58ch] text-base text-slate-200">{writing.data.description}</p>
    </div>
    <div class="mt-auto flex flex-wrap gap-3 text-sm font-semibold text-accent group-hover:text-moon">
      <span>Read essay</span>
      {writing.data.externalUrl && <span>Also linked externally</span>}
    </div>
  </a>
</article>
