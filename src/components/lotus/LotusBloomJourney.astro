---
import { lotusBloomQuestions } from '../../data/lotus';

const appData = {
  questions: lotusBloomQuestions,
};
---

<section class="lotus-bloom-app" data-lotus-bloom-root data-mode="forward" data-bloom-state="bud" data-save-state="idle">
  <div class="lotus-bloom-stage">
    <header class="lotus-bloom-rail">
      <button id="lotus-nav-down" class="lotus-rail-button" type="button" disabled>
        Back down
      </button>
      <div class="lotus-rail-copy">
        <p id="lotus-progress-label" class="lotus-rail-progress">Before the first bloom</p>
        <p id="lotus-mode-label" class="lotus-rail-mode">Begin when ready</p>
      </div>
      <button id="lotus-return-current" class="lotus-rail-button" type="button" hidden>
        Return upward
      </button>
    </header>

    <div class="lotus-bloom-viewport">
      <p id="lotus-trust-note" class="lotus-trust-note">
        What closes into the stalk is still kept. To recover earlier answers, move back down the stalk deliberately.
      </p>

      <div class="lotus-bloom-focus">
        <div class="lotus-bloom-shell">
          <div class="lotus-bloom-aura" aria-hidden="true"></div>
          <div class="lotus-bloom-petal lotus-bloom-petal-one" aria-hidden="true"></div>
          <div class="lotus-bloom-petal lotus-bloom-petal-two" aria-hidden="true"></div>
          <div class="lotus-bloom-petal lotus-bloom-petal-three" aria-hidden="true"></div>
          <div class="lotus-bloom-petal lotus-bloom-petal-four" aria-hidden="true"></div>

          <div id="lotus-bud-panel" class="lotus-panel lotus-panel-bud">
            <p class="eyebrow">Lotus</p>
            <h1 id="lotus-bud-title" class="lotus-bloom-title">Open the first bloom.</h1>
            <p id="lotus-bud-copy" class="lotus-bloom-copy">
              One question. One writing surface. Forward is always upward.
            </p>
            <button id="lotus-open-bloom" type="button" class="button-primary lotus-bloom-open">
              Begin ascent
            </button>
          </div>

          <div id="lotus-active-panel" class="lotus-panel lotus-panel-active" hidden>
            <p id="lotus-phase-label" class="eyebrow">Current bloom</p>
            <h1 id="lotus-question-text" class="lotus-bloom-title"></h1>
            <p id="lotus-question-note" class="lotus-bloom-copy lotus-bloom-note"></p>

            <textarea
              id="lotus-bloom-input"
              class="lotus-bloom-input"
              rows="7"
              spellcheck="true"
              autocomplete="off"
              autocapitalize="sentences"
              aria-labelledby="lotus-phase-label lotus-question-text"
              aria-describedby="lotus-word-status lotus-submit-hint"
            ></textarea>

            <div class="lotus-bloom-meta">
              <p id="lotus-word-status" class="lotus-word-status">100 words available</p>
              <p id="lotus-draft-status" class="lotus-draft-status">Drafts save quietly as you write.</p>
            </div>

            <p id="lotus-error-status" class="lotus-error-status" hidden>
              Couldn't save — your words are still here.
            </p>

            <div class="lotus-submit-shell">
              <button id="lotus-submit" type="button" class="button-primary lotus-submit-button" disabled>
                <span id="lotus-submit-label">Prepare bloom closure</span>
                <span id="lotus-submit-progress" class="lotus-submit-progress" aria-hidden="true"></span>
              </button>
              <p id="lotus-submit-hint" class="lotus-submit-hint">
                First prepare, then hold the button to close the bloom.
              </p>
            </div>
          </div>

          <div id="lotus-complete-panel" class="lotus-panel lotus-panel-complete" hidden>
            <p class="eyebrow">Completion</p>
            <h1 class="lotus-bloom-title">The stalk holds all that you carried upward.</h1>
            <p class="lotus-bloom-copy">
              Nothing has been scored. Nothing has been reduced. The path below keeps every closed bloom, and you can
              return through it whenever you need to.
            </p>
            <div class="lotus-complete-actions">
              <button id="lotus-review-answers" type="button" class="button-primary">Review your answers</button>
              <a class="button-secondary" href="/lotus/research/">Open research tools</a>
              <a class="button-secondary" href="/projects/lotus/">Read the project record</a>
            </div>
          </div>
        </div>

        <div class="lotus-stalk-column">
          <div class="lotus-stalk-line" aria-hidden="true"></div>
          <div id="lotus-node-stack" class="lotus-node-stack" aria-label="Completed Lotus blooms"></div>
          <p id="lotus-node-overflow" class="lotus-node-overflow" hidden></p>
        </div>
      </div>
    </div>
  </div>

  <script is:inline type="application/json" id="lotus-bloom-data" set:html={JSON.stringify(appData)}></script>
  <script is:inline>
    const lotusRoot = document.querySelector('[data-lotus-bloom-root]');
    const lotusDataElement = document.getElementById('lotus-bloom-data');

    if (lotusRoot && lotusDataElement) {
      const { questions = [] } = JSON.parse(lotusDataElement.textContent || '{}');
      const STORAGE_KEY = 'lotus-bloom-session-v1';
      const WORD_LIMIT = 100;
      const HOLD_MS = 650;

      const elements = {
        progressLabel: document.getElementById('lotus-progress-label'),
        modeLabel: document.getElementById('lotus-mode-label'),
        navDown: document.getElementById('lotus-nav-down'),
        returnCurrent: document.getElementById('lotus-return-current'),
        trustNote: document.getElementById('lotus-trust-note'),
        budPanel: document.getElementById('lotus-bud-panel'),
        budTitle: document.getElementById('lotus-bud-title'),
        budCopy: document.getElementById('lotus-bud-copy'),
        openBloom: document.getElementById('lotus-open-bloom'),
        activePanel: document.getElementById('lotus-active-panel'),
        phaseLabel: document.getElementById('lotus-phase-label'),
        questionText: document.getElementById('lotus-question-text'),
        questionNote: document.getElementById('lotus-question-note'),
        input: document.getElementById('lotus-bloom-input'),
        wordStatus: document.getElementById('lotus-word-status'),
        draftStatus: document.getElementById('lotus-draft-status'),
        errorStatus: document.getElementById('lotus-error-status'),
        submit: document.getElementById('lotus-submit'),
        submitLabel: document.getElementById('lotus-submit-label'),
        submitHint: document.getElementById('lotus-submit-hint'),
        submitProgress: document.getElementById('lotus-submit-progress'),
        completePanel: document.getElementById('lotus-complete-panel'),
        reviewAnswers: document.getElementById('lotus-review-answers'),
        nodeStack: document.getElementById('lotus-node-stack'),
        nodeOverflow: document.getElementById('lotus-node-overflow'),
      };

      let draftTimer = null;
      let holdTimer = null;
      let holdResetTimer = null;
      let holdTriggered = false;
      let armedTimer = null;
      let viewportResizeHandler = null;

      const defaultState = () => ({
        answers: [],
        currentIndex: 0,
        currentOpen: false,
        forwardDraft: '',
        mode: 'forward',
        reviewIndex: null,
        reviewDraft: '',
        saveState: 'idle',
        completed: false,
        transition: '',
      });

      const countWords = (value) => {
        const matches = (value || '').trim().match(/\S+/g);
        return matches ? matches.length : 0;
      };

      const trimToWordLimit = (value, limit) => {
        const parts = (value || '').match(/\S+\s*/g);
        if (!parts || parts.length <= limit) {
          return value;
        }
        return parts.slice(0, limit).join('').trimEnd();
      };

      const nowIso = () => new Date().toISOString();

      const cloneState = (source) => JSON.parse(JSON.stringify(source));

      const normalizeLoadedState = (source) => {
        const base = defaultState();
        const loaded = source && typeof source === 'object' ? source : {};
        const answers = Array.isArray(loaded.answers)
          ? loaded.answers
              .filter((entry) => entry && typeof entry.questionId === 'string' && typeof entry.answerText === 'string')
              .slice(0, questions.length)
          : [];

        const completed = Boolean(loaded.completed) || answers.length >= questions.length;
        const currentIndex = completed
          ? questions.length - 1
          : Math.min(Number.isInteger(loaded.currentIndex) ? loaded.currentIndex : answers.length, questions.length - 1);

        return {
          ...base,
          answers,
          currentIndex: Math.max(0, currentIndex),
          currentOpen: Boolean(loaded.currentOpen) || Boolean(loaded.forwardDraft),
          forwardDraft: trimToWordLimit(String(loaded.forwardDraft || ''), WORD_LIMIT),
          mode: loaded.mode === 'review' && answers.length ? 'review' : 'forward',
          reviewIndex:
            loaded.mode === 'review' && Number.isInteger(loaded.reviewIndex) && loaded.reviewIndex >= 0
              ? Math.min(loaded.reviewIndex, Math.max(0, answers.length - 1))
              : null,
          reviewDraft: trimToWordLimit(String(loaded.reviewDraft || ''), WORD_LIMIT),
          saveState: 'idle',
          completed,
          transition: '',
        };
      };

      let state = defaultState();

      const readStoredState = () => {
        try {
          const raw = window.localStorage.getItem(STORAGE_KEY);
          if (!raw) {
            return defaultState();
          }
          return normalizeLoadedState(JSON.parse(raw));
        } catch (_error) {
          return defaultState();
        }
      };

      const persistState = () => {
        const payload = cloneState({
          answers: state.answers,
          currentIndex: state.currentIndex,
          currentOpen: state.currentOpen,
          forwardDraft: state.forwardDraft,
          mode: state.mode,
          reviewIndex: state.reviewIndex,
          reviewDraft: state.reviewDraft,
          completed: state.completed,
        });

        try {
          window.localStorage.setItem(STORAGE_KEY, JSON.stringify(payload));
          state.saveState = 'saved';
          window.clearTimeout(holdResetTimer);
          holdResetTimer = window.setTimeout(() => {
            if (state.saveState === 'saved') {
              state.saveState = 'idle';
              render();
            }
          }, 1200);
          return true;
        } catch (_error) {
          state.saveState = 'error';
          return false;
        }
      };

      const scheduleDraftSave = () => {
        window.clearTimeout(draftTimer);
        state.saveState = 'draft-saving';
        draftTimer = window.setTimeout(() => {
          persistState();
          render();
        }, 500);
      };

      const flushPendingDraftSave = () => {
        if (draftTimer === null) {
          return;
        }

        window.clearTimeout(draftTimer);
        draftTimer = null;
        persistState();
      };

      const currentQuestionIndex = () =>
        state.mode === 'review'
          ? Math.max(0, state.reviewIndex ?? 0)
          : Math.min(state.currentIndex, Math.max(0, questions.length - 1));

      const currentQuestion = () => questions[currentQuestionIndex()] || questions[questions.length - 1];

      const currentText = () => (state.mode === 'review' ? state.reviewDraft : state.forwardDraft);

      const setCurrentText = (value) => {
        if (state.mode === 'review') {
          state.reviewDraft = value;
        } else {
          state.forwardDraft = value;
        }
      };

      const currentWordCount = () => countWords(currentText());

      const canSubmit = () => currentWordCount() > 0;

      const setTransition = (nextTransition, callback) => {
        state.transition = nextTransition;
        render();
        window.setTimeout(() => {
          state.transition = '';
          callback();
        }, nextTransition === 'closing' ? 760 : 420);
      };

      const disarmSubmit = () => {
        state.submitArmed = false;
        window.clearTimeout(armedTimer);
      };

      const armSubmit = () => {
        state.submitArmed = true;
        window.clearTimeout(armedTimer);
        armedTimer = window.setTimeout(() => {
          state.submitArmed = false;
          render();
        }, 5000);
      };

      const renderNodes = () => {
        const showFullStalk = state.completed || state.mode === 'review';
        const visibleNodes = (showFullStalk ? state.answers : state.answers.slice(-4)).slice().reverse();
        elements.nodeStack.innerHTML = '';

        visibleNodes.forEach((answer, visibleIndex) => {
          const absoluteIndex = state.answers.findIndex((entry) => entry.questionId === answer.questionId);
          const node = document.createElement('button');
          node.type = 'button';
          node.className = 'lotus-node';
          node.dataset.depth = showFullStalk
            ? String(state.answers.length - absoluteIndex)
            : String(visibleNodes.length - visibleIndex);
          node.dataset.selected = state.mode === 'review' && state.reviewIndex === absoluteIndex ? 'true' : 'false';
          node.setAttribute('aria-label', `Review question ${absoluteIndex + 1}: ${answer.questionText}`);

          const inner = document.createElement('span');
          inner.className = 'lotus-node-core';
          node.appendChild(inner);

          node.addEventListener('click', () => {
            enterReview(absoluteIndex);
          });

          elements.nodeStack.appendChild(node);
        });

        const hiddenCount = Math.max(0, state.answers.length - visibleNodes.length);
        elements.nodeOverflow.hidden = hiddenCount === 0 && !showFullStalk;
        elements.nodeOverflow.textContent = showFullStalk
          ? `Full stalk visible: ${state.answers.length} closed blooms held below.`
          : hiddenCount
            ? `${hiddenCount} more lower on the stalk`
            : '';
      };

      const syncKeyboardOffset = () => {
        if (!window.visualViewport) {
          return;
        }

        const keyboardHeight = Math.max(0, window.innerHeight - window.visualViewport.height - window.visualViewport.offsetTop);
        lotusRoot.style.setProperty('--lotus-keyboard-offset', `${keyboardHeight}px`);
      };

      const ensureFocusedBloomVisible = () => {
        syncKeyboardOffset();
        if (!state.currentOpen && state.mode !== 'review') {
          return;
        }

        window.requestAnimationFrame(() => {
          elements.activePanel.scrollIntoView({
            block: 'center',
            inline: 'nearest',
            behavior: window.matchMedia('(prefers-reduced-motion: reduce)').matches ? 'auto' : 'smooth',
          });
        });
      };

      const renderBudCopy = () => {
        if (state.completed) {
          elements.budTitle.textContent = 'All blooms are closed.';
          elements.budCopy.textContent = 'You can review the stalk below whenever you want to return.';
          elements.openBloom.textContent = 'Review the last bloom';
          return;
        }

        if (!state.answers.length && !state.forwardDraft) {
          elements.budTitle.textContent = 'Open the first bloom.';
          elements.budCopy.textContent = 'One question. One writing surface. Forward is always upward.';
          elements.openBloom.textContent = 'Begin ascent';
          return;
        }

        if (state.forwardDraft) {
          elements.budTitle.textContent = 'Your current bloom is waiting.';
          elements.budCopy.textContent = 'The stalk remembers where you paused. Reopen the bloom when you are ready.';
          elements.openBloom.textContent = 'Reopen current bloom';
          return;
        }

        elements.budTitle.textContent = 'Pause before the next bloom.';
        elements.budCopy.textContent = 'The last answer has settled into the stalk. Open the next bloom when you are ready.';
        elements.openBloom.textContent = 'Open next bloom';
      };

      const renderActivePanel = () => {
        const question = currentQuestion();
        const wordCount = currentWordCount();
        const remaining = WORD_LIMIT - wordCount;
        const reviewMode = state.mode === 'review';

        elements.phaseLabel.textContent = reviewMode ? 'Reviewing bloom' : 'Current bloom';
        elements.questionText.textContent = question.prompt;
        elements.questionNote.textContent = question.note;

        if (elements.input.value !== currentText()) {
          elements.input.value = currentText();
        }

        if (wordCount >= WORD_LIMIT) {
          elements.wordStatus.textContent = 'Full';
        } else if (wordCount >= 80) {
          elements.wordStatus.textContent = `${remaining} words remaining`;
        } else {
          elements.wordStatus.textContent = `${remaining} remaining`;
        }

        if (reviewMode) {
          elements.draftStatus.textContent = 'Review mode keeps your current forward bloom intact above.';
        } else if (state.saveState === 'draft-saving') {
          elements.draftStatus.textContent = 'Draft saving locally...';
        } else if (state.saveState === 'saved') {
          elements.draftStatus.textContent = 'Draft saved locally.';
        } else {
          elements.draftStatus.textContent = 'Drafts save quietly as you write.';
        }

        const submitReady = canSubmit();
        elements.submit.disabled = !submitReady;
        elements.submit.dataset.armed = state.submitArmed ? 'true' : 'false';
        elements.submitLabel.textContent = state.submitArmed
          ? reviewMode
            ? 'Hold to seal revision'
            : 'Hold to close bloom'
          : reviewMode
            ? 'Prepare revision'
            : 'Prepare bloom closure';
        elements.submitHint.textContent = submitReady
          ? state.submitArmed
            ? 'Hold the button for a beat. Accidental submission is blocked by design.'
            : 'First prepare, then hold the button to close the bloom.'
          : 'Write at least one word before preparing the bloom closure.';
      };

      const render = () => {
        const reviewMode = state.mode === 'review';
        const showActive = reviewMode || state.currentOpen;
        const bloomState = state.transition
          ? state.transition
          : state.completed
            ? 'complete'
            : reviewMode
              ? 'review'
              : showActive
                ? currentWordCount() >= 80
                  ? 'near-limit'
                  : 'active'
                : 'bud';

        lotusRoot.dataset.mode = state.mode;
        lotusRoot.dataset.bloomState = bloomState;
        lotusRoot.dataset.saveState = state.saveState;

        const currentPositionLabel = state.completed
          ? `All ${questions.length} blooms closed`
          : reviewMode
            ? `Reviewing question ${currentQuestionIndex() + 1} of ${questions.length}`
            : showActive
              ? `Question ${currentQuestionIndex() + 1} of ${questions.length}`
              : `${state.answers.length} of ${questions.length} blooms closed`;

        elements.progressLabel.textContent = currentPositionLabel;
        elements.modeLabel.textContent = reviewMode
          ? 'Review mode'
          : state.completed
            ? 'Completion'
            : showActive
              ? 'Forward flow'
              : state.answers.length
                ? 'Pause before ascent'
                : 'Begin when ready';

        elements.navDown.disabled = state.answers.length === 0;
        elements.navDown.textContent = reviewMode ? 'Go further down' : 'Back down';
        elements.returnCurrent.hidden = !reviewMode;

        elements.budPanel.hidden = showActive || state.completed;
        elements.activePanel.hidden = !showActive;
        elements.completePanel.hidden = !state.completed;
        elements.errorStatus.hidden = state.saveState !== 'error';

        renderBudCopy();
        renderNodes();

        if (showActive) {
          renderActivePanel();
        }
      };

      const startCurrentBloom = () => {
        state.mode = 'forward';
        state.reviewIndex = null;
        state.reviewDraft = '';
        state.currentOpen = true;
        disarmSubmit();
        setTransition('opening', () => {
          render();
          elements.input.focus();
          elements.input.setSelectionRange(elements.input.value.length, elements.input.value.length);
          ensureFocusedBloomVisible();
        });
      };

      const enterReview = (index) => {
        if (index < 0 || index >= state.answers.length) {
          return;
        }

        state.mode = 'review';
        state.reviewIndex = index;
        state.reviewDraft = state.answers[index].answerText || '';
        disarmSubmit();
        setTransition('review', () => {
          render();
          elements.input.focus();
          elements.input.setSelectionRange(elements.input.value.length, elements.input.value.length);
          ensureFocusedBloomVisible();
        });
      };

      const returnToCurrent = () => {
        state.mode = 'forward';
        state.reviewIndex = null;
        state.reviewDraft = '';
        disarmSubmit();
        if (state.currentOpen && !state.completed) {
          setTransition('opening', () => {
            render();
            elements.input.focus();
            elements.input.setSelectionRange(elements.input.value.length, elements.input.value.length);
            ensureFocusedBloomVisible();
          });
        } else {
          render();
        }
      };

      const resetHold = () => {
        window.clearTimeout(holdTimer);
        holdTimer = null;
        holdTriggered = false;
        elements.submit.dataset.holding = 'false';
      };

      const finalizeReviewSubmission = () => {
        const previousState = cloneState(state);
        const reviewIndex = state.reviewIndex;
        if (reviewIndex === null || reviewIndex < 0 || reviewIndex >= state.answers.length) {
          return;
        }

        const answerText = currentText().trim();
        state.answers[reviewIndex] = {
          ...state.answers[reviewIndex],
          answerText,
          submittedAt: nowIso(),
        };
        state.mode = 'forward';
        state.reviewIndex = null;
        state.reviewDraft = '';
        disarmSubmit();
        state.saveState = 'idle';

        setTransition('closing', () => {
          const saved = persistState();
          if (!saved) {
            state = previousState;
            state.mode = 'review';
            state.reviewIndex = reviewIndex;
            state.reviewDraft = answerText;
            state.currentOpen = true;
          }
          render();
        });
      };

      const finalizeForwardSubmission = () => {
        const previousState = cloneState(state);
        const questionIndex = currentQuestionIndex();
        const question = currentQuestion();
        const answerText = currentText().trim();

        state.answers = [
          ...state.answers.slice(0, questionIndex),
          {
            id: `${question.id}-${Date.now()}`,
            questionId: question.id,
            questionText: question.prompt,
            answerText,
            submittedAt: nowIso(),
          },
          ...state.answers.slice(questionIndex + 1),
        ];

        state.forwardDraft = '';
        state.currentIndex = Math.min(questionIndex + 1, Math.max(0, questions.length - 1));
        state.completed = state.answers.length >= questions.length;
        state.currentOpen = false;
        disarmSubmit();
        state.saveState = 'idle';

        setTransition('closing', () => {
          const saved = persistState();
          if (!saved) {
            state = previousState;
            state.currentOpen = true;
          }
          render();
        });
      };

      const submitActiveBloom = () => {
        if (!canSubmit()) {
          return;
        }

        if (state.mode === 'review') {
          finalizeReviewSubmission();
          return;
        }

        finalizeForwardSubmission();
      };

      const beginHold = () => {
        if (!state.submitArmed || !canSubmit()) {
          return;
        }
        window.clearTimeout(holdTimer);
        holdTriggered = false;
        elements.submit.dataset.holding = 'true';
        holdTimer = window.setTimeout(() => {
          holdTriggered = true;
          submitActiveBloom();
          resetHold();
        }, HOLD_MS);
      };

      const handleInputChange = () => {
        const previousValue = currentText();
        const rawValue = elements.input.value;
        let nextValue = trimToWordLimit(rawValue, WORD_LIMIT);

        if (countWords(previousValue) >= WORD_LIMIT && rawValue.length > previousValue.length) {
          nextValue = previousValue;
        }

        if (nextValue !== elements.input.value) {
          elements.input.value = nextValue;
        }

        setCurrentText(nextValue);
        disarmSubmit();

        if (state.mode === 'forward') {
          scheduleDraftSave();
        }

        render();
      };

      elements.openBloom.addEventListener('click', () => {
        if (state.completed) {
          enterReview(Math.max(0, state.answers.length - 1));
          return;
        }
        startCurrentBloom();
      });

      elements.navDown.addEventListener('click', () => {
        if (!state.answers.length) {
          return;
        }
        if (state.mode === 'review') {
          enterReview(Math.max(0, (state.reviewIndex ?? 0) - 1));
          return;
        }
        enterReview(state.answers.length - 1);
      });

      elements.returnCurrent.addEventListener('click', returnToCurrent);
      elements.reviewAnswers.addEventListener('click', () => {
        enterReview(Math.max(0, state.answers.length - 1));
      });

      elements.input.addEventListener('input', handleInputChange);
      elements.input.addEventListener('focus', ensureFocusedBloomVisible);
      elements.input.addEventListener('blur', () => {
        lotusRoot.style.setProperty('--lotus-keyboard-offset', '0px');
      });

      elements.submit.addEventListener('click', () => {
        if (!canSubmit()) {
          return;
        }
        if (!state.submitArmed) {
          armSubmit();
          render();
        }
      });

      ['pointerdown', 'mousedown'].forEach((eventName) => {
        elements.submit.addEventListener(eventName, () => {
          beginHold();
        });
      });

      ['pointerup', 'pointerleave', 'pointercancel', 'mouseup', 'mouseleave'].forEach((eventName) => {
        elements.submit.addEventListener(eventName, () => {
          resetHold();
        });
      });

      elements.submit.addEventListener('keydown', (event) => {
        if ((event.key === 'Enter' || event.key === ' ') && state.submitArmed) {
          event.preventDefault();
          beginHold();
        }
      });

      elements.submit.addEventListener('keyup', (event) => {
        if (event.key === 'Enter' || event.key === ' ') {
          resetHold();
        }
      });

      const handlePageHide = () => {
        flushPendingDraftSave();
      };

      state = readStoredState();
      render();
      syncKeyboardOffset();

      window.addEventListener('pagehide', handlePageHide);
      window.addEventListener('beforeunload', handlePageHide);
      document.addEventListener('visibilitychange', () => {
        if (document.visibilityState === 'hidden') {
          handlePageHide();
        }
      });

      if (window.visualViewport) {
        viewportResizeHandler = () => {
          syncKeyboardOffset();
          if (document.activeElement === elements.input) {
            ensureFocusedBloomVisible();
          }
        };
        window.visualViewport.addEventListener('resize', viewportResizeHandler);
      }

      if (state.currentOpen && !state.completed && state.mode === 'forward') {
        lotusRoot.dataset.bloomState = 'opening';
        window.setTimeout(() => {
          lotusRoot.dataset.bloomState = currentWordCount() >= 80 ? 'near-limit' : 'active';
          render();
          ensureFocusedBloomVisible();
        }, 320);
      }
    }
