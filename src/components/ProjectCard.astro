---
import type { CollectionEntry } from 'astro:content';
import { clampText, contentSlug } from '../lib/content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const slug = contentSlug(project.id);
const standaloneProjectRoute = {
  echo: '/echo/',
  astral: '/gaia/',
  lotus: '/lotus/',
  'dr-sort': '/dr-sort/',
  scriptorium: '/scripto/',
  'skill-ecosystem': '/hephaistos/',
}[slug];
const opensInNewWindow = Boolean(standaloneProjectRoute);
const projectHref = standaloneProjectRoute ?? `/projects/${slug}/`;
const projectCta = {
  echo: 'Open ECHO',
  astral: 'Open GAIA',
  'dr-sort': 'Open Dr.Sort',
  lotus: 'Open LOTUS',
  scriptorium: 'Open SCRIPTO',
  'skill-ecosystem': 'Open Hephaistos',
}[slug] ?? 'View project';
const motifClass =
  {
    'breath-of-the-astral-year': 'project-motif-orbit',
    lotus: 'project-motif-recursion',
    scriptorium: 'project-motif-seal',
    'the-witches-road': 'project-motif-road',
    'the-sealed-card-protocol': 'project-motif-seal',
    'the-violet-gem': 'project-motif-gem',
    recurso: 'project-motif-recursion',
  }[slug] ?? 'project-motif-default';
const summary = clampText(project.data.description, 190);
---

<article data-filter-item data-tags={project.data.tags.join('|').toLowerCase()} data-search={`${project.data.title} ${project.data.subtitle} ${project.data.description} ${project.data.role} ${project.data.tags.join(' ')}`.toLowerCase()}>
  <a
    class="group card-link"
    href={projectHref}
    target={opensInNewWindow ? '_blank' : undefined}
    rel={opensInNewWindow ? 'noopener noreferrer' : undefined}
  >
    <div class="overflow-hidden border-b border-[rgba(36,27,23,0.1)]">
      <div class:list={['aspect-[16/8] p-5 project-motif-shell', motifClass]}>
        <div class="flex h-full flex-col justify-between">
          <p class="eyebrow">{project.data.status}</p>
          {project.data.year && <p class="text-sm uppercase tracking-[0.14em] text-slate-400">{project.data.year}</p>}
        </div>
      </div>
    </div>
    <div class="space-y-2">
      <h3 class="text-[1.06rem] leading-tight md:text-[1.28rem]">{project.data.title}</h3>
      <p class="text-sm text-slate-200">{project.data.subtitle}</p>
    </div>
    <p class="project-card-role">{project.data.role}</p>
    <p class="project-card-summary max-w-[58ch]">{summary}</p>
    <span class="mt-auto text-sm font-semibold text-accent group-hover:text-moon">
      {projectCta}
    </span>
  </a>
</article>
