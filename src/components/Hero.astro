---
import { heroFacts } from '../data/site';
import BackgroundTreatment from './BackgroundTreatment.astro';
---

<section class="relative overflow-hidden border-b border-[rgba(17,23,38,0.08)]">
  <BackgroundTreatment variant="hero" />
  <div class="section-shell relative grid gap-8 lg:grid-cols-[minmax(0,1.1fr)_22rem] lg:items-start">
    <div class="hero-copy-panel max-w-4xl">
      <p class="eyebrow">Martin Lepage</p>
      <h1 class="mt-5 max-w-3xl text-[2.1rem] leading-[0.96] md:text-[3.25rem]">
        AI governance strategy, public writing, and a selective archive.
      </h1>
      <p class="mt-6 max-w-3xl text-[1.08rem] leading-8 text-slate-100">
        Martin Lepage builds governance documents, review structures, and explanatory writing for AI-related work,
        with a sustained focus on legitimacy, documentation, and public intelligibility.
      </p>
      <p class="mt-5 max-w-3xl text-base text-slate-200">
        The site brings governance practice, publications, talks, writing, and direct contact into one readable public
        record.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a class="button-primary" href="/governance/">Explore governance work</a>
        <a class="button-secondary" href="/resume/">View resume and CV</a>
      </div>
      <ul class="bullet-links mt-6">
        <li><a class="link-inline" href="/contact/">Get in touch</a></li>
        <li><a class="link-inline" href="/papers/">Browse publications</a></li>
      </ul>
      <ul class="bullet-facts mt-8">
        {heroFacts.map((fact) => (
          <li>{fact}</li>
        ))}
      </ul>
    </div>

    <aside class="veil-panel space-y-4 lg:mt-10">
      <div>
        <p class="eyebrow">Start here</p>
        <h2 class="mt-4 text-[1.22rem] md:text-[1.38rem]">Choose the path that matches why you arrived.</h2>
        <p class="mt-4 text-base leading-7 text-slate-200">
          Governance readers usually start with the governance page or contact. The other routes are for publications,
          writing, talks, and first-time orientation.
        </p>
      </div>

      <ul class="space-y-3">
        <li class="border-t border-[rgba(17,23,38,0.08)] pt-3 text-base text-slate-200">Governance and consulting</li>
        <li class="border-t border-[rgba(17,23,38,0.08)] pt-3 text-base text-slate-200">Academic readers</li>
        <li class="border-t border-[rgba(17,23,38,0.08)] pt-3 text-base text-slate-200">Editors, media, and speaking organizers</li>
        <li class="border-t border-[rgba(17,23,38,0.08)] pt-3 text-base text-slate-200">General readers and first-time visitors</li>
      </ul>
    </aside>
  </div>
</section>
