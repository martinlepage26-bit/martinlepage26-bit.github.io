---
import { heroFacts } from '../data/site';
import BackgroundTreatment from './BackgroundTreatment.astro';
---

<section class="relative overflow-hidden border-b border-[rgba(17,23,38,0.08)]">
  <BackgroundTreatment variant="hero" />
  <div class="section-shell relative grid gap-8 lg:grid-cols-[minmax(0,1.1fr)_22rem] lg:items-start">
    <div class="hero-copy-panel max-w-4xl">
      <p class="eyebrow">Martin Lepage</p>
      <h1 class="mt-5 max-w-3xl text-[2.1rem] leading-[1.02] md:text-[3.25rem]">
        AI governance, institutional analysis, and public writing.
      </h1>
      <p class="mt-6 max-w-3xl text-[1.08rem] leading-8 text-slate-100">
        Martin Lepage designs governance frameworks, evidence pathways, and strategic writing that clarify how
        decisions are made, which assumptions govern them, and where consequences land.
      </p>
      <p class="mt-5 max-w-3xl text-base text-slate-200">
        The method combines operational rigor with cultural and philosophical reading so systems remain inspectable,
        contestable, and usable under real institutional pressure.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a class="button-primary" href="/governance/">Review governance work</a>
        <a class="button-secondary" href="/resume/">View resume and CV</a>
      </div>
      <ul class="bullet-links mt-6">
        <li><a class="link-inline" href="/contact/">Start a conversation</a></li>
        <li><a class="link-inline" href="/papers/">Read publications</a></li>
      </ul>
      <ul class="bullet-facts mt-8">
        {heroFacts.map((fact) => (
          <li>{fact}</li>
        ))}
      </ul>
    </div>

    <aside class="veil-panel space-y-4 lg:mt-10">
      <div>
        <p class="eyebrow">Start here</p>
        <h2 class="mt-4 text-[1.22rem] md:text-[1.38rem]">Choose a route by decision need.</h2>
        <p class="mt-4 text-base leading-7 text-slate-200">
          Each path is organized for a different reader: governance partners, researchers, editors, speaking
          organizers, and first-time visitors.
        </p>
      </div>

      <ul class="space-y-3">
        <li class="border-t border-[rgba(17,23,38,0.08)] pt-3 text-base text-slate-200">Governance engagements</li>
        <li class="border-t border-[rgba(17,23,38,0.08)] pt-3 text-base text-slate-200">Research and publications</li>
        <li class="border-t border-[rgba(17,23,38,0.08)] pt-3 text-base text-slate-200">Writing and media</li>
        <li class="border-t border-[rgba(17,23,38,0.08)] pt-3 text-base text-slate-200">Talks and first orientation</li>
      </ul>
    </aside>
  </div>
</section>
