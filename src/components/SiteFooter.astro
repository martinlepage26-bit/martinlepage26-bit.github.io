---
import { navigation, siteMeta } from '../data/site';
---

<footer class="site-footer border-t border-[rgba(35,27,53,0.12)]">
  <div class="section-shell grid gap-12 lg:grid-cols-[minmax(0,1fr)_420px]">
    <div class="space-y-5">
      <p class="eyebrow">Martin Lepage</p>
      <h2 class="max-w-xl text-[1.44rem] md:text-[1.7rem]">
        Governance, scholarship, and authorship made clear.
      </h2>
      <p class="max-w-2xl text-base text-slate-200">
        A compact Astro site for publications, projects, essays, and public-facing work.
      </p>
      <ul class="bullet-links">
        <li><a class="link-inline" href="/contact/">Get in touch</a></li>
        {siteMeta.siteUrl && <li><a class="link-inline" href="/rss.xml">RSS feed</a></li>}
      </ul>
    </div>

    <div class="grid gap-8 sm:grid-cols-2">
      <div>
        <h3 class="font-mono text-sm font-semibold uppercase tracking-[0.24em] text-accent">Navigate</h3>
        <ul class="mt-4 space-y-3">
          {navigation.map(({ href, label }) => (
            <li>
              <a class="text-sm text-slate-200 hover:text-accent" href={href}>
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="font-mono text-sm font-semibold uppercase tracking-[0.24em] text-accent">Elsewhere</h3>
        <ul class="mt-4 space-y-3 text-sm">
          <li><a class="text-slate-200 hover:text-accent" href={`mailto:${siteMeta.email}`}>{siteMeta.email}</a></li>
          <li><a class="text-slate-200 hover:text-accent" href={siteMeta.linkedIn}>LinkedIn</a></li>
          <li><a class="text-slate-200 hover:text-accent" href={siteMeta.github}>GitHub</a></li>
          <li><a class="text-slate-200 hover:text-accent" href={siteMeta.orcid}>ORCID</a></li>
          <li><a class="text-slate-200 hover:text-accent" href={siteMeta.substack}>HEXA</a></li>
          <li><a class="text-slate-200 hover:text-accent" href={siteMeta.instagram}>Instagram</a></li>
        </ul>
      </div>
    </div>
  </div>

  <div class="shell flex flex-col gap-3 border-t border-[rgba(35,27,53,0.12)] py-5 text-sm text-slate-300 md:flex-row md:items-center md:justify-between">
    <p>&copy; {new Date().getFullYear()} Martin Lepage. Montreal-based scholar, writer, and AI governance strategist.</p>
    <p>Streamlined layout, restrained motion, content-first architecture.</p>
  </div>
</footer>
