---
interface Props {
  variant?: 'hero' | 'section' | 'panel';
  className?: string;
}

const { variant = 'section', className = '' } = Astro.props;
const showEye = variant === 'hero';
---

<div aria-hidden="true" class:list={['pointer-events-none absolute inset-0 overflow-hidden', className]}>
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_14%_18%,rgba(127,83,178,0.18),transparent_30%),radial-gradient(circle_at_84%_12%,rgba(92,110,198,0.14),transparent_24%),linear-gradient(180deg,rgba(255,255,255,0.34),rgba(255,255,255,0)_62%,transparent)]"></div>
  <div class="absolute inset-y-0 left-[9%] hidden w-px bg-gradient-to-b from-transparent via-[rgba(35,27,53,0.12)] to-transparent lg:block"></div>
  <div class="absolute inset-y-0 right-[11%] hidden w-px bg-gradient-to-b from-transparent via-[rgba(35,27,53,0.08)] to-transparent xl:block"></div>
  <div class="absolute left-[10%] right-[10%] top-[26%] h-px bg-gradient-to-r from-transparent via-[rgba(127,83,178,0.24)] to-transparent"></div>
  <div class="absolute left-[16%] right-[18%] top-[58%] h-px bg-gradient-to-r from-transparent via-[rgba(92,110,198,0.2)] to-transparent"></div>
  <div class="absolute right-[4%] top-[6%] h-[16rem] w-[16rem] rounded-full bg-[radial-gradient(circle,rgba(92,110,198,0.14),rgba(92,110,198,0.03),transparent_68%)] blur-3xl"></div>
  <div class="absolute bottom-[-6%] left-[4%] h-[15rem] w-[15rem] rounded-full bg-[radial-gradient(circle,rgba(127,83,178,0.14),rgba(127,83,178,0.02),transparent_72%)] blur-3xl"></div>
  <img
    src="/assets/isometric-grid-corner.png"
    alt=""
    class="absolute right-0 top-0 hidden w-64 opacity-[0.04] mix-blend-multiply lg:block"
  />
  <img
    src="/assets/geometric-motif-bottomleft.png"
    alt=""
    class="absolute bottom-0 left-0 hidden w-64 opacity-[0.04] mix-blend-multiply lg:block"
  />
  {
    showEye && (
      <div class="absolute right-[2%] top-10 hidden h-[14rem] w-[20rem] border border-[rgba(35,27,53,0.08)] bg-[linear-gradient(180deg,rgba(250,244,251,0.5),rgba(250,244,251,0.08))] xl:block">
        <div class="absolute left-8 right-8 top-10 h-px bg-[rgba(35,27,53,0.12)]"></div>
        <div class="absolute left-8 right-12 top-16 h-px bg-[rgba(35,27,53,0.08)]"></div>
        <div class="absolute left-8 right-10 top-22 h-px bg-[rgba(35,27,53,0.08)]"></div>
        <div class="absolute left-8 right-14 top-28 h-px bg-[rgba(35,27,53,0.06)]"></div>
        <div class="absolute bottom-6 right-8 font-display text-6xl italic text-[rgba(127,83,178,0.14)]">ML</div>
      </div>
    )
  }
</div>
