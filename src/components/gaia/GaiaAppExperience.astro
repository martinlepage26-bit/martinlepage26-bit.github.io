---
import AstralGaialogyApp from '../astral/AstralGaialogyApp.astro';
import { gaialogySigns } from '../../data/astralYear';
---

<!-- GAIA design lock: keep this route as a direct full-bleed app surface unless an explicit redesign is requested. -->
<section id="gaia-tool" class="gaia-app-page" data-gaia-page-lock="full-bleed-app">
  <div class="gaia-app-bleed" data-gaia-page-shell="reference-surface">
    <AstralGaialogyApp signs={gaialogySigns} />
  </div>
</section>

<style>
  .gaia-app-page {
    padding: 0;
  }

  .gaia-app-bleed {
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
  }
</style>
