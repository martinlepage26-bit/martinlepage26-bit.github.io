---
import { contactAreas, siteMeta } from '../data/site';

interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<section class="veil-panel">
  <div class:list={['grid gap-8', !compact && 'lg:grid-cols-[minmax(0,1fr)_320px]']}>
    <div>
      <p class="eyebrow">Contact</p>
      <h2 class="mt-3 text-[1.46rem] md:text-[1.7rem]">For governance, research, speaking, or editorial work.</h2>
      <p class="mt-4 max-w-2xl text-base text-slate-200">
        Email is the simplest way to reach Martin. Public links below point to the wider writing and research footprint.
      </p>
      <div class="mt-6"><a class="button-primary" href={`mailto:${siteMeta.email}`}>Email Martin</a></div>
    </div>

    <div class="space-y-6">
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-[0.24em] text-accent/80">Direct</h3>
        <ul class="mt-3 space-y-2 text-base text-slate-200">
          <li>{siteMeta.location}</li>
          <li><a href={`mailto:${siteMeta.email}`}>{siteMeta.email}</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold uppercase tracking-[0.24em] text-accent/80">Public channels</h3>
        <ul class="mt-3 space-y-2 text-base text-slate-200">
          <li><a href={siteMeta.linkedIn}>LinkedIn</a></li>
          <li><a href={siteMeta.github}>GitHub</a></li>
          <li><a href={siteMeta.academia}>Academia.edu</a></li>
          <li><a href={siteMeta.orcid}>ORCID</a></li>
          <li><a href={siteMeta.substack}>HEXA</a></li>
          <li><a href={siteMeta.instagram}>Instagram</a></li>
        </ul>
      </div>

      {!compact && (
        <div>
          <h3 class="text-sm font-semibold uppercase tracking-[0.24em] text-accent/80">Best fits</h3>
          <ul class="mt-3 ml-5 list-disc space-y-2 text-base text-slate-200">
            {contactAreas.map((area) => (
              <li>{area}</li>
            ))}
          </ul>
        </div>
      )}
    </div>
  </div>
</section>
