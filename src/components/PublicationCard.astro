---
import type { CollectionEntry } from 'astro:content';
import { clampText, contentSlug } from '../lib/content';

interface Props {
  paper: CollectionEntry<'papers'>;
}

const { paper } = Astro.props;
---

<article data-filter-item data-tags={paper.data.tags.join('|').toLowerCase()} data-search={`${paper.data.title} ${paper.data.venue} ${paper.data.abstract} ${paper.data.tags.join(' ')}`.toLowerCase()}>
  <a class="group card-link" href={`/papers/${contentSlug(paper.id)}/`}>
    <div class="flex items-start justify-between gap-4">
      <div>
        <p class="eyebrow">{paper.data.type}</p>
        <h3 class="mt-3 text-[1rem] leading-tight md:text-[1.22rem]">{paper.data.title}</h3>
      </div>
      <span class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-400">
        {paper.data.year}
      </span>
    </div>

    <p class="text-sm uppercase tracking-[0.14em] text-slate-400">
      {paper.data.venue} · {paper.data.status}
    </p>
    <p class="max-w-[58ch] text-base text-slate-200">{clampText(paper.data.abstract, 240)}</p>
    <span class="mt-auto text-sm font-semibold text-accent group-hover:text-moon">
      View record
    </span>
  </a>
</article>
