---
import type { CollectionEntry } from 'astro:content';
import { clampText, contentSlug, isPublishedPaper } from '../lib/content';

interface Props {
  paper: CollectionEntry<'papers'>;
}

const { paper } = Astro.props;
const href = isPublishedPaper(paper) ? `/papers/${contentSlug(paper.id)}/` : `/projects/${contentSlug(paper.id)}/`;
const summary = clampText(paper.data.abstract, 190);
---

<article data-filter-item data-tags={paper.data.tags.join('|').toLowerCase()} data-search={`${paper.data.title} ${paper.data.venue} ${paper.data.abstract} ${paper.data.tags.join(' ')}`.toLowerCase()}>
  <a class="group card-link publication-card" href={href}>
    <div class="flex items-start justify-between gap-4">
      <div>
        <p class="eyebrow">{paper.data.type}</p>
        <h3 class="publication-card-title mt-3 text-[1rem] leading-tight md:text-[1.22rem]">{paper.data.title}</h3>
      </div>
      {paper.data.year && (
        <span class="publication-card-year text-[0.74rem] font-semibold uppercase tracking-[0.12em] text-slate-300">
          {paper.data.year}
        </span>
      )}
    </div>

    <div class="publication-card-meta">
      <p class="publication-card-venue">{paper.data.venue}</p>
      <p class="publication-card-status">{paper.data.status}</p>
    </div>
    <p class="publication-card-summary max-w-[58ch]">{summary}</p>
    <span class="publication-card-cta mt-auto text-sm font-semibold text-accent group-hover:text-moon">Open record</span>
  </a>
</article>
