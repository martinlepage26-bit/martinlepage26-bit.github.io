---
import BackgroundTreatment from './BackgroundTreatment.astro';
import TagList from './TagList.astro';

interface LinkItem {
  label: string;
  url: string;
}

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  meta: string;
  backHref: string;
  backLabel: string;
  tags?: string[];
  links?: LinkItem[];
}

const { eyebrow, title, description, meta, backHref, backLabel, tags = [], links = [] } = Astro.props;
const standaloneRoutes = new Set([
  '/echo/',
  '/gaia/',
  '/gaia/app/',
  '/gaia/glossary/',
  '/gaia/book/',
  '/lotus/',
  '/scriptorium/',
  '/hephaistos/',
]);
const opensInNewWindow = (url: string) => standaloneRoutes.has(url) || /^https?:\/\//.test(url);
---

<section class="relative overflow-hidden border-b border-[rgba(255,255,255,0.08)]">
  <BackgroundTreatment variant="panel" />
  <div class="section-shell relative">
    <div class="hero-copy-panel mt-2 max-w-4xl">
      <a class="link-inline inline-flex" href={backHref}>&larr; {backLabel}</a>
      <p class="eyebrow">{eyebrow}</p>
      <h1 class="mt-4 max-w-3xl text-[1.9rem] md:text-[2.2rem]">{title}</h1>
      <p class="mt-4 max-w-[62ch] text-[1.05rem] leading-8 text-slate-100 md:text-[1.12rem]">{description}</p>
      <p class="mt-5 text-[0.84rem] uppercase tracking-[0.1em] text-slate-400">{meta}</p>
      {tags.length > 0 && <div class="mt-6"><TagList tags={tags} /></div>}
      {
        links.length > 0 && (
          <ul class="bullet-links mt-6">
            {links.map((link) => (
              <li>
                <a
                  class="link-inline"
                  href={link.url}
                  target={opensInNewWindow(link.url) ? '_blank' : undefined}
                  rel={opensInNewWindow(link.url) ? 'noopener noreferrer' : undefined}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </div>
</section>
