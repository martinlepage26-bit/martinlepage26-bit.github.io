---
import BackgroundTreatment from './BackgroundTreatment.astro';
import TagList from './TagList.astro';

interface LinkItem {
  label: string;
  url: string;
}

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  meta: string;
  backHref: string;
  backLabel: string;
  tags?: string[];
  links?: LinkItem[];
}

const { eyebrow, title, description, meta, backHref, backLabel, tags = [], links = [] } = Astro.props;
---

<section class="relative overflow-hidden border-b border-[rgba(36,27,23,0.12)]">
  <BackgroundTreatment variant="panel" />
  <div class="section-shell relative">
    <a class="link-inline" href={backHref}>&larr; {backLabel}</a>
    <div class="mt-5 max-w-3xl">
      <p class="eyebrow">{eyebrow}</p>
      <h1 class="mt-4 max-w-3xl text-[1.74rem] leading-tight md:text-[2rem]">{title}</h1>
      <p class="mt-4 max-w-2xl text-base leading-7 text-slate-100">{description}</p>
      <p class="mt-5 text-sm uppercase tracking-[0.14em] text-slate-400">{meta}</p>
      {tags.length > 0 && <div class="mt-6"><TagList tags={tags} /></div>}
      {
        links.length > 0 && (
          <ul class="bullet-links mt-6">
            {links.map((link) => (
              <li><a class="link-inline" href={link.url}>{link.label}</a></li>
            ))}
          </ul>
        )
      }
    </div>
  </div>
</section>
