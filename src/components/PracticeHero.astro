---
import BackgroundTreatment from './BackgroundTreatment.astro';

interface LinkItem {
  label: string;
  url: string;
  variant?: 'primary' | 'secondary' | 'inline';
}

interface StatItem {
  eyebrow: string;
  value: string | number;
  label: string;
  description: string;
}

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  details?: string;
  links?: LinkItem[];
  stats?: StatItem[];
  sideEyebrow?: string;
  sideTitle?: string;
  sideDescription?: string;
  sidePoints?: string[];
}

const {
  eyebrow,
  title,
  description,
  details = '',
  links = [],
  stats = [],
  sideEyebrow = 'Practice map',
  sideTitle = '',
  sideDescription = '',
  sidePoints = [],
} = Astro.props;

const buttonLinks = links.filter((link) => link.variant !== 'inline');
const inlineLinks = links.filter((link) => link.variant === 'inline');
const stars = [
  { top: '12%', left: '9%', size: '0.42rem', delay: '0s', duration: '7.8s' },
  { top: '18%', left: '22%', size: '0.26rem', delay: '1.4s', duration: '8.4s' },
  { top: '9%', left: '38%', size: '0.34rem', delay: '0.8s', duration: '6.7s' },
  { top: '22%', left: '56%', size: '0.24rem', delay: '2s', duration: '9.2s' },
  { top: '11%', left: '68%', size: '0.44rem', delay: '1.1s', duration: '7.1s' },
  { top: '16%', left: '82%', size: '0.3rem', delay: '2.2s', duration: '8.8s' },
  { top: '30%', left: '14%', size: '0.24rem', delay: '1.7s', duration: '6.9s' },
  { top: '36%', left: '27%', size: '0.5rem', delay: '0.3s', duration: '9.6s' },
  { top: '41%', left: '46%', size: '0.28rem', delay: '2.7s', duration: '8s' },
  { top: '34%', left: '74%', size: '0.22rem', delay: '1.2s', duration: '7.4s' },
  { top: '46%', left: '88%', size: '0.36rem', delay: '2.5s', duration: '8.6s' },
  { top: '8%', left: '16%', size: '0.18rem', delay: '0.5s', duration: '6.4s' },
  { top: '14%', left: '31%', size: '0.2rem', delay: '1.9s', duration: '7.7s' },
  { top: '6%', left: '52%', size: '0.18rem', delay: '0.9s', duration: '8.1s' },
  { top: '20%', left: '63%', size: '0.18rem', delay: '2.6s', duration: '7.2s' },
  { top: '12%', left: '91%', size: '0.2rem', delay: '1.3s', duration: '8.8s' },
  { top: '28%', left: '6%', size: '0.18rem', delay: '2.1s', duration: '7.5s' },
  { top: '32%', left: '39%', size: '0.18rem', delay: '1.1s', duration: '6.8s' },
  { top: '38%', left: '61%', size: '0.18rem', delay: '2.9s', duration: '9.1s' },
  { top: '44%', left: '79%', size: '0.2rem', delay: '0.7s', duration: '7.6s' },
  { top: '55%', left: '11%', size: '0.18rem', delay: '1.8s', duration: '8.2s' },
  { top: '58%', left: '34%', size: '0.22rem', delay: '0.4s', duration: '6.5s' },
  { top: '62%', left: '52%', size: '0.18rem', delay: '2.2s', duration: '8.7s' },
  { top: '67%', left: '71%', size: '0.2rem', delay: '1.5s', duration: '7.1s' },
  { top: '72%', left: '89%', size: '0.18rem', delay: '2.8s', duration: '9.4s' },
  { top: '79%', left: '23%', size: '0.18rem', delay: '1s', duration: '7.3s' },
  { top: '84%', left: '47%', size: '0.22rem', delay: '2.4s', duration: '8.5s' },
];
---

<section class="practice-hero-shell relative overflow-hidden border-b border-[rgba(36,27,23,0.12)]">
  <BackgroundTreatment variant="hero" className="practice-treatment" />
  <div class="practice-starfield" aria-hidden="true">
    {stars.map((star) => (
      <span
        class="practice-star"
        style={`top:${star.top};left:${star.left};width:${star.size};height:${star.size};animation-delay:${star.delay};animation-duration:${star.duration};`}
      />
    ))}
  </div>

  <div class="section-shell relative">
    <div class="grid gap-8 xl:grid-cols-[minmax(0,1.18fr)_minmax(19rem,0.82fr)] xl:items-start">
      <div class="practice-glass-panel">
        <div class="practice-panel-shine" aria-hidden="true"></div>
        <div class="practice-panel-glow" aria-hidden="true"></div>
        <div class="practice-panel-recursion practice-panel-recursion-main" aria-hidden="true">
          <span class="practice-triangle-frame practice-triangle-frame-xl"></span>
          <span class="practice-triangle-frame practice-triangle-frame-lg practice-triangle-frame-flip"></span>
          <span class="practice-triangle-frame practice-triangle-frame-md"></span>
          <span class="practice-triangle-frame practice-triangle-frame-sm practice-triangle-frame-flip"></span>
        </div>
        <p class="eyebrow">{eyebrow}</p>
        <h1 class="mt-5 max-w-4xl text-[2rem] leading-[0.96] md:text-[2.95rem]">{title}</h1>
        <p class="mt-6 max-w-3xl text-[1.08rem] leading-8 text-slate-100">{description}</p>
        {details && <p class="mt-5 max-w-3xl text-base leading-7 text-slate-300">{details}</p>}

        {
          buttonLinks.length > 0 && (
            <div class="mt-8 flex flex-wrap gap-3">
              {buttonLinks.map((link, index) => (
                <a class={index === 0 ? 'button-primary' : 'button-secondary'} href={link.url}>
                  {link.label}
                </a>
              ))}
            </div>
          )
        }

        {
          inlineLinks.length > 0 && (
            <ul class="bullet-links mt-6">
              {inlineLinks.map((link) => (
                <li><a class="link-inline" href={link.url}>{link.label}</a></li>
              ))}
            </ul>
          )
        }
      </div>

      <aside class="practice-side-panel">
        <div class="practice-panel-recursion practice-panel-recursion-side" aria-hidden="true">
          <span class="practice-triangle-frame practice-triangle-frame-xl"></span>
          <span class="practice-triangle-frame practice-triangle-frame-lg practice-triangle-frame-flip"></span>
          <span class="practice-triangle-frame practice-triangle-frame-md"></span>
          <span class="practice-triangle-core"></span>
        </div>
        <p class="eyebrow">{sideEyebrow}</p>
        {sideTitle && <h2 class="mt-4 text-[1.2rem] md:text-[1.38rem]">{sideTitle}</h2>}
        {sideDescription && <p class="mt-4 text-base leading-7 text-slate-200">{sideDescription}</p>}
        {
          sidePoints.length > 0 && (
            <ul class="mt-6 space-y-3">
              {sidePoints.map((point) => (
                <li class="practice-side-point">{point}</li>
              ))}
            </ul>
          )
        }
      </aside>
    </div>

    {
      stats.length > 0 && (
        <div class="mt-8 grid gap-4 md:grid-cols-3">
          {stats.map((stat) => (
            <article class="practice-stat-card">
              <div class="practice-panel-recursion practice-panel-recursion-stat" aria-hidden="true">
                <span class="practice-triangle-frame practice-triangle-frame-lg"></span>
                <span class="practice-triangle-frame practice-triangle-frame-md practice-triangle-frame-flip"></span>
                <span class="practice-triangle-frame practice-triangle-frame-sm"></span>
              </div>
              <p class="eyebrow">{stat.eyebrow}</p>
              <p class="mt-5 font-display text-[1.9rem] leading-none text-moon md:text-[2.2rem]">{stat.value}</p>
              <h2 class="mt-4 text-[1.04rem] md:text-[1.14rem]">{stat.label}</h2>
              <p class="mt-3 text-sm leading-6 text-slate-300">{stat.description}</p>
            </article>
          ))}
        </div>
      )
    }
  </div>

  <style>
    .practice-hero-shell {
      isolation: isolate;
    }

    .practice-starfield {
      position: absolute;
      inset: 0;
      pointer-events: none;
      z-index: 0;
    }

    .practice-star {
      position: absolute;
      background: rgba(18, 24, 39, 0.96);
      box-shadow:
        0 0 0 0.08rem rgba(18, 24, 39, 0.7),
        0 0 1.2rem rgba(18, 24, 39, 0.42);
      animation: practice-twinkle ease-in-out infinite alternate;
      opacity: 0.72;
      clip-path: polygon(50% 0, 64% 36%, 100% 50%, 64% 64%, 50% 100%, 36% 64%, 0 50%, 36% 36%);
      transform: rotate(8deg);
    }

    .practice-glass-panel,
    .practice-side-panel,
    .practice-stat-card {
      --practice-chamfer: 1.2rem;
      position: relative;
      isolation: isolate;
      overflow: hidden;
      border: 1px solid rgba(35, 27, 53, 0.14);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      clip-path: polygon(
        var(--practice-chamfer) 0,
        calc(100% - var(--practice-chamfer)) 0,
        100% var(--practice-chamfer),
        100% calc(100% - var(--practice-chamfer)),
        calc(100% - var(--practice-chamfer)) 100%,
        var(--practice-chamfer) 100%,
        0 calc(100% - var(--practice-chamfer)),
        0 var(--practice-chamfer)
      );
      box-shadow:
        0 28px 80px rgba(17, 23, 38, 0.12),
        inset 0 1px 0 rgba(255, 255, 255, 0.48);
    }

    .practice-glass-panel {
      --practice-chamfer: 1.55rem;
      padding: 1.6rem;
      background:
        linear-gradient(145deg, rgba(255, 255, 255, 0.78), rgba(245, 241, 237, 0.42) 42%, rgba(235, 233, 242, 0.24) 100%),
        repeating-linear-gradient(60deg, rgba(233, 226, 190, 0.08) 0 1px, rgba(233, 226, 190, 0) 1px 3.2rem),
        repeating-linear-gradient(-60deg, rgba(233, 226, 190, 0.08) 0 1px, rgba(233, 226, 190, 0) 1px 3.2rem),
        repeating-linear-gradient(0deg, rgba(233, 226, 190, 0.06) 0 1px, rgba(233, 226, 190, 0) 1px 2.78rem);
    }

    .practice-side-panel {
      --practice-chamfer: 1.25rem;
      padding: 1.4rem;
      background:
        linear-gradient(170deg, rgba(250, 246, 242, 0.76), rgba(243, 239, 247, 0.35) 55%, rgba(232, 241, 239, 0.22) 100%),
        repeating-linear-gradient(60deg, rgba(233, 226, 190, 0.07) 0 1px, rgba(233, 226, 190, 0) 1px 2.7rem),
        repeating-linear-gradient(-60deg, rgba(233, 226, 190, 0.07) 0 1px, rgba(233, 226, 190, 0) 1px 2.7rem),
        repeating-linear-gradient(0deg, rgba(233, 226, 190, 0.05) 0 1px, rgba(233, 226, 190, 0) 1px 2.34rem);
    }

    .practice-stat-card {
      --practice-chamfer: 1rem;
      padding: 1.2rem 1.1rem 1.15rem;
      background:
        linear-gradient(155deg, rgba(255, 255, 255, 0.74), rgba(246, 241, 247, 0.42) 52%, rgba(235, 242, 240, 0.26) 100%),
        repeating-linear-gradient(60deg, rgba(233, 226, 190, 0.06) 0 1px, rgba(233, 226, 190, 0) 1px 2.32rem),
        repeating-linear-gradient(-60deg, rgba(233, 226, 190, 0.06) 0 1px, rgba(233, 226, 190, 0) 1px 2.32rem),
        repeating-linear-gradient(0deg, rgba(233, 226, 190, 0.04) 0 1px, rgba(233, 226, 190, 0) 1px 2rem);
    }

    .practice-glass-panel::before,
    .practice-side-panel::before,
    .practice-stat-card::before,
    .practice-glass-panel::after,
    .practice-side-panel::after,
    .practice-stat-card::after {
      content: "";
      position: absolute;
      pointer-events: none;
    }

    .practice-glass-panel::before,
    .practice-side-panel::before,
    .practice-stat-card::before {
      left: 0.95rem;
      top: 0.9rem;
      width: 3.6rem;
      height: 1px;
      background: linear-gradient(90deg, rgba(17, 23, 38, 0.62), rgba(17, 23, 38, 0));
      opacity: 0.46;
    }

    .practice-glass-panel::after,
    .practice-side-panel::after,
    .practice-stat-card::after {
      right: 0.9rem;
      bottom: 0.9rem;
      width: 2.8rem;
      height: 2.8rem;
      border-right: 1px solid rgba(17, 23, 38, 0.22);
      border-bottom: 1px solid rgba(17, 23, 38, 0.22);
      clip-path: polygon(62% 0, 100% 0, 100% 38%, 38% 100%, 0 100%, 0 62%);
      opacity: 0.5;
    }

    .practice-panel-shine,
    .practice-panel-glow,
    .practice-panel-recursion {
      position: absolute;
      pointer-events: none;
      z-index: 0;
    }

    .practice-glass-panel > :not(.practice-panel-shine):not(.practice-panel-glow):not(.practice-panel-recursion),
    .practice-side-panel > :not(.practice-panel-recursion),
    .practice-stat-card > :not(.practice-panel-recursion) {
      position: relative;
      z-index: 1;
    }

    .practice-panel-shine {
      inset: -18% auto auto -8%;
      width: 70%;
      height: 16rem;
      background:
        linear-gradient(118deg, rgba(22, 28, 44, 0) 0%, rgba(22, 28, 44, 0.34) 32%, rgba(22, 28, 44, 0.1) 46%, rgba(22, 28, 44, 0) 70%);
      transform: rotate(-8deg);
      opacity: 0.78;
    }

    .practice-panel-glow {
      right: -12%;
      top: -14%;
      width: 16rem;
      height: 16rem;
      border-radius: 999px;
      background:
        radial-gradient(circle, rgba(34, 51, 79, 0.18) 0%, rgba(95, 95, 178, 0.14) 36%, rgba(95, 95, 178, 0) 72%);
      opacity: 0.82;
    }

    .practice-panel-recursion {
      filter: drop-shadow(0 0 1.1rem rgba(17, 23, 38, 0.14));
      mix-blend-mode: screen;
    }

    .practice-panel-recursion-main {
      right: -2.1rem;
      top: 0.2rem;
      width: min(56%, 22rem);
      aspect-ratio: 1 / 0.92;
      opacity: 0.9;
    }

    .practice-panel-recursion-side {
      right: 0.8rem;
      top: 0.9rem;
      width: 7.8rem;
      aspect-ratio: 1 / 0.92;
      opacity: 0.92;
    }

    .practice-panel-recursion-stat {
      right: 0.45rem;
      bottom: 0.35rem;
      width: 5.2rem;
      aspect-ratio: 1 / 0.92;
      opacity: 0.72;
    }

    .practice-triangle-frame,
    .practice-triangle-core {
      position: absolute;
      left: 50%;
      top: 50%;
      transform: translate(-50%, -50%);
      clip-path: polygon(50% 0, 0 100%, 100% 100%);
    }

    .practice-triangle-frame {
      border: 1px solid rgba(233, 226, 190, 0.34);
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(233, 226, 190, 0.05) 42%, rgba(17, 23, 38, 0) 100%);
      will-change: transform, opacity;
      animation: practice-triangle-radiate 9.4s ease-out infinite;
    }

    .practice-triangle-frame-flip {
      transform: translate(-50%, -50%) rotate(180deg);
      animation-name: practice-triangle-radiate-flip;
    }

    .practice-triangle-frame-xl {
      width: 100%;
      height: 92%;
      animation-delay: 0s;
    }

    .practice-triangle-frame-lg {
      width: 76%;
      height: 69%;
      animation-delay: -2.1s;
    }

    .practice-triangle-frame-md {
      width: 55%;
      height: 49%;
      animation-delay: -4.2s;
    }

    .practice-triangle-frame-sm {
      width: 35%;
      height: 31%;
      animation-delay: -6.3s;
    }

    .practice-triangle-core {
      width: 0.9rem;
      height: 0.82rem;
      background: rgba(18, 24, 39, 0.86);
      box-shadow: 0 0 1.2rem rgba(18, 24, 39, 0.36);
      animation: practice-triangle-core-pulse 5.8s ease-in-out infinite;
    }

    .practice-side-point {
      position: relative;
      padding-left: 1.1rem;
      font-size: 0.98rem;
      line-height: 1.6;
      color: var(--color-slate-200);
    }

    .practice-side-point::before {
      content: "";
      position: absolute;
      left: 0;
      top: 0.72rem;
      width: 0.36rem;
      height: 0.36rem;
      transform: rotate(45deg);
      background: rgba(17, 23, 38, 0.84);
      box-shadow: 0 0 0.7rem rgba(17, 23, 38, 0.18);
    }

    @keyframes practice-twinkle {
      0% {
        opacity: 0.42;
        transform: scale(0.88);
      }

      100% {
        opacity: 0.96;
        transform: scale(1.12);
      }
    }

    @keyframes practice-triangle-radiate {
      0% {
        opacity: 0.14;
        transform: translate(-50%, -50%) scale(0.82);
      }

      38% {
        opacity: 0.44;
        transform: translate(-50%, -50%) scale(0.98);
      }

      72% {
        opacity: 0.18;
        transform: translate(-50%, -50%) scale(1.12);
      }

      100% {
        opacity: 0.08;
        transform: translate(-50%, -50%) scale(1.22);
      }
    }

    @keyframes practice-triangle-radiate-flip {
      0% {
        opacity: 0.14;
        transform: translate(-50%, -50%) rotate(180deg) scale(0.82);
      }

      38% {
        opacity: 0.44;
        transform: translate(-50%, -50%) rotate(180deg) scale(0.98);
      }

      72% {
        opacity: 0.18;
        transform: translate(-50%, -50%) rotate(180deg) scale(1.12);
      }

      100% {
        opacity: 0.08;
        transform: translate(-50%, -50%) rotate(180deg) scale(1.22);
      }
    }

    @keyframes practice-triangle-core-pulse {
      0%,
      100% {
        opacity: 0.74;
        transform: translate(-50%, -50%) scale(0.86);
      }

      50% {
        opacity: 1;
        transform: translate(-50%, -50%) scale(1.18);
      }
    }

    @media (max-width: 960px) {
      .practice-glass-panel,
      .practice-side-panel {
        padding: 1.2rem;
      }

      .practice-glass-panel {
        --practice-chamfer: 1.15rem;
      }

      .practice-side-panel {
        --practice-chamfer: 1rem;
      }

      .practice-panel-recursion-main {
        right: -1.8rem;
        top: -0.2rem;
        width: min(54%, 14rem);
      }

      .practice-panel-recursion-side {
        width: 5.8rem;
      }

      .practice-panel-recursion-stat {
        width: 4.3rem;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .practice-star,
      .practice-triangle-frame,
      .practice-triangle-core {
        animation: none;
      }
    }
  </style>
</section>
