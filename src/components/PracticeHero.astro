---
import BackgroundTreatment from './BackgroundTreatment.astro';

interface LinkItem {
  label: string;
  url: string;
  variant?: 'primary' | 'secondary' | 'inline';
}

interface StatItem {
  eyebrow: string;
  value: string | number;
  label: string;
  description: string;
}

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  details?: string;
  links?: LinkItem[];
  stats?: StatItem[];
  sideEyebrow?: string;
  sideTitle?: string;
  sideDescription?: string;
  sidePoints?: readonly string[];
}

const {
  eyebrow,
  title,
  description,
  details = '',
  links = [],
  stats = [],
  sideEyebrow = 'Practice map',
  sideTitle = '',
  sideDescription = '',
  sidePoints = [],
} = Astro.props;

const buttonLinks = links.filter((link) => link.variant !== 'inline');
const inlineLinks = links.filter((link) => link.variant === 'inline');
---

<section class="relative overflow-hidden border-b border-[rgba(17,23,38,0.08)]">
  <BackgroundTreatment variant="hero" />

  <div class="section-shell relative">
    <div class="grid gap-8 xl:grid-cols-[minmax(0,1.18fr)_minmax(19rem,0.82fr)] xl:items-start">
      <div class="hero-copy-panel space-y-5">
        <p class="eyebrow">{eyebrow}</p>
        <h1 class="max-w-4xl text-[2rem] leading-[0.96] md:text-[3rem]">{title}</h1>
        <p class="max-w-3xl text-[1.08rem] leading-8 text-slate-100">{description}</p>
        {details && <p class="max-w-3xl text-base leading-7 text-slate-200">{details}</p>}

        {
          buttonLinks.length > 0 && (
            <div class="flex flex-wrap gap-3 pt-2">
              {buttonLinks.map((link, index) => (
                <a class={index === 0 ? 'button-primary' : 'button-secondary'} href={link.url}>
                  {link.label}
                </a>
              ))}
            </div>
          )
        }

        {
          inlineLinks.length > 0 && (
            <ul class="bullet-links pt-1">
              {inlineLinks.map((link) => (
                <li><a class="link-inline" href={link.url}>{link.label}</a></li>
              ))}
            </ul>
          )
        }
      </div>

      <aside class="veil-panel space-y-4">
        <p class="eyebrow">{sideEyebrow}</p>
        {sideTitle && <h2 class="text-[1.2rem] md:text-[1.38rem]">{sideTitle}</h2>}
        {sideDescription && <p class="text-base leading-7 text-slate-200">{sideDescription}</p>}
        {
          sidePoints.length > 0 && (
            <ul class="space-y-3">
              {sidePoints.map((point) => (
                <li class="border-t border-[rgba(17,23,38,0.08)] pt-3 text-base text-slate-200">{point}</li>
              ))}
            </ul>
          )
        }
      </aside>
    </div>

    {
      stats.length > 0 && (
        <div class="mt-10 grid gap-4 md:grid-cols-3">
          {stats.map((stat) => (
            <article class="veil-panel h-full">
              <p class="eyebrow">{stat.eyebrow}</p>
              <p class="mt-5 font-display text-[1.85rem] leading-none text-moon md:text-[2.1rem]">{stat.value}</p>
              <h2 class="mt-4 text-[1.04rem] md:text-[1.14rem]">{stat.label}</h2>
              <p class="mt-3 text-sm leading-6 text-slate-300">{stat.description}</p>
            </article>
          ))}
        </div>
      )
    }
  </div>
</section>
