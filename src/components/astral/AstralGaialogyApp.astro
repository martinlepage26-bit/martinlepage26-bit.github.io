        </div>
        <div class="astral-mini-card">
          <p class="astral-mini-label">Personalization scope</p>
          <p class="mt-2 text-sm leading-6 text-slate-200">
            No natal chart or transit engine yet. This version is sign + season + day rhythm, openly and consistently.
          </p>
        </div>
      </div>

      <div class="astral-link-row mt-8">
        <a class="button-secondary" href="/gaia/book/">Read the book frame</a>
        <a class="button-secondary" href="/gaia/glossary/">Open glossary terms</a>
      </div>
    </section>

    <aside class="veil-panel astral-result-panel" aria-live="polite" aria-atomic="true">
      <div class="astral-result-toolbar">
        <div>
          <p id="astral-result-mode" class="astral-mini-label">General reading</p>
          <p id="astral-result-source" class="mt-2 text-xs uppercase tracking-[0.15em] text-slate-400">
            Stable sign profile
