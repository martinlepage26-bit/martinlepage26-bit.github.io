        <p id="astral-contract-status" class="mt-2 text-sm leading-6 text-slate-200"></p>
        <ul id="astral-contract-factors" class="mt-3 list-disc space-y-2 pl-5 text-sm leading-6 text-slate-300"></ul>
      </article>

      <div class="mt-8 grid gap-4 md:grid-cols-2">
        <article class="astral-reading-card">
          <p id="astral-label-note" class="astral-mini-label">Core orientation</p>
          <p id="astral-result-note" class="mt-2 text-base leading-7 text-slate-200">{initialProfile.keyNote}</p>
        </article>
        <article class="astral-reading-card">
          <p id="astral-label-active" class="astral-mini-label">What is active</p>
