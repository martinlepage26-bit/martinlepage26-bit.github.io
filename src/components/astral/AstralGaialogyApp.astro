---
import type { AstralSign } from '../../data/astralYear';
import { buildAstralGaialogyProfile, determineAstralSign } from '../../data/astralGaialogy';

interface Props {
  signs: AstralSign[];
}

const { signs } = Astro.props;

const monthOptions = [
  { value: 1, label: 'January', days: 31 },
  { value: 2, label: 'February', days: 29 },
  { value: 3, label: 'March', days: 31 },
  { value: 4, label: 'April', days: 30 },
  { value: 5, label: 'May', days: 31 },
  { value: 6, label: 'June', days: 30 },
  { value: 7, label: 'July', days: 31 },
  { value: 8, label: 'August', days: 31 },
  { value: 9, label: 'September', days: 30 },
  { value: 10, label: 'October', days: 31 },
  { value: 11, label: 'November', days: 30 },
  { value: 12, label: 'December', days: 31 },
];

const initialSign = signs[0];
const profilesBySlug = Object.fromEntries(
  signs.map((sign) => [sign.slug, buildAstralGaialogyProfile({ sign: sign.slug })]),
);
const initialProfile = profilesBySlug[initialSign.slug];

const dateLookup = Object.fromEntries(
  monthOptions.flatMap((month) =>
    Array.from({ length: month.days }, (_, index) => index + 1).map((day) => [
      `${month.value}-${day}`,
      determineAstralSign(month.value, day).slug,
    ]),
  ),
);

const appData = {
  profiles: profilesBySlug,
  months: monthOptions,
  dateLookup,
  signOrder: signs.map((sign) => sign.slug),
};
---

<div class="gaia-surface" id="gaia-app-shell" style={`--gaia-sign-color: ${initialProfile.sign.color};`}>
  <div class="gaia-background" aria-hidden="true"></div>

  <header class="gaia-header">
    <p class="gaia-kicker">Breath of the Astral Year</p>
    <h2 class="gaia-wordmark">GAIA</h2>
    <p class="gaia-subtitle">Earth-based reading surface</p>
  </header>

  <main class="gaia-main">
    <div class="gaia-mode-toggle" role="group" aria-label="Reading modes">
      <button id="astral-mode-general" type="button" class="gaia-mode-button" aria-pressed="true">
        General Reading
      </button>
      <button id="astral-mode-daily" type="button" class="gaia-mode-button" aria-pressed="false">
        Daily Horoscope
      </button>
    </div>
    <p id="astral-mode-description" class="gaia-mode-note">
      General reading stays with season, temperament, relation, pressure, and repair.
    </p>

    <section class="gaia-sign-section">
      <p class="gaia-section-label">Select your sign</p>
      <div class="gaia-sign-grid">
        {signs.map((sign) => (
          <button
            type="button"
            class="gaia-sign-button"
            data-gaia-sign
            data-sign={sign.slug}
            aria-pressed={sign.slug === initialSign.slug ? 'true' : 'false'}
            style={`--sign-color: ${sign.color};`}
          >
            <span class="gaia-sign-symbol">{sign.glyph}</span>
            <span class="gaia-sign-name">{sign.name}</span>
          </button>
        ))}
      </div>
    </section>

    <section id="gaia-daily-controls" class="gaia-date-card" hidden>
      <p class="gaia-section-label">Forecast date</p>
      <div class="gaia-date-row">
        <input id="astral-daily-date" type="date" class="gaia-date-input" />
        <button id="astral-daily-resolve-sign" type="button" class="gaia-inline-button">Use sign from date</button>
        <button id="astral-daily-today" type="button" class="gaia-inline-button gaia-inline-button-accent">Today</button>
      </div>
      <p id="astral-daily-mode" class="gaia-helper-text">
        Daily reading combines stable sign pattern with date and weekday modulation.
      </p>
    </section>

    <div class="gaia-hidden-inputs" aria-hidden="true">
      <select id="astral-sign-select">
        {signs.map((sign) => (
          <option value={sign.slug}>{sign.name} · {sign.dateLabel}</option>
        ))}
      </select>
      <select id="astral-daily-sign-select">
        {signs.map((sign) => (
          <option value={sign.slug}>{sign.name} · {sign.dateLabel}</option>
        ))}
      </select>
      <select id="astral-month-select">
        {monthOptions.map((month) => (
          <option value={month.value}>{month.label}</option>
        ))}
      </select>
      <select id="astral-day-select">
        {Array.from({ length: monthOptions[0].days }, (_, index) => index + 1).map((day) => (
          <option value={day}>{day}</option>
        ))}
      </select>
    </div>

    <section class="gaia-preview-card">
      <div class="gaia-preview-header">
        <div class="gaia-preview-glyph" id="gaia-preview-glyph">{initialProfile.sign.glyph}</div>
        <div class="gaia-preview-copy">
          <div class="gaia-preview-title-row">
            <h3 id="gaia-preview-sign" class="gaia-preview-sign">{initialProfile.sign.name}</h3>
            <span id="gaia-preview-element" class="gaia-preview-element">{initialProfile.sign.element}</span>
          </div>
          <p id="gaia-preview-range" class="gaia-preview-range">{initialProfile.sign.dateLabel}</p>
        </div>
      </div>

      <div class="gaia-preview-grid">
        <article>
          <p class="gaia-section-label">Competence</p>
          <p id="gaia-preview-competence" class="gaia-preview-detail">{initialProfile.sign.competence}</p>
        </article>
        <article>
          <p class="gaia-section-label">Civic theme</p>
          <p id="gaia-preview-civic" class="gaia-preview-detail">{initialProfile.sign.civicTheme}</p>
        </article>
        <article>
          <p class="gaia-section-label">Body</p>
          <p id="gaia-preview-body" class="gaia-preview-detail">{initialProfile.sign.bodyRegister}</p>
        </article>
        <article>
          <p class="gaia-section-label">Shadow</p>
          <p id="gaia-preview-shadow" class="gaia-preview-detail">{initialProfile.sign.shadow}</p>
        </article>
      </div>

      <div class="gaia-preview-ritual">
        <p class="gaia-section-label">Ritual</p>
        <p id="gaia-preview-ritual" class="gaia-preview-ritual-text">{initialProfile.sign.ritual}</p>
      </div>
    </section>

    <p id="astral-entry-mode" class="gaia-helper-text">Currently showing the direct sign reading.</p>

    <button id="gaia-generate" type="button" class="gaia-generate-button">
      Generate {initialProfile.sign.name} Reading
    </button>

    <section id="gaia-output" class="gaia-output" hidden>
      <div class="gaia-output-toolbar">
        <div>
          <p id="astral-result-mode" class="gaia-section-label">Direct sign reading</p>
          <p id="astral-result-source" class="gaia-output-source">Stable sign profile</p>
        </div>
        <div class="gaia-output-actions">
          <button id="astral-share" type="button" class="gaia-inline-button">Copy share link</button>
          <button id="astral-reset" type="button" class="gaia-inline-button">Reset</button>
        </div>
      </div>

      <p id="astral-share-status" class="gaia-share-status" aria-live="polite"></p>
      <p id="astral-result-summary" class="gaia-output-summary">{initialProfile.summary}</p>
      <p id="astral-result-message" class="gaia-output-message">{initialProfile.message}</p>

      <div class="gaia-reading-grid">
        <article class="gaia-reading-card">
          <p id="astral-label-note" class="gaia-section-label">Key note</p>
          <p id="astral-result-note" class="gaia-reading-copy">{initialProfile.keyNote}</p>
        </article>
        <article class="gaia-reading-card">
          <p id="astral-label-active" class="gaia-section-label">Season mood</p>
          <p id="astral-result-active" class="gaia-reading-copy">{initialProfile.seasonMood}</p>
        </article>
        <article class="gaia-reading-card">
          <p id="astral-label-body" class="gaia-section-label">Body feeling</p>
          <p id="astral-result-body" class="gaia-reading-copy">{initialProfile.bodyFeeling}</p>
        </article>
        <article class="gaia-reading-card">
          <p id="astral-label-social" class="gaia-section-label">How it moves</p>
          <p id="astral-result-social" class="gaia-reading-copy">{initialProfile.movementPattern}</p>
        </article>
      </div>

      <div class="gaia-reading-split">
        <article class="gaia-reading-card gaia-reading-shadow">
          <p id="astral-label-shadow" class="gaia-section-label">Watch for</p>
          <p id="astral-result-shadow" class="gaia-reading-copy gaia-reading-copy-small">{initialProfile.shadow}</p>
        </article>
        <article class="gaia-reading-card gaia-reading-ritual">
          <p id="astral-label-ritual" class="gaia-section-label">Small ritual</p>
          <p id="astral-result-ritual" class="gaia-reading-copy gaia-reading-copy-ritual">{initialProfile.ritual}</p>
        </article>
      </div>

      <article class="gaia-reading-card gaia-reading-prompt">
        <p id="astral-label-prompt" class="gaia-section-label">Grounding action</p>
        <p id="astral-result-prompt" class="gaia-reading-copy">
          Name one concrete action that practices {initialProfile.keyNote.toLowerCase()} in your real day.
        </p>
      </article>

      <article class="gaia-reading-card gaia-reading-guidance">
        <p id="astral-label-guidance" class="gaia-section-label">Grounded guidance</p>
        <ul id="astral-result-guidance" class="gaia-guidance-list">
          {initialProfile.guidance.map((line) => (
            <li>{line}</li>
          ))}
        </ul>
      </article>

      <details class="gaia-method-details">
        <summary>Method and reading details</summary>

        <div class="gaia-reading-grid gaia-method-grid">
          <article class="gaia-reading-card">
            <p class="gaia-section-label">Stable baseline</p>
            <p id="astral-contract-stable" class="gaia-reading-copy"></p>
          </article>
          <article class="gaia-reading-card">
            <p class="gaia-section-label">Daily modulation</p>
            <p id="astral-contract-daily" class="gaia-reading-copy"></p>
          </article>
        </div>

        <article class="gaia-reading-card">
          <p class="gaia-section-label">Current reading contract</p>
          <p id="astral-contract-status" class="gaia-reading-copy gaia-reading-copy-small"></p>
          <ul id="astral-contract-factors" class="gaia-guidance-list gaia-factors-list"></ul>
        </article>

        <div class="gaia-method-rows">
          <article class="gaia-reading-card">
            <p class="gaia-section-label">Stable sign pattern</p>
            <p id="astral-method-stable" class="gaia-reading-copy gaia-reading-copy-small"></p>
          </article>
          <article class="gaia-reading-card">
            <p class="gaia-section-label">Date modulation</p>
            <p id="astral-method-daily" class="gaia-reading-copy gaia-reading-copy-small"></p>
          </article>
          <article class="gaia-reading-card">
            <p class="gaia-section-label">Input path used</p>
            <p id="astral-method-input" class="gaia-reading-copy gaia-reading-copy-small"></p>
          </article>
        </div>
      </details>
    </section>

    <footer class="gaia-footer">
      <div class="gaia-footer-links">
        <a href="/gaia/book/">Book frame</a>
        <a href="/gaia/glossary/">Glossary</a>
      </div>
      <div class="gaia-footer-meta">
        GAIA · Martin Lepage, PhD ·
        <a href="https://martin.govern-ai.ca/gaia/" target="_blank" rel="noreferrer">martin.govern-ai.ca/gaia</a>
      </div>
      <div class="gaia-footer-note">No natal chart · No transits · Earth-bound sign grammar only</div>
    </footer>
  </main>

  <script is:inline type="application/json" id="astral-app-data" set:html={JSON.stringify(appData)}></script>
  <script is:inline>
    const dataElement = document.getElementById('astral-app-data');

    if (dataElement) {
      const data = JSON.parse(dataElement.textContent || '{}');
      const profiles = data.profiles || {};
      const months = data.months || [];
      const dateLookup = data.dateLookup || {};
      const signOrder = data.signOrder || [];

      const requiredIds = [
        'gaia-app-shell',
        'astral-sign-select',
        'astral-daily-sign-select',
        'astral-month-select',
        'astral-day-select',
        'astral-daily-date',
        'astral-daily-resolve-sign',
        'astral-daily-today',
        'astral-mode-general',
        'astral-mode-daily',
        'astral-mode-description',
        'gaia-daily-controls',
        'gaia-generate',
        'gaia-output',
        'gaia-preview-glyph',
        'gaia-preview-sign',
        'gaia-preview-element',
        'gaia-preview-range',
        'gaia-preview-competence',
        'gaia-preview-civic',
        'gaia-preview-body',
        'gaia-preview-shadow',
        'gaia-preview-ritual',
        'astral-entry-mode',
        'astral-daily-mode',
        'astral-result-mode',
        'astral-result-source',
        'astral-result-summary',
        'astral-result-message',
        'astral-contract-stable',
        'astral-contract-daily',
        'astral-contract-status',
        'astral-contract-factors',
        'astral-result-note',
        'astral-result-active',
        'astral-result-body',
        'astral-result-social',
        'astral-result-shadow',
        'astral-result-ritual',
        'astral-result-prompt',
        'astral-result-guidance',
        'astral-label-note',
        'astral-label-active',
        'astral-label-body',
        'astral-label-social',
        'astral-label-shadow',
        'astral-label-ritual',
        'astral-label-prompt',
        'astral-label-guidance',
        'astral-method-stable',
        'astral-method-daily',
        'astral-method-input',
        'astral-share',
        'astral-reset',
        'astral-share-status',
      ];

      const elements = Object.fromEntries(requiredIds.map((id) => [id, document.getElementById(id)]));
      const missing = requiredIds.filter((id) => !elements[id]);

      if (missing.length > 0) {
        console.warn('[GAIA] Missing expected DOM nodes:', missing.join(', '));
      } else {
        const shell = elements['gaia-app-shell'];
        const signSelect = elements['astral-sign-select'];
        const dailySignSelect = elements['astral-daily-sign-select'];
        const monthSelect = elements['astral-month-select'];
        const daySelect = elements['astral-day-select'];
        const dailyDateInput = elements['astral-daily-date'];
        const dailyResolveSignButton = elements['astral-daily-resolve-sign'];
        const dailyTodayButton = elements['astral-daily-today'];
        const modeGeneralButton = elements['astral-mode-general'];
        const modeDailyButton = elements['astral-mode-daily'];
        const modeDescription = elements['astral-mode-description'];
        const dailyControls = elements['gaia-daily-controls'];
        const generateButton = elements['gaia-generate'];
        const output = elements['gaia-output'];

        const previewGlyph = elements['gaia-preview-glyph'];
        const previewSign = elements['gaia-preview-sign'];
        const previewElement = elements['gaia-preview-element'];
        const previewRange = elements['gaia-preview-range'];
        const previewCompetence = elements['gaia-preview-competence'];
        const previewCivic = elements['gaia-preview-civic'];
        const previewBody = elements['gaia-preview-body'];
        const previewShadow = elements['gaia-preview-shadow'];
        const previewRitual = elements['gaia-preview-ritual'];

        const entryMode = elements['astral-entry-mode'];
        const dailyMode = elements['astral-daily-mode'];
        const modeLabel = elements['astral-result-mode'];
        const sourceLabel = elements['astral-result-source'];
        const summary = elements['astral-result-summary'];
        const message = elements['astral-result-message'];
        const contractStable = elements['astral-contract-stable'];
        const contractDaily = elements['astral-contract-daily'];
        const contractStatus = elements['astral-contract-status'];
        const contractFactors = elements['astral-contract-factors'];
        const note = elements['astral-result-note'];
        const active = elements['astral-result-active'];
        const body = elements['astral-result-body'];
        const social = elements['astral-result-social'];
        const shadow = elements['astral-result-shadow'];
        const ritual = elements['astral-result-ritual'];
        const prompt = elements['astral-result-prompt'];
        const guidance = elements['astral-result-guidance'];
        const labelNote = elements['astral-label-note'];
        const labelActive = elements['astral-label-active'];
        const labelBody = elements['astral-label-body'];
        const labelSocial = elements['astral-label-social'];
        const labelShadow = elements['astral-label-shadow'];
        const labelRitual = elements['astral-label-ritual'];
        const labelPrompt = elements['astral-label-prompt'];
        const labelGuidance = elements['astral-label-guidance'];
        const methodStable = elements['astral-method-stable'];
        const methodDaily = elements['astral-method-daily'];
        const methodInput = elements['astral-method-input'];
        const shareButton = elements['astral-share'];
        const resetButton = elements['astral-reset'];
        const shareStatus = elements['astral-share-status'];
        const signButtons = Array.from(document.querySelectorAll('[data-gaia-sign]'));

        const dayMs = 24 * 60 * 60 * 1000;
        const dailyPulseFrames = [
          'The day opens with ignition pressure.',
          'The day asks for steadier pacing.',
          'The day turns through relational signals.',
          'The day brings inner weather to the surface.',
          'The day rewards practical follow-through.',
          'The day stretches your horizon of meaning.',
          'The day tests boundaries before giving clarity.',
        ];
        const dailyTimingFrames = [
          'Morning favors naming direction before momentum takes over.',
          'Midday favors practical adjustments over declarations.',
          'Late day favors repair and relational follow-through.',
          'Evening favors ritual closure and grounding.',
        ];
        const dailySocialFrames = [
          'Move one exchange from abstract to concrete',
          'Name the hidden agreement before acting',
          'Choose reciprocity over symbolic performance',
          'Protect the pace that keeps trust intact',
          'Keep language precise and accountable',
        ];
        const dailyCautionFrames = [
          'Do not confuse velocity with direction.',
          'Do not over-interpret noise as signal.',
          'Do not let urgency erase tenderness.',
          'Do not perform certainty when repair is needed.',
          'Do not hide in abstraction when action is possible.',
        ];
        const dailyRitualFrames = [
          'Keep the action small, embodied, and repeatable.',
          'Anchor the day in one concrete adjustment.',
          'Favor repair over display in your next move.',
          'Let the body set the pace before the mind speeds up.',
        ];

        const hasSignSlug = (slug) => Object.prototype.hasOwnProperty.call(profiles, slug);
        const firstProfile = profiles[Object.keys(profiles)[0]];
        const signBySlug = (slug) => (hasSignSlug(slug) ? profiles[slug] : firstProfile);
        const validMode = (mode) => mode === 'general' || mode === 'daily';
        const buildUtcDate = (year, month, day) => new Date(Date.UTC(year, month - 1, day));

        const isValidGregorianDate = (year, month, day) => {
          if (!Number.isInteger(year) || !Number.isInteger(month) || !Number.isInteger(day)) {
            return false;
          }

          const date = buildUtcDate(year, month, day);
          return date.getUTCFullYear() === year && date.getUTCMonth() === month - 1 && date.getUTCDate() === day;
        };

        const parseDateInputValue = (value) => {
          const normalized = String(value || '').trim();
          if (!/^\d{4}-\d{2}-\d{2}$/.test(normalized)) {
            return null;
          }

          const [yearText, monthText, dayText] = normalized.split('-');
          const year = Number(yearText);
          const month = Number(monthText);
          const day = Number(dayText);

          if (!isValidGregorianDate(year, month, day)) {
            return null;
          }

          return {
            year,
            month,
            day,
            isoDate: normalized,
            utcDate: buildUtcDate(year, month, day),
          };
        };

        const formatDayLabel = (year, month, day) => {
          if (!isValidGregorianDate(year, month, day)) {
            return `${year}-${month}-${day}`;
          }

          const date = buildUtcDate(year, month, day);
          return new Intl.DateTimeFormat('en-US', {
            timeZone: 'UTC',
            weekday: 'long',
            month: 'long',
            day: 'numeric',
            year: 'numeric',
          }).format(date);
        };

        const weekdayLabel = (weekdayIndex) => {
          const labels = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
          return labels[weekdayIndex] || 'Unknown';
        };

        const toDateInputValue = (date) => {
          const year = date.getFullYear();
          const month = String(date.getMonth() + 1).padStart(2, '0');
          const day = String(date.getDate()).padStart(2, '0');
          return `${year}-${month}-${day}`;
        };

        const daysForGeneralMonth = (month) => months.find((entry) => entry.value === month)?.days || 31;

        const normalizeGeneralMonthDay = (month, day) => {
          const safeMonth = Number.isInteger(month) ? Math.max(1, Math.min(12, month)) : 1;
          const maxDay = daysForGeneralMonth(safeMonth);
          const safeDay = Number.isInteger(day) ? Math.max(1, Math.min(maxDay, day)) : 1;
          return { month: safeMonth, day: safeDay };
        };

        const rebuildDays = (month, currentDay) => {
          const limit = daysForGeneralMonth(month);
          const nextDay = Math.min(currentDay, limit);
          daySelect.innerHTML = '';

          for (let day = 1; day <= limit; day += 1) {
            const option = document.createElement('option');
            option.value = String(day);
            option.textContent = String(day);
            daySelect.appendChild(option);
          }

          daySelect.value = String(nextDay);
        };

        const applyMonthDay = (month, day) => {
          const normalized = normalizeGeneralMonthDay(month, day);
          monthSelect.value = String(normalized.month);
          rebuildDays(normalized.month, normalized.day);
          daySelect.value = String(normalized.day);
          return normalized;
        };

        const resolveSignSlugByMonthDay = (month, day) => dateLookup[`${month}-${day}`];
        const setShareStatus = (text = '') => {
          shareStatus.textContent = text;
        };

        const dayOfYear = (dateParts) => {
          const startStamp = Date.UTC(dateParts.year, 0, 1);
          const currentStamp = Date.UTC(dateParts.year, dateParts.month - 1, dateParts.day);
          return Math.floor((currentStamp - startStamp) / dayMs) + 1;
        };

        const signPhase = (sign, dateParts) => {
          const wrapsYear =
            sign.startMonth > sign.endMonth ||
            (sign.startMonth === sign.endMonth && sign.startDay > sign.endDay);

          const currentStamp = Date.UTC(dateParts.year, dateParts.month - 1, dateParts.day);
          let startYear = dateParts.year;
          let endYear = dateParts.year;

          if (wrapsYear) {
            const startThisYear = Date.UTC(dateParts.year, sign.startMonth - 1, sign.startDay);
            if (currentStamp < startThisYear) {
              startYear = dateParts.year - 1;
            }
            endYear = startYear + 1;
          }

          const startStamp = Date.UTC(startYear, sign.startMonth - 1, sign.startDay);
          const endStamp = Date.UTC(endYear, sign.endMonth - 1, sign.endDay);
          const spanDays = Math.floor((endStamp - startStamp) / dayMs) + 1;
          const offsetDays = Math.max(0, Math.min(spanDays - 1, Math.floor((currentStamp - startStamp) / dayMs)));
          const progress = spanDays <= 1 ? 0 : offsetDays / (spanDays - 1);

          if (progress < 0.25) {
            return 'ignition phase';
          }
          if (progress < 0.5) {
            return 'formation phase';
          }
          if (progress < 0.75) {
            return 'pressure phase';
          }
          return 'release phase';
        };

        const modeDescriptions = {
          general:
            'General reading stays with season, temperament, relation, pressure, and repair.',
          daily:
            'Daily horoscope starts from the same sign architecture, then modulates it through date rhythm and seasonal pressure.',
        };

        const buildGeneralView = (profile, sourceText) => ({
          mode: sourceText === 'Date-based sign resolution' ? 'Date-based reading' : 'Stable sign reading',
          source: sourceText,
          modeDescription: modeDescriptions.general,
          summary: `Stable orientation for ${profile.sign.name}: ${profile.sign.competence} carried through ${profile.sign.element.toLowerCase()} seasonality.`,
          message: profile.message,
          labels: {
            note: 'Key note',
            active: 'Season mood',
            body: 'Body feeling',
            social: 'How it moves',
            shadow: 'Watch for',
            ritual: 'Small ritual',
            prompt: 'Grounding action',
            guidance: 'Grounded guidance',
          },
          values: {
            note: `${profile.sign.competence} is your durable organizing tone.`,
            active: profile.seasonMood,
            body: profile.bodyFeeling,
            social: profile.movementPattern,
            shadow: profile.shadow,
            ritual: profile.ritual,
            prompt: `Where can you practice ${profile.sign.competence.toLowerCase()} in one concrete, accountable way today?`,
            guidance: profile.guidance,
          },
          method: {
            stable: `${profile.sign.name} profile from Breath of the Astral Year fields: competence, civic theme, body register, social pattern, shadow, ritual.`,
            daily: 'No daily modulation in this mode. This is the stable sign baseline.',
            input:
              sourceText === 'Date-based sign resolution'
                ? `Sign resolved from ${monthSelect.options[monthSelect.selectedIndex].text} ${daySelect.value}, then rendered as a stable profile.`
                : `Sign selected directly as ${profile.sign.name}.`,
          },
          contract: {
            stable: `${profile.sign.name} baseline is fully active.`,
            daily: 'Daily modulation is intentionally off in General mode.',
            status: 'This output is a stable sign architecture reading.',
          },
          factors: [
            `Sign baseline: ${profile.sign.competence}`,
            `Seasonal frame: ${profile.sign.civicTheme}`,
            `Input path: ${
              sourceText === 'Date-based sign resolution'
                ? `resolved from ${monthSelect.options[monthSelect.selectedIndex].text} ${daySelect.value}`
                : 'direct sign selection'
            }`,
          ],
        });

        const buildDailyPendingView = (profile, sourceText, reason) => ({
          mode: 'Daily horoscope',
          source: sourceText,
          modeDescription: modeDescriptions.daily,
          summary: 'Daily reading is waiting for a valid calendar date.',
          message: reason,
          labels: {
            note: 'Key note',
            active: 'Season mood',
            body: 'Body feeling',
            social: 'How it moves',
            shadow: 'Watch for',
            ritual: 'Small ritual',
            prompt: 'Grounding action',
            guidance: 'Grounded guidance',
          },
          values: {
            note: 'No daily modulation applied yet.',
            active: 'Enter a valid date to compute day-specific weather.',
            body: 'Body cue appears once date modulation is valid.',
            social: 'Relational move appears once date modulation is valid.',
            shadow: 'Caution line appears once date modulation is valid.',
            ritual: profile.ritual,
            prompt: 'Complete date input to generate today-specific action.',
            guidance: [
              'Daily output is paused until date validation succeeds.',
              'Stable sign reading remains available as your baseline.',
            ],
          },
          method: {
            stable: `${profile.sign.name} base profile is ready.`,
            daily: 'Date modulation is pending valid Gregorian date input.',
            input: 'Awaiting a valid YYYY-MM-DD daily date.',
          },
          contract: {
            stable: `${profile.sign.name} baseline remains active.`,
            daily: 'Daily modulation is paused until date validation succeeds.',
            status: 'Daily mode is selected, but no valid date is currently available.',
          },
          factors: [
            `Sign baseline: ${profile.sign.competence}`,
            'Date factor: pending valid YYYY-MM-DD input',
            'Weekday/day-of-year factors: pending date validation',
          ],
        });

        const buildDailyView = (profile, dateParts, sourceText) => {
          const sign = profile.sign;
          const signIndex = Math.max(0, signOrder.indexOf(sign.slug));
          const ordinal = dayOfYear(dateParts);
          const weekday = dateParts.utcDate.getUTCDay();
          const dayLabel = formatDayLabel(dateParts.year, dateParts.month, dateParts.day);
          const phase = signPhase(sign, dateParts);

          const pulse = dailyPulseFrames[(ordinal + signIndex) % dailyPulseFrames.length];
          const timing = dailyTimingFrames[(weekday + signIndex) % dailyTimingFrames.length];
          const socialMove = dailySocialFrames[(ordinal + weekday + signIndex) % dailySocialFrames.length];
          const cautionLead = dailyCautionFrames[(Math.floor(ordinal / 3) + signIndex) % dailyCautionFrames.length];
          const ritualLead = dailyRitualFrames[(Math.floor(ordinal / 5) + signIndex) % dailyRitualFrames.length];

          const coreOrientation = `${sign.competence} in ${phase}. ${pulse}`;
          const activeNow = `${sign.civicTheme}. ${timing}`;
          const bodyCue = `Track ${sign.bodyRegister}. Keep the body as the first sensor, not the afterthought.`;
          const socialCue = `${socialMove} through ${sign.socialPattern}.`;
          const shadowCue = `${cautionLead} Watch for ${sign.shadow}.`;
          const ritualCue = `${ritualLead} ${sign.ritual}`;

          return {
            mode: 'Daily horoscope',
            source: sourceText,
            modeDescription: modeDescriptions.daily,
            summary: `${sign.name} daily weather: ${coreOrientation}`,
            message: [
              `Today's reading starts from ${sign.name}'s stable profile and applies date-based modulation.`,
              `Civic weather centers on ${sign.civicTheme}, while body register centers on ${sign.bodyRegister}.`,
              `The practical closing move remains ritual: ${sign.ritual}`,
            ].join(' '),
            labels: {
              note: 'Key note',
              active: 'Season mood',
              body: 'Body feeling',
              social: 'How it moves',
              shadow: 'Watch for',
              ritual: 'Small ritual',
              prompt: 'Grounding action',
              guidance: 'Grounded guidance',
            },
            values: {
              note: coreOrientation,
              active: activeNow,
              body: bodyCue,
              social: socialCue,
              shadow: shadowCue,
              ritual: ritualCue,
              prompt: `What single action can you complete before evening that practices ${sign.competence.toLowerCase()} under today's pressure?`,
              guidance: [
                `Timing signal: ${timing}`,
                `Phase signal: ${phase}. Let pace and ambition match that phase.`,
                `Ritual anchor: ${sign.ritual}`,
              ],
            },
            method: {
              stable: `${sign.name} base profile remains fixed: ${sign.competence} / ${sign.civicTheme} / ${sign.bodyRegister}.`,
              daily: `Date modulation for ${dayLabel}: Gregorian day-of-year ${ordinal}, weekday ${weekday}, and sign phase ${phase}.`,
              input: `${sourceText}. Inputs: sign ${sign.name}, date ${dayLabel}.`,
            },
            contract: {
              stable: `${sign.name} baseline remains active.`,
              daily: 'Daily modulation is active from validated date inputs.',
              status: 'This output combines stable sign architecture with date-specific modulation.',
            },
            factors: [
              `Input sign: ${sign.name}`,
              `Date: ${dayLabel}`,
              `Weekday rhythm: ${weekdayLabel(weekday)} (${weekday})`,
              `Day-of-year pulse: ${ordinal}`,
              `Seasonal sign phase: ${phase}`,
            ],
          };
        };

        const renderView = (view) => {
          modeLabel.textContent = view.mode;
          sourceLabel.textContent = view.source;
          modeDescription.textContent = view.modeDescription;
          summary.textContent = view.summary;
          message.textContent = view.message;
          contractStable.textContent = view.contract.stable;
          contractDaily.textContent = view.contract.daily;
          contractStatus.textContent = view.contract.status;

          labelNote.textContent = view.labels.note;
          labelActive.textContent = view.labels.active;
          labelBody.textContent = view.labels.body;
          labelSocial.textContent = view.labels.social;
          labelShadow.textContent = view.labels.shadow;
          labelRitual.textContent = view.labels.ritual;
          labelPrompt.textContent = view.labels.prompt;
          labelGuidance.textContent = view.labels.guidance;

          note.textContent = view.values.note;
          active.textContent = view.values.active;
          body.textContent = view.values.body;
          social.textContent = view.values.social;
          shadow.textContent = view.values.shadow;
          ritual.textContent = view.values.ritual;
          prompt.textContent = view.values.prompt;

          guidance.innerHTML = '';
          view.values.guidance.forEach((line) => {
            const item = document.createElement('li');
            item.textContent = line;
            guidance.appendChild(item);
          });

          contractFactors.innerHTML = '';
          view.factors.forEach((line) => {
            const item = document.createElement('li');
            item.textContent = line;
            contractFactors.appendChild(item);
          });

          methodStable.textContent = view.method.stable;
          methodDaily.textContent = view.method.daily;
          methodInput.textContent = view.method.input;
        };

        const syncSignButtons = (activeSlug) => {
          signButtons.forEach((button) => {
            const isActive = button.dataset.sign === activeSlug;
            button.setAttribute('aria-pressed', isActive ? 'true' : 'false');
          });
        };

        const syncHiddenSignSelections = (slug) => {
          if (hasSignSlug(slug)) {
            signSelect.value = slug;
            dailySignSelect.value = slug;
          }
        };

        const updateGenerateLabel = () => {
          const profile = signBySlug(currentSignSlug);
          generateButton.textContent =
            currentMode === 'daily' ? 'Generate Daily Horoscope' : `Generate ${profile.sign.name} Reading`;
        };

        const renderPreview = (slug) => {
          const profile = signBySlug(slug);
          if (!profile) {
            return;
          }

          shell.style.setProperty('--gaia-sign-color', profile.sign.color);
          previewGlyph.textContent = profile.sign.glyph;
          previewSign.textContent = profile.sign.name;
          previewElement.textContent = profile.sign.element;
          previewRange.textContent = profile.sign.dateLabel;
          previewCompetence.textContent = profile.sign.competence;
          previewCivic.textContent = profile.sign.civicTheme;
          previewBody.textContent = profile.sign.bodyRegister;
          previewShadow.textContent = profile.sign.shadow;
          previewRitual.textContent = profile.sign.ritual;
          syncSignButtons(profile.sign.slug);
          updateGenerateLabel();
        };

        const applyUrlState = () => {
          const params = new URLSearchParams();
          params.set('mode', currentMode);
          params.set('sign', currentSignSlug);

          const generalDate = normalizeGeneralMonthDay(Number(monthSelect.value || 1), Number(daySelect.value || 1));
          if (lastGeneralSource === 'Date-based sign resolution') {
            params.set('month', String(generalDate.month));
            params.set('day', String(generalDate.day));
            params.set('entry', 'date');
          } else if (currentMode === 'daily' && dailyDateInput.value) {
            params.set('entry', lastDailySource === 'Sign resolved from date + daily modulation' ? 'date-sign' : 'manual');
          }

          const parsedDailyDate = parseDateInputValue(dailyDateInput.value);
          if (parsedDailyDate) {
            params.set('date', parsedDailyDate.isoDate);
          }

          const query = params.toString();
          const nextUrl = query ? `${window.location.pathname}?${query}` : window.location.pathname;
          window.history.replaceState(null, '', nextUrl);
        };

        const clearOutput = () => {
          output.hidden = true;
          output.removeAttribute('data-visible');
          setShareStatus();
        };

        const showOutput = () => {
          output.hidden = false;
          output.setAttribute('data-visible', 'true');
        };

        let currentMode = 'general';
        let currentSignSlug = signOrder[0];
        let lastGeneralSource = 'Direct sign selection';
        let lastDailySource = 'Manual sign + date';

        const generateCurrentView = () => {
          const profile = signBySlug(currentSignSlug);
          if (!profile) {
            return false;
          }

          if (currentMode === 'general') {
            renderView(buildGeneralView(profile, lastGeneralSource));
            entryMode.textContent =
              lastGeneralSource === 'Date-based sign resolution'
                ? `Resolved from ${monthSelect.options[monthSelect.selectedIndex].text} ${daySelect.value}.`
                : 'Currently showing the direct sign reading.';
            dailyMode.textContent = 'Daily reading combines stable sign pattern with date and weekday modulation.';
          } else {
            const parsed = parseDateInputValue(dailyDateInput.value);
            if (!parsed) {
              renderView(buildDailyPendingView(profile, lastDailySource, 'Choose a valid date to generate the daily reading.'));
            } else {
              renderView(buildDailyView(profile, parsed, lastDailySource));
            }
            entryMode.textContent = 'Stable sign reading remains available as your baseline.';
          }

          showOutput();
          setShareStatus();
          applyUrlState();
          return true;
        };

        const setMode = (mode, options = {}) => {
          if (!validMode(mode)) {
            return;
          }

          currentMode = mode;
          const isGeneral = mode === 'general';
          modeGeneralButton.setAttribute('aria-pressed', isGeneral ? 'true' : 'false');
          modeDailyButton.setAttribute('aria-pressed', isGeneral ? 'false' : 'true');
          dailyControls.hidden = isGeneral;
          modeDescription.textContent = isGeneral ? modeDescriptions.general : modeDescriptions.daily;
          updateGenerateLabel();
          applyUrlState();

          if (!options.preserveOutput) {
            clearOutput();
          }
        };

        const selectSign = (slug, sourceText = 'Direct sign selection') => {
          if (!hasSignSlug(slug)) {
            return;
          }

          currentSignSlug = slug;
          syncHiddenSignSelections(slug);
          lastGeneralSource = sourceText;
          if (currentMode === 'daily' && sourceText === 'Sign resolved from date + daily modulation') {
            lastDailySource = sourceText;
          }

          renderPreview(slug);
          clearOutput();
          applyUrlState();
        };

        const hydrateFromUrl = () => {
          const params = new URLSearchParams(window.location.search);
          const mode = params.get('mode');
          if (validMode(mode)) {
            currentMode = mode;
          }

          const dateParam = params.get('date');
          const parsedDate = dateParam ? parseDateInputValue(dateParam) : null;
          if (parsedDate) {
            dailyDateInput.value = parsedDate.isoDate;
            applyMonthDay(parsedDate.month, parsedDate.day);
          }

          const monthParam = params.get('month');
          const dayParam = params.get('day');
          if (monthParam !== null && dayParam !== null) {
            const month = Number(monthParam);
            const day = Number(dayParam);
            if (Number.isInteger(month) && Number.isInteger(day)) {
              applyMonthDay(month, day);
            }
          }

          const sign = params.get('sign');
          if (sign && hasSignSlug(sign)) {
            currentSignSlug = sign;
            syncHiddenSignSelections(sign);
          } else if (params.get('entry') === 'date') {
            const slug = resolveSignSlugByMonthDay(Number(monthSelect.value), Number(daySelect.value));
            if (slug) {
              currentSignSlug = slug;
              syncHiddenSignSelections(slug);
            }
          }

          if (params.get('entry') === 'date') {
            lastGeneralSource = 'Date-based sign resolution';
          }

          if (params.get('entry') === 'date-sign') {
            lastDailySource = 'Sign resolved from date + daily modulation';
          }
        };

        const now = new Date();
        const todayValue = toDateInputValue(now);
        const todayMonth = now.getMonth() + 1;
        const todayDay = now.getDate();
        const todaySign = resolveSignSlugByMonthDay(todayMonth, todayDay) || signOrder[0];

        rebuildDays(Number(monthSelect.value || 1), Number(daySelect.value || 1));
        applyMonthDay(todayMonth, todayDay);
        dailyDateInput.value = todayValue;
        currentSignSlug = todaySign;
        syncHiddenSignSelections(todaySign);

        hydrateFromUrl();
        renderPreview(currentSignSlug);
        setMode(currentMode, { preserveOutput: true });

        signButtons.forEach((button) => {
          button.addEventListener('click', () => {
            selectSign(button.dataset.sign || '', 'Direct sign selection');
          });
        });

        modeGeneralButton.addEventListener('click', () => {
          setMode('general');
        });

        modeDailyButton.addEventListener('click', () => {
          setMode('daily');
        });

        dailyDateInput.addEventListener('change', () => {
          const parsed = parseDateInputValue(dailyDateInput.value);
          if (parsed) {
            applyMonthDay(parsed.month, parsed.day);
          }
          lastDailySource = 'Manual sign + date';
          clearOutput();
          applyUrlState();
        });

        dailyResolveSignButton.addEventListener('click', () => {
          const parsed = parseDateInputValue(dailyDateInput.value);
          if (!parsed) {
            clearOutput();
            setShareStatus('Enter a valid daily date before resolving sign.');
            return;
          }

          const slug = resolveSignSlugByMonthDay(parsed.month, parsed.day);
          if (slug) {
            currentSignSlug = slug;
            syncHiddenSignSelections(slug);
            lastDailySource = 'Sign resolved from date + daily modulation';
            renderPreview(slug);
            clearOutput();
            applyUrlState();
          }
        });

        dailyTodayButton.addEventListener('click', () => {
          dailyDateInput.value = todayValue;
          applyMonthDay(todayMonth, todayDay);
          currentSignSlug = todaySign;
          syncHiddenSignSelections(todaySign);
          lastDailySource = 'Manual sign + date';
          renderPreview(todaySign);
          clearOutput();
          applyUrlState();
        });

        generateButton.addEventListener('click', () => {
          generateCurrentView();
        });

        shareButton.addEventListener('click', async () => {
          setShareStatus();
          const shareUrl = `${window.location.origin}${window.location.pathname}${window.location.search}#gaia-tool`;
          try {
            if (navigator.clipboard && navigator.clipboard.writeText) {
              await navigator.clipboard.writeText(shareUrl);
              setShareStatus('Share link copied.');
            } else {
              setShareStatus('Clipboard unavailable. Copy from your browser URL bar.');
            }
          } catch (error) {
            setShareStatus('Could not copy automatically. Copy from your browser URL bar.');
            console.warn('[GAIA] Share copy failed:', error);
          }
        });

        resetButton.addEventListener('click', () => {
          currentMode = 'general';
          currentSignSlug = todaySign;
          lastGeneralSource = 'Direct sign selection';
          lastDailySource = 'Manual sign + date';
          dailyDateInput.value = todayValue;
          applyMonthDay(todayMonth, todayDay);
          syncHiddenSignSelections(todaySign);
          renderPreview(todaySign);
          setMode('general', { preserveOutput: true });
          clearOutput();
          window.history.replaceState(null, '', window.location.pathname);
          setShareStatus();
          entryMode.textContent = 'Currently showing the direct sign reading.';
        });

        if (window.location.search) {
          generateCurrentView();
        } else {
          clearOutput();
        }
      }
    }
  </script>
</div>

