---
import type { AstralSign } from '../../data/astralYear';
import { buildAstralGaialogyProfile, determineAstralSign } from '../../data/astralGaialogy';

interface Props {
  signs: AstralSign[];
}

const { signs } = Astro.props;

const monthOptions = [
  { value: 1, label: 'January', days: 31 },
  { value: 2, label: 'February', days: 29 },
  { value: 3, label: 'March', days: 31 },
  { value: 4, label: 'April', days: 30 },
  { value: 5, label: 'May', days: 31 },
  { value: 6, label: 'June', days: 30 },
  { value: 7, label: 'July', days: 31 },
  { value: 8, label: 'August', days: 31 },
  { value: 9, label: 'September', days: 30 },
  { value: 10, label: 'October', days: 31 },
  { value: 11, label: 'November', days: 30 },
  { value: 12, label: 'December', days: 31 },
];

const initialSign = signs[0];
const profilesBySlug = Object.fromEntries(
  signs.map((sign) => [sign.slug, buildAstralGaialogyProfile({ sign: sign.slug })]),
);
const initialProfile = profilesBySlug[initialSign.slug];

const dateLookup = Object.fromEntries(
  monthOptions.flatMap((month) =>
    Array.from({ length: month.days }, (_, index) => index + 1).map((day) => [
      `${month.value}-${day}`,
      determineAstralSign(month.value, day).slug,
    ]),
  ),
);

const appData = {
  profiles: profilesBySlug,
  months: monthOptions,
  dateLookup,
  signOrder: signs.map((sign) => sign.slug),
};
---

<div class="astral-app-shell" id="gaia-app-shell">
  <div class="grid gap-8 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-start">
    <section class="veil-panel astral-control-panel">
      <p class="eyebrow">GAIA reading tool</p>
      <h2 class="mt-4 text-[1.56rem] leading-tight md:text-[1.82rem]">Choose your reading path.</h2>
      <p class="mt-4 max-w-xl text-base leading-7 text-slate-200">
        GAIA keeps one Earth-based grammar and offers two outputs: a stable sign profile and a date-modulated daily
        horoscope. Both come from the same Breath of the Astral Year method fields.
      </p>

      <div class="astral-mode-toggle mt-8" role="group" aria-label="Reading modes">
        <button id="astral-mode-general" type="button" class="astral-mode-button" data-mode="general" aria-pressed="true">
          General reading
        </button>
        <button id="astral-mode-daily" type="button" class="astral-mode-button" data-mode="daily" aria-pressed="false">
          Daily horoscope
        </button>
      </div>
      <p id="astral-mode-description" class="astral-flow-note mt-4">
        General reading gives the stable sign architecture: competence, season weather, body register, relation, shadow, ritual.
      </p>

      <div id="astral-general-controls" class="astral-control-group mt-8 grid gap-5">
        <div class="astral-input-card">
          <label class="astral-label" for="astral-sign-select">General sign</label>
          <select id="astral-sign-select" class="astral-select">
            {signs.map((sign) => (
              <option value={sign.slug}>{sign.name} - {sign.dateLabel}</option>
            ))}
          </select>
          <p class="mt-3 text-sm leading-6 text-slate-400">
            Use this for a stable orientation reading that does not depend on one specific day.
          </p>
        </div>

        <div class="astral-input-card">
          <label class="astral-label" for="astral-month-select">Resolve sign by month and day</label>
          <div class="mt-3 grid gap-3 sm:grid-cols-[minmax(0,1fr)_120px]">
            <select id="astral-month-select" class="astral-select">
              {monthOptions.map((month) => (
                <option value={month.value}>{month.label}</option>
              ))}
            </select>
            <select id="astral-day-select" class="astral-select">
              {Array.from({ length: monthOptions[0].days }, (_, index) => index + 1).map((day) => (
                <option value={day}>{day}</option>
              ))}
            </select>
          </div>
          <div class="mt-4 flex flex-wrap gap-3">
            <button id="astral-date-submit" type="button" class="button-primary">Resolve sign by date</button>
            <button id="astral-general-today" type="button" class="button-secondary">Use today's sign</button>
            <button id="astral-date-reset" type="button" class="button-secondary">Back to direct sign</button>
          </div>
          <p id="astral-entry-mode" class="mt-3 text-sm leading-6 text-slate-400">
            Currently showing the direct sign reading.
          </p>
          <p class="mt-2 text-xs leading-6 text-slate-500">
            Month/day sign resolution is seasonal and year-agnostic. Daily horoscope uses full Gregorian date validation.
          </p>
        </div>
      </div>

      <div id="astral-daily-controls" class="astral-control-group mt-8 grid gap-5" hidden>
        <div class="astral-input-card">
          <label class="astral-label" for="astral-daily-sign-select">Daily sign</label>
          <select id="astral-daily-sign-select" class="astral-select">
            {signs.map((sign) => (
              <option value={sign.slug}>{sign.name} - {sign.dateLabel}</option>
