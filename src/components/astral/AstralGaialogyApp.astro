      <div class="mt-6 grid gap-4 md:grid-cols-2">
        <article class="astral-reading-card">
          <p class="astral-mini-label">Stable baseline</p>
          <p id="astral-contract-stable" class="mt-2 text-sm leading-6 text-slate-200"></p>
        </article>
        <article class="astral-reading-card">
