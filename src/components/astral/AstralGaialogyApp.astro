      radial-gradient(circle at center, rgba(204, 153, 103, 0.22), rgba(204, 153, 103, 0) 68%),
      radial-gradient(circle at 24% 16%, rgba(95, 127, 174, 0.14), rgba(95, 127, 174, 0) 62%),
