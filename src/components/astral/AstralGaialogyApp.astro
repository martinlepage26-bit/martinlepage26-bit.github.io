        </div>

        <div class="astral-input-card">
          <label class="astral-label" for="astral-daily-date">Forecast date</label>
          <input id="astral-daily-date" type="date" class="astral-date-input" />
          <div class="mt-4 flex flex-wrap gap-3">
            <button id="astral-daily-generate" type="button" class="button-primary">Generate daily horoscope</button>
            <button id="astral-daily-resolve-sign" type="button" class="button-secondary">Use sign from date</button>
            <button id="astral-daily-today" type="button" class="button-secondary">Use today</button>
          </div>
