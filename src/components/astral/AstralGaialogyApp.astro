      <article class="astral-prompt-card mt-4">
        <p id="astral-label-prompt" class="astral-mini-label">Grounding action</p>
        <p id="astral-result-prompt" class="mt-2 text-base leading-7 text-slate-200">
          Name one concrete action that practices {initialProfile.keyNote.toLowerCase()} in your real day.
        </p>
      </article>

      <div class="mt-6 astral-guidance-strip">
        <p id="astral-label-guidance" class="astral-mini-label">Grounded guidance</p>
        <ul id="astral-result-guidance" class="mt-3 space-y-2 text-sm leading-6 text-slate-200">
          {initialProfile.guidance.map((line) => (
            <li>{line}</li>
          ))}
        </ul>
      </div>

      <details class="astral-method-details mt-6">
        <summary>How this reading is formed</summary>
        <div class="astral-method-grid mt-4">
          <div class="astral-method-row">
            <p class="astral-mini-label">Stable sign pattern</p>
            <p id="astral-method-stable" class="mt-2 text-sm leading-6 text-slate-200"></p>
          </div>
