---
import { classicalElements, type AstralSign } from '../../data/astralYear';

interface Props {
  signs: AstralSign[];
}

const { signs } = Astro.props as Props;

const fieldDefinitions = [
  { key: 'civicTheme', label: 'Civic theme' },
  { key: 'bodyRegister', label: 'Body register' },
  { key: 'socialPattern', label: 'Social pattern' },
  { key: 'shadow', label: 'Shadow' },
  { key: 'ritual', label: 'Ritual' },
] as const;

const groupedSigns = classicalElements
  .map((element) => ({
    element,
    signs: signs.filter((sign) => sign.element === element.name),
  }))
  .filter((group) => group.signs.length > 0);
---

<div class="space-y-12" id="astral-glossary-grid">
  <nav class="flex flex-wrap gap-3">
    {groupedSigns.map(({ element }) => (
      <a class="glossary-nav-pill" href={`#${element.slug}`}>
        {element.name}
      </a>
    ))}
  </nav>

  {groupedSigns.map(({ element, signs: elementSigns }) => (
    <section id={element.slug} class="glossary-element-group" style={`--element-color:${element.color};`}>
      <div class="glossary-element-head">
        <div class="max-w-xl">
          <p class="eyebrow">Element</p>
          <h3 class="mt-4 text-[1.45rem] md:text-[1.85rem]">{element.name}</h3>
          <p class="mt-3 text-sm uppercase tracking-[0.16em] text-slate-400">
            {element.signs.join(' / ')}
          </p>
        </div>
        <p class="max-w-2xl text-base leading-7 text-slate-300">
          <strong>{element.traits}</strong> {element.bookUse}
        </p>
      </div>

      <div class="mt-6 grid gap-6 lg:grid-cols-3 md:grid-cols-2">
        {elementSigns.map((sign) => (
          <article class="glossary-card" id={sign.slug} style={`--sign-color:${sign.color};`}>
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="glossary-sign-meta">{sign.dateLabel}</p>
                <h4 class="mt-2 text-[1.25rem] md:text-[1.45rem]">
                  <span class="glossary-sign-glyph">{sign.glyph}</span>
                  <span>{sign.name}</span>
                </h4>
              </div>
              <div class="glossary-competence">
                <span class="glossary-competence-label">Competence</span>
                <span>{sign.competence}</span>
              </div>
            </div>

            <dl class="mt-5 grid gap-4 md:grid-cols-2">
              {fieldDefinitions.map((field) => (
                <div class="glossary-field">
                  <dt>{field.label}</dt>
                  <dd>{sign[field.key]}</dd>
                </div>
              ))}
            </dl>
          </article>
        ))}
      </div>
    </section>
  ))}
</div>

<style>
  .glossary-nav-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.7rem 1rem;
    border-radius: 999px;
    border: 1px solid rgba(201, 149, 47, 0.18);
    background: rgba(17, 34, 70, 0.46);
    color: var(--color-moon);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    box-shadow: inset 0 1px 0 rgba(248, 243, 234, 0.05);
  }

  .glossary-nav-pill:hover {
    border-color: rgba(201, 149, 47, 0.38);
    color: var(--color-aqua);
  }

  .glossary-element-group {
    --element-accent: color-mix(in srgb, var(--element-color) 34%, transparent);
    padding: 1.2rem;
    border: 1px solid rgba(201, 149, 47, 0.14);
    border-radius: 1.4rem;
    background:
      radial-gradient(circle at top left, var(--element-accent) 0%, transparent 45%),
      linear-gradient(180deg, rgba(17, 34, 70, 0.58), rgba(8, 17, 32, 0.7));
    box-shadow:
      0 18px 36px rgba(5, 3, 10, 0.16),
      inset 0 1px 0 rgba(248, 243, 234, 0.04);
  }

  .glossary-element-head {
    display: grid;
    gap: 1rem;
    align-items: start;
  }

  @media (min-width: 1024px) {
    .glossary-element-head {
      grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
      gap: 1.5rem;
    }
  }

  .glossary-card {
    --card-accent: color-mix(in srgb, var(--sign-color) 24%, transparent);
    height: 100%;
    padding: 1.15rem;
    border-radius: 1.15rem;
    border: 1px solid rgba(201, 149, 47, 0.16);
    background:
      radial-gradient(circle at top right, var(--card-accent) 0%, transparent 42%),
      linear-gradient(180deg, rgba(14, 10, 28, 0.9), rgba(25, 16, 40, 0.92));
    box-shadow:
      0 14px 32px rgba(5, 3, 10, 0.16),
      inset 0 1px 0 rgba(248, 243, 234, 0.04);
  }

  .glossary-sign-meta {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-aqua);
  }

  .glossary-sign-glyph {
    margin-right: 0.5rem;
    color: var(--sign-color);
  }

  .glossary-competence {
    display: grid;
    gap: 0.3rem;
    justify-items: end;
    text-align: right;
  }

  .glossary-competence-label {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-slate-ink);
  }

  .glossary-competence span:last-child {
    color: var(--color-moon);
    font-size: 0.94rem;
    font-weight: 600;
  }

  .glossary-field {
    border-radius: 0.95rem;
    border: 1px solid rgba(255, 255, 255, 0.06);
    background: rgba(255, 255, 255, 0.03);
    padding: 0.85rem 0.9rem;
  }

  .glossary-field dt {
    font-family: var(--font-mono);
    font-size: 0.64rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    line-height: 1.4;
    text-transform: uppercase;
    color: var(--color-aqua);
  }

  .glossary-field dd {
    margin-top: 0.5rem;
    font-size: 0.92rem;
    line-height: 1.7;
    color: var(--color-moon);
  }
</style>
