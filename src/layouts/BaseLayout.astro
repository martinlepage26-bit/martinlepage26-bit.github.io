---
import { buildCanonical, buildPersonSchema } from '../lib/seo';
import { pageMeta, siteMeta } from '../data/site';
import '../styles/global.css';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
  ogType?: 'website' | 'article';
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description, image, canonical, ogType = 'website', structuredData } = Astro.props;
const pageTitle = title ? (title.includes(siteMeta.title) ? title : `${title} | ${siteMeta.title}`) : siteMeta.title;
const pageDescription = description ?? siteMeta.description;
const canonicalUrl = canonical ? buildCanonical(canonical) : buildCanonical(Astro.url.pathname);
const ogImagePath = image ?? '/social/og-default.png';
const ogImage = siteMeta.siteUrl
  ? new URL(ogImagePath, siteMeta.siteUrl).toString()
  : ogImagePath;
const socialImageAlt = `${pageTitle} social preview`;

const structuredPayload = [
  buildPersonSchema(),
  ...(Array.isArray(structuredData)
    ? structuredData
    : structuredData
      ? [structuredData]
      : []),
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={pageDescription} />
    <meta name="theme-color" content="#f2ede7" />
    <meta name="color-scheme" content="light" />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/site.webmanifest" />
    {siteMeta.siteUrl && <link rel="alternate" type="application/rss+xml" title={pageMeta.rss.title} href="/rss.xml" />}

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={socialImageAlt} />
    <meta property="og:locale" content={siteMeta.locale} />
    <meta property="og:site_name" content={siteMeta.name} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={socialImageAlt} />

    <title>{pageTitle}</title>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredPayload)} />
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <div class="site-aurora" aria-hidden="true"></div>
    <div class="site-frame">
      <SiteHeader />
      <main id="content">
        <slot />
      </main>
      <SiteFooter />
    </div>
  </body>
</html>
