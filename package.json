{
  "name": "martin-lepage-site",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "dev:local": "astro dev --host 127.0.0.1 --port 4510 --strictPort",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "lotus:check": "node ./scripts/lotus-validate.mjs",
    "lotus:full-check": "npm run build && npm run lotus:smoke",
    "lotus:smoke": "node ./scripts/lotus-smoke.mjs",
    "lotus:e2e": "npm run build && playwright test tests/lotus-bloom-e2e.spec.ts",
    "smoke": "node ./scripts/smoke.mjs",
    "deploy:echo:worker": "cd workers/echo-tts-online && npx wrangler deploy",
    "deploy:echo:site": "npm run build && npx wrangler pages deploy dist --project-name martin-lepage-site --branch main --commit-dirty=true",
    "deploy:echo": "npm run deploy:echo:worker && npm run deploy:echo:site",
    "inventory:corpus": "node ./scripts/generate-corpus-inventory.mjs",
    "inventory:external": "python3 ./scripts/generate-external-corpus-inventory.py",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.0",
    "@astrojs/react": "^5.0.2",
    "@astrojs/rss": "^4.0.17",
    "@astrojs/sitemap": "^3.7.1",
    "@breezystack/lamejs": "^1.2.7",
    "@fontsource-variable/manrope": "^5.2.8",
    "@fontsource-variable/newsreader": "^5.2.10",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@fontsource/crimson-text": "^5.2.7",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/lato": "^5.2.7",
    "@tailwindcss/vite": "^4.2.1",
    "astro": "^6.0.3",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "mespeak": "^2.0.2",
    "pdfjs-dist": "^5.5.207",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.1",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.7",
    "@playwright/test": "^1.58.2",
    "typescript": "^5.9.3"
  }
}
